<?xml version="1.0" encoding="utf-8"?>
<!--
    Command Center design tokens — the single source of truth for the HUD visual language.
    Surfaces/text live in ThemeDictionaries (Default = dark, the design target; Light = fallback).
    Accent + semantic-status brushes are top-level (near theme-invariant) so controls can resolve
    them from code-behind. Spacing / radii / typography are theme-independent.
    See docs/REDESIGN-COMMAND-CENTER.md.
-->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.ThemeDictionaries>
        <!-- DARK (design target) — frosted "holo glass" surfaces -->
        <ResourceDictionary x:Key="Default">
            <AcrylicBrush x:Key="HudSurfaceBrush" TintColor="#141B2E" TintOpacity="0.5"
                          TintLuminosityOpacity="0.42" FallbackColor="#E0141B2E" />
            <AcrylicBrush x:Key="HudSurfaceAltBrush" TintColor="#0B1018" TintOpacity="0.6"
                          TintLuminosityOpacity="0.4" FallbackColor="#E60B1018" />
            <SolidColorBrush x:Key="HudHairlineBrush"    Color="#1FFFFFFF" />
            <SolidColorBrush x:Key="HudGridLineBrush"    Color="#12FFFFFF" />
            <SolidColorBrush x:Key="HudTextPrimaryBrush" Color="#FFEAF0FA" />
        </ResourceDictionary>
        <!-- LIGHT (fallback) -->
        <ResourceDictionary x:Key="Light">
            <AcrylicBrush x:Key="HudSurfaceBrush" TintColor="#FFFFFF" TintOpacity="0.4"
                          TintLuminosityOpacity="0.72" FallbackColor="#F2FFFFFF" />
            <AcrylicBrush x:Key="HudSurfaceAltBrush" TintColor="#F3F5F9" TintOpacity="0.5"
                          TintLuminosityOpacity="0.8" FallbackColor="#FFF3F5F9" />
            <SolidColorBrush x:Key="HudHairlineBrush"    Color="#14000000" />
            <SolidColorBrush x:Key="HudGridLineBrush"    Color="#0A000000" />
            <SolidColorBrush x:Key="HudTextPrimaryBrush" Color="#FF0B0F17" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <!-- ── Accent ramp (electric cyan) — top-level ────────────────────────── -->
    <SolidColorBrush x:Key="AccentCyanBrush"       Color="#FF38BDF8" />
    <SolidColorBrush x:Key="AccentCyanBrightBrush" Color="#FF7DD3FC" />
    <SolidColorBrush x:Key="AccentCyanDeepBrush"   Color="#FF0EA5E9" />
    <SolidColorBrush x:Key="AccentGlowBrush"       Color="#6638BDF8" />
    <SolidColorBrush x:Key="AccentSoftBrush"       Color="#2638BDF8" />
    <SolidColorBrush x:Key="OnAccentBrush"         Color="#FF06121A" />
    <Color x:Key="AccentCyanColor">#FF38BDF8</Color>
    <Color x:Key="AccentCyanDeepColor">#FF0EA5E9</Color>

    <!-- Secondary accent (violet) for the holo cyan→violet sheen -->
    <SolidColorBrush x:Key="VioletBrush"     Color="#FFA78BFA" />
    <SolidColorBrush x:Key="VioletSoftBrush" Color="#26A78BFA" />
    <Color x:Key="VioletColor">#FFA78BFA</Color>

    <!-- Glowing glass edge: cyan → violet → cyan diagonal -->
    <LinearGradientBrush x:Key="HudGlassBorderBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#A638BDF8" Offset="0.0" />
        <GradientStop Color="#59A78BFA" Offset="0.5" />
        <GradientStop Color="#8C38BDF8" Offset="1.0" />
    </LinearGradientBrush>

    <!-- Top sheen overlay for glass surfaces (subtle light from above) -->
    <LinearGradientBrush x:Key="HudSheenBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#14FFFFFF" Offset="0.0" />
        <GradientStop Color="#00FFFFFF" Offset="0.45" />
    </LinearGradientBrush>

    <!-- Deep page background gradient (gives the acrylic something to refract) -->
    <LinearGradientBrush x:Key="HudPageBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF070B14" Offset="0.0" />
        <GradientStop Color="#FF0A1020" Offset="0.5" />
        <GradientStop Color="#FF0B0816" Offset="1.0" />
    </LinearGradientBrush>

    <!-- ── Semantic status — top-level ────────────────────────────────────── -->
    <SolidColorBrush x:Key="SuccessBrush"     Color="#FF34D399" />
    <SolidColorBrush x:Key="SuccessSoftBrush" Color="#2634D399" />
    <SolidColorBrush x:Key="WarningBrush"     Color="#FFF59E0B" />
    <SolidColorBrush x:Key="WarningSoftBrush" Color="#26F59E0B" />
    <SolidColorBrush x:Key="DangerBrush"      Color="#FFF87171" />
    <SolidColorBrush x:Key="DangerSoftBrush"  Color="#26F87171" />
    <SolidColorBrush x:Key="InfoBrush"        Color="#FF60A5FA" />
    <SolidColorBrush x:Key="InfoSoftBrush"    Color="#2660A5FA" />
    <SolidColorBrush x:Key="MutedBrush"       Color="#FF9CA3AF" />
    <SolidColorBrush x:Key="MutedSoftBrush"   Color="#269CA3AF" />

    <!-- ── Spacing scale (8pt grid) ───────────────────────────────────────── -->
    <x:Double x:Key="SpacingXs">4</x:Double>
    <x:Double x:Key="SpacingS">8</x:Double>
    <x:Double x:Key="SpacingM">12</x:Double>
    <x:Double x:Key="SpacingL">16</x:Double>
    <x:Double x:Key="SpacingXl">24</x:Double>
    <x:Double x:Key="Spacing2Xl">32</x:Double>

    <Thickness x:Key="CardPadding">16</Thickness>
    <Thickness x:Key="CardPaddingTight">12</Thickness>
    <Thickness x:Key="PillPadding">8,3</Thickness>

    <!-- ── Geometry ───────────────────────────────────────────────────────── -->
    <CornerRadius x:Key="CardCornerRadius">16</CornerRadius>
    <CornerRadius x:Key="InnerCornerRadius">10</CornerRadius>
    <CornerRadius x:Key="PillCornerRadius">999</CornerRadius>

    <!-- ── Typography ─────────────────────────────────────────────────────── -->
    <Style x:Key="HudDisplayStyle" TargetType="TextBlock" BasedOn="{StaticResource BaseTextBlockStyle}">
        <Setter Property="FontSize" Value="40" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="LineHeight" Value="44" />
    </Style>
    <Style x:Key="HudTitleStyle" TargetType="TextBlock" BasedOn="{StaticResource BaseTextBlockStyle}">
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style x:Key="HudSubtitleStyle" TargetType="TextBlock" BasedOn="{StaticResource BaseTextBlockStyle}">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style x:Key="HudBodyStyle" TargetType="TextBlock" BasedOn="{StaticResource BaseTextBlockStyle}">
        <Setter Property="FontSize" Value="14" />
    </Style>
    <Style x:Key="HudCaptionStyle" TargetType="TextBlock" BasedOn="{StaticResource BaseTextBlockStyle}">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
    </Style>
    <Style x:Key="HudMicroStyle" TargetType="TextBlock" BasedOn="{StaticResource BaseTextBlockStyle}">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CharacterSpacing" Value="100" />
        <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
    </Style>
    <Style x:Key="HudMetricStyle" TargetType="TextBlock" BasedOn="{StaticResource BaseTextBlockStyle}">
        <Setter Property="FontFamily" Value="Consolas" />
        <Setter Property="FontSize" Value="26" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style x:Key="HudMonoSmallStyle" TargetType="TextBlock" BasedOn="{StaticResource BaseTextBlockStyle}">
        <Setter Property="FontFamily" Value="Consolas" />
        <Setter Property="FontSize" Value="12" />
    </Style>

</ResourceDictionary>
