<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="Optimizer.WinUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Optimizer.WinUI.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <!-- Command Center design tokens (colors, typography, spacing, radii) -->
                <ResourceDictionary Source="ms-appx:///Styles/Tokens.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <!-- Earned accent: the hub rail's active indicator glows cyan -->
            <SolidColorBrush x:Key="NavigationViewSelectionIndicatorForeground" Color="#FF38BDF8" />
            <!-- App-wide converter. Pages used to declare this 19× — now one instance is shared.
                 Supports ConverterParameter=Invert for negated bindings. -->
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
