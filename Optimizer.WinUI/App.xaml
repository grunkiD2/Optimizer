<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="Optimizer.WinUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <!-- Command Center design tokens (colors, typography, spacing, radii) -->
                <ResourceDictionary Source="ms-appx:///Styles/Tokens.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <!-- Earned accent: the hub rail's active indicator glows cyan -->
            <SolidColorBrush x:Key="NavigationViewSelectionIndicatorForeground" Color="#FF38BDF8" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
