<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Optimizer.WinUI.Views.CommandCenterPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:hud="using:Optimizer.WinUI.Controls.Hud"
    Background="Transparent">

    <hud:HudBackdrop>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="36,28,36,36">
            <StackPanel Spacing="28" MaxWidth="1280" HorizontalAlignment="Left">

                <!-- Header: context + title -->
                <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                    <Border CornerRadius="{StaticResource PillCornerRadius}"
                            Background="{StaticResource AccentSoftBrush}"
                            BorderBrush="{StaticResource HudGlassBorderBrush}" BorderThickness="1"
                            Padding="12,5" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="&#x25D7;" Foreground="{StaticResource AccentCyanBrush}" FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock x:Name="CtxText" Text="DETECTING&#x2026;" Foreground="{StaticResource AccentCyanBrightBrush}"
                                       FontWeight="SemiBold" FontSize="12" CharacterSpacing="60" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <TextBlock Text="Command Center" Style="{StaticResource HudTitleStyle}" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Quick actions — the command center does things, not just shows them -->
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <Button Click="OptimizeGaming_Click" Style="{StaticResource AccentButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE945;" FontSize="14"/>
                            <TextBlock Text="Optimize for Gaming"/>
                        </StackPanel>
                    </Button>
                    <Button Click="RunCleanup_Click" Content="Run Cleanup"/>
                    <Button Click="ContextDetect_Click" Content="Re-detect Context"/>
                    <TextBlock x:Name="ActionStatus" Style="{StaticResource HudCaptionStyle}"
                               VerticalAlignment="Center" Margin="6,0,0,0"/>
                </StackPanel>

                <!-- Hero: health ring + live vitals -->
                <Grid ColumnSpacing="28">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            CornerRadius="{StaticResource CardCornerRadius}"
                            Background="{ThemeResource HudSurfaceBrush}"
                            BorderBrush="{StaticResource HudGlassBorderBrush}" BorderThickness="1"
                            Padding="24" VerticalAlignment="Stretch">
                        <hud:HealthRing x:Name="HealthRingControl" VerticalAlignment="Center"/>
                    </Border>

                    <Grid Grid.Column="1" ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <hud:StatTile x:Name="CpuTile" Grid.Column="0" Label="CPU" Unit="%" Value="--"/>
                        <hud:StatTile x:Name="GpuTile" Grid.Column="1" Label="GPU" Unit="%" Value="--"/>
                        <hud:StatTile x:Name="RamTile" Grid.Column="2" Label="MEMORY" Unit="GB" Value="--"/>
                    </Grid>
                </Grid>

                <!-- Needs attention + automation -->
                <Grid ColumnSpacing="28">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>

                    <hud:HudCard Grid.Column="0" Header="NEEDS ATTENTION">
                        <StackPanel x:Name="AttentionList" Spacing="12"/>
                    </hud:HudCard>

                    <hud:HudCard Grid.Column="1" Header="AUTOMATION">
                        <StackPanel x:Name="AutomationList" Spacing="12"/>
                    </hud:HudCard>
                </Grid>

            </StackPanel>
        </ScrollViewer>
    </hud:HudBackdrop>
</Page>
