<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Optimizer.WinUI.Views.PluginsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Optimizer.WinUI.ViewModels"
    xmlns:converters="using:Optimizer.WinUI.Converters"
    Background="Transparent"
    Loaded="Page_Loaded">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="24,16,24,24" Spacing="20">
            <StackPanel.ChildrenTransitions>
                <TransitionCollection>
                    <EntranceThemeTransition FromVerticalOffset="20"/>
                </TransitionCollection>
            </StackPanel.ChildrenTransitions>

            <!-- ── Header ──────────────────────────────────────────────────── -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Spacing="2">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE74C;" FontSize="28" VerticalAlignment="Center"/>
                        <TextBlock Text="Plugins" FontSize="28" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Community optimization plugins — browse, install, and manage"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               FontSize="13"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Content="Submit Plugin"
                        VerticalAlignment="Center"
                        Click="SubmitPlugin_Click"
                        Visibility="{x:Bind ViewModel.CanSubmit, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>
            </Grid>

            <!-- ═══════════════════════════════════════════════════════════════ -->
            <!-- INSTALLED SECTION                                              -->
            <!-- ═══════════════════════════════════════════════════════════════ -->
            <StackPanel Spacing="10">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="INSTALLED" FontSize="12" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <ProgressRing Width="16" Height="16"
                                  IsActive="{x:Bind ViewModel.IsLoadingInstalled, Mode=OneWay}"
                                  Visibility="{x:Bind ViewModel.IsLoadingInstalled, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>
                </StackPanel>

                <!-- Empty state for installed -->
                <Border CornerRadius="8" Padding="24"
                        Visibility="{x:Bind ViewModel.IsInstalledEmpty, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                        Background="{ThemeResource LayerFillColorDefaultBrush}">
                    <StackPanel HorizontalAlignment="Center" Spacing="8">
                        <FontIcon Glyph="&#xE74C;" FontSize="36" HorizontalAlignment="Center" Opacity="0.4"/>
                        <TextBlock Text="No plugins installed"
                                   FontSize="14" FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Browse available plugins below and click Install to add them."
                                   FontSize="12" HorizontalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap" MaxWidth="280" TextAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Installed plugin cards -->
                <ItemsRepeater ItemsSource="{x:Bind ViewModel.Installed, Mode=OneWay}">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="8" Orientation="Vertical"/>
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="vm:InstalledPluginVm">
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    CornerRadius="8" Padding="16"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Info -->
                                    <StackPanel Grid.Column="0" Spacing="3">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" FontSize="14"/>
                                            <!-- Permission violation badge -->
                                            <Border CornerRadius="4" Padding="5,2"
                                                    Background="#CC6633"
                                                    Visibility="{x:Bind HasViolations, Converter={StaticResource BoolToVisibility}}">
                                                <TextBlock Text="blocked" FontSize="10" Foreground="White"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{x:Bind Author}"
                                                   FontSize="11"
                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                        <TextBlock Text="{x:Bind Description}"
                                                   FontSize="12"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   TextWrapping="Wrap" MaxLines="2" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock FontSize="11" Foreground="#CC6633"
                                                   TextWrapping="Wrap"
                                                   Visibility="{x:Bind HasViolations, Converter={StaticResource BoolToVisibility}}"
                                                   Text="This plugin touches disallowed paths and has been force-disabled."/>
                                    </StackPanel>

                                    <!-- Category pill -->
                                    <Border Grid.Column="1" CornerRadius="4" Padding="6,2"
                                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Category}" FontSize="10"/>
                                    </Border>

                                    <!-- Enable toggle -->
                                    <ToggleSwitch Grid.Column="2"
                                                  IsOn="{x:Bind IsEnabled, Mode=OneWay}"
                                                  IsEnabled="{x:Bind HasViolations, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"
                                                  Toggled="PluginToggle_Toggled"
                                                  Tag="{x:Bind PluginId}"
                                                  VerticalAlignment="Center"
                                                  OnContent="" OffContent=""/>

                                    <!-- Remove button -->
                                    <Button Grid.Column="3"
                                            Tag="{x:Bind PluginId}"
                                            Click="RemovePlugin_Click"
                                            VerticalAlignment="Center"
                                            ToolTipService.ToolTip="Remove plugin">
                                        <FontIcon Glyph="&#xE74D;" FontSize="14"/>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </StackPanel>

            <!-- ═══════════════════════════════════════════════════════════════ -->
            <!-- AVAILABLE FROM MARKETPLACE SECTION                             -->
            <!-- ═══════════════════════════════════════════════════════════════ -->
            <StackPanel Spacing="10">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="AVAILABLE FROM MARKETPLACE" FontSize="12" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <ProgressRing Width="16" Height="16"
                                  IsActive="{x:Bind ViewModel.IsLoadingAvailable, Mode=OneWay}"
                                  Visibility="{x:Bind ViewModel.IsLoadingAvailable, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>
                </StackPanel>

                <!-- No server configured -->
                <Border CornerRadius="8" Padding="24"
                        Visibility="{x:Bind ViewModel.ShowNoServer, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                        Background="{ThemeResource LayerFillColorDefaultBrush}">
                    <StackPanel HorizontalAlignment="Center" Spacing="8">
                        <FontIcon Glyph="&#xE968;" FontSize="36" HorizontalAlignment="Center" Opacity="0.4"/>
                        <TextBlock Text="Not connected to a server"
                                   FontSize="14" FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Connect to an Optimizer server in Settings to browse community plugins."
                                   FontSize="12" HorizontalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap" MaxWidth="300" TextAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Empty state when server connected but no plugins -->
                <Border CornerRadius="8" Padding="24"
                        Visibility="{x:Bind ViewModel.IsAvailableEmpty, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                        Background="{ThemeResource LayerFillColorDefaultBrush}">
                    <StackPanel HorizontalAlignment="Center" Spacing="8">
                        <TextBlock Text="No plugins available"
                                   FontSize="14" FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="The server has no approved plugins yet."
                                   FontSize="12" HorizontalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Plugin grid -->
                <ItemsRepeater x:Name="AvailableRepeater"
                               ItemsSource="{x:Bind ViewModel.Available, Mode=OneWay}">
                    <ItemsRepeater.Layout>
                        <UniformGridLayout MinItemWidth="320" MinItemHeight="220"
                                           MinColumnSpacing="12" MinRowSpacing="12"
                                           ItemsStretch="Fill"/>
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="vm:RemotePluginVm">
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    CornerRadius="8" Padding="16"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1">
                                <Grid RowSpacing="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Header: name + verified badge + category -->
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Spacing="2">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <TextBlock Text="{x:Bind Name}"
                                                           FontWeight="SemiBold" FontSize="14"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock Text="&#x2713;" FontSize="13"
                                                           Foreground="#1E90FF"
                                                           VerticalAlignment="Center"
                                                           Visibility="{x:Bind Verified, Converter={StaticResource BoolToVisibility}}"
                                                           ToolTipService.ToolTip="Verified by Optimizer team"/>
                                            </StackPanel>
                                            <TextBlock Text="{x:Bind AuthorDisplayName}"
                                                       FontSize="11"
                                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                        </StackPanel>
                                        <Border Grid.Column="1" CornerRadius="4" Padding="6,2"
                                                Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                                VerticalAlignment="Top">
                                            <TextBlock Text="{x:Bind Category}" FontSize="10"/>
                                        </Border>
                                    </Grid>

                                    <!-- Description -->
                                    <TextBlock Grid.Row="1"
                                               Text="{x:Bind Description}"
                                               TextWrapping="Wrap" FontSize="12"
                                               MaxLines="4" TextTrimming="CharacterEllipsis"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                                    <!-- Stats + Install button -->
                                    <Grid Grid.Row="2" ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" VerticalAlignment="Center">
                                            <Run Text="&#x2B50;" FontSize="11"/>
                                            <Run Text="{x:Bind RatingText}" FontSize="11"/>
                                        </TextBlock>
                                        <TextBlock Grid.Column="1" VerticalAlignment="Center">
                                            <Run Text="&#x2B07;" FontSize="11"/>
                                            <Run Text="{x:Bind DownloadsText}" FontSize="11"/>
                                        </TextBlock>
                                        <Button Grid.Column="3"
                                                Content="Install"
                                                Tag="{x:Bind PluginId}"
                                                Click="InstallPlugin_Click"
                                                Style="{ThemeResource AccentButtonStyle}"
                                                IsEnabled="{x:Bind IsAlreadyInstalled, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"/>
                                    </Grid>

                                    <!-- Installed badge -->
                                    <TextBlock Grid.Row="3"
                                               Text="&#x2713; Installed"
                                               FontSize="11" Foreground="Green"
                                               Visibility="{x:Bind IsAlreadyInstalled, Converter={StaticResource BoolToVisibility}}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
