<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Optimizer.WinUI.Views.MarketplacePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Optimizer.WinUI.Models"
    xmlns:converters="using:Optimizer.WinUI.Converters"
    Background="Transparent"
    Loaded="Page_Loaded">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" Spacing="16">

            <!-- ── Header ──────────────────────────────────────────────── -->
            <StackPanel Spacing="2">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="{x:Bind ViewModel.CategoryIcon}" FontSize="28" VerticalAlignment="Center"/>
                    <TextBlock Text="{x:Bind ViewModel.CategoryName}" FontSize="28" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="Community-shared optimization profiles"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           FontSize="13"/>
            </StackPanel>

            <!-- ── Filter row ───────────────────────────────────────────── -->
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         PlaceholderText="Search by name, description, or tag…"
                         Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <ComboBox Grid.Column="1"
                          Header="Category"
                          SelectedItem="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}"
                          ItemsSource="{x:Bind ViewModel.CategoryOptions}"
                          MinWidth="150"/>

                <ComboBox Grid.Column="2"
                          Header="Sort by"
                          SelectedItem="{x:Bind ViewModel.SortBy, Mode=TwoWay}"
                          ItemsSource="{x:Bind ViewModel.SortOptions}"
                          MinWidth="170"/>
            </Grid>

            <!-- ── Loading indicator ────────────────────────────────────── -->
            <ProgressBar IsIndeterminate="True"
                         Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>

            <!-- ── Entry count ──────────────────────────────────────────── -->
            <TextBlock x:Name="CountText"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       FontSize="12"/>

            <!-- ── Marketplace grid ─────────────────────────────────────── -->
            <ItemsRepeater x:Name="EntriesRepeater"
                           ItemsSource="{x:Bind ViewModel.Entries, Mode=OneWay}">
                <ItemsRepeater.Layout>
                    <UniformGridLayout MinItemWidth="320"
                                       MinColumnSpacing="12"
                                       MinRowSpacing="12"/>
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="models:MarketplaceEntry">
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="8" Padding="16"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1">
                            <StackPanel Spacing="10">

                                <!-- name + verified badge + category pill -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <TextBlock Text="{x:Bind Name}"
                                                       FontWeight="SemiBold" FontSize="14"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="✓" FontSize="13"
                                                       Foreground="#1E90FF"
                                                       VerticalAlignment="Center"
                                                       Visibility="{x:Bind Verified, Converter={StaticResource BoolToVisibility}}"
                                                       ToolTipService.ToolTip="Verified by Optimizer team"/>
                                        </StackPanel>
                                        <TextBlock Text="{x:Bind Author}"
                                                   FontSize="11"
                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                    </StackPanel>

                                    <Border Grid.Column="1"
                                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                            CornerRadius="4" Padding="6,2"
                                            VerticalAlignment="Top">
                                        <TextBlock Text="{x:Bind Category}" FontSize="10"/>
                                    </Border>
                                </Grid>

                                <!-- description -->
                                <TextBlock Text="{x:Bind Description}"
                                           TextWrapping="Wrap" FontSize="12" MaxLines="3"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                                <!-- tags -->
                                <TextBlock Text="{x:Bind TagsText}"
                                           FontSize="10"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>

                                <!-- stats + install button -->
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" VerticalAlignment="Center">
                                        <Run Text="⭐" FontSize="11"/>
                                        <Run Text="{x:Bind RatingText}" FontSize="11"/>
                                    </TextBlock>

                                    <TextBlock Grid.Column="1" VerticalAlignment="Center">
                                        <Run Text="⬇" FontSize="11"/>
                                        <Run Text="{x:Bind DownloadsText}" FontSize="11"/>
                                    </TextBlock>

                                    <Button Grid.Column="3"
                                            Content="Install"
                                            Tag="{x:Bind Id}"
                                            Click="Install_Click"
                                            Style="{ThemeResource AccentButtonStyle}"
                                            IsEnabled="{x:Bind IsInstalled, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert, Mode=OneWay}"/>
                                </Grid>

                                <!-- installed badge (shown after install) -->
                                <TextBlock Text="✓ Installed"
                                           FontSize="11" Foreground="Green"
                                           Visibility="{x:Bind IsInstalled, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>

                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

            <!-- ── Empty state ──────────────────────────────────────────── -->
            <StackPanel HorizontalAlignment="Center" Spacing="8"
                        Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                <!-- Shown from code-behind when Entries is empty -->
                <TextBlock x:Name="EmptyState"
                           Text="No profiles match your search."
                           HorizontalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Visibility="Collapsed"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
