<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Optimizer.WinUI.Views.MarketplacePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:tk="using:CommunityToolkit.WinUI.Controls"
    xmlns:vm="using:Optimizer.WinUI.ViewModels"
    xmlns:models="using:Optimizer.WinUI.Models"
    xmlns:converters="using:Optimizer.WinUI.Converters"
    xmlns:hud="using:Optimizer.WinUI.Controls.Hud"
    Background="Transparent"
    Loaded="Page_Loaded">

    <Page.Resources>
        <converters:StringToSolidColorBrushConverter x:Key="StringToBrush"/>
    </Page.Resources>

    <hud:HudBackdrop>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32,24,32,32">
            <StackPanel Spacing="24" MaxWidth="1360" HorizontalAlignment="Left">
                <StackPanel.ChildrenTransitions>
                    <TransitionCollection>
                        <EntranceThemeTransition FromVerticalOffset="20"/>
                    </TransitionCollection>
                </StackPanel.ChildrenTransitions>

                <!-- ── Page header ──────────────────────────────────────────── -->
                <hud:HudPageHeader Icon="{x:Bind ViewModel.CategoryIcon}"
                                   Title="Extensions"
                                   Description="Third-party content — community optimization profiles and Optimizer plugins. Browse, install, and manage in one place."/>

                <!-- ── Section switcher ─────────────────────────────────────── -->
                <tk:Segmented x:Name="SectionSeg" SelectedIndex="0"
                              SelectionChanged="Section_Changed"
                              HorizontalAlignment="Left">
                    <tk:SegmentedItem Content="Profiles"/>
                    <tk:SegmentedItem Content="Plugins"/>
                </tk:Segmented>

                <!-- ═════════════════════════════════════════════════════════════
                     PANEL A — Community Profiles (was MarketplacePage)
                ═════════════════════════════════════════════════════════════ -->
                <StackPanel x:Name="PanelProfiles" Spacing="16">

                    <!-- Header row: caption + submit button -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Community-shared optimization profiles"
                                   Foreground="{StaticResource MutedBrush}" FontSize="13"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="1" x:Name="SubmitProfileButton"
                                Content="Submit Profile" VerticalAlignment="Center"
                                Click="SubmitProfile_Click"
                                Visibility="{x:Bind ViewModel.CanSubmit, Converter={StaticResource BoolToVisibility}}"/>
                    </Grid>

                    <!-- Filter row -->
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 PlaceholderText="Search by name, description, or tag…"
                                 Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <ComboBox Grid.Column="1" Header="Category"
                                  SelectedItem="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}"
                                  ItemsSource="{x:Bind ViewModel.CategoryOptions}" MinWidth="150"/>
                        <ComboBox Grid.Column="2" Header="Sort by"
                                  SelectedItem="{x:Bind ViewModel.SortBy, Mode=TwoWay}"
                                  ItemsSource="{x:Bind ViewModel.SortOptions}" MinWidth="170"/>
                    </Grid>

                    <ProgressBar IsIndeterminate="True"
                                 Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>

                    <TextBlock x:Name="CountText"
                               Foreground="{StaticResource MutedBrush}" FontSize="12"/>

                    <!-- Marketplace grid -->
                    <ItemsRepeater x:Name="EntriesRepeater"
                                   ItemsSource="{x:Bind ViewModel.Entries, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout MinItemWidth="340" MinItemHeight="240"
                                               MinColumnSpacing="12" MinRowSpacing="12"
                                               ItemsStretch="Fill"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="models:MarketplaceEntry">
                                <Border Background="{ThemeResource HudSurfaceAltBrush}"
                                        CornerRadius="{StaticResource CardCornerRadius}" Padding="16"
                                        BorderBrush="{ThemeResource HudHairlineBrush}" BorderThickness="1">
                                    <Grid RowSpacing="8">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Spacing="2">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <TextBlock Text="{x:Bind Name}"
                                                               FontWeight="SemiBold" FontSize="14"
                                                               TextWrapping="Wrap"/>
                                                    <TextBlock Text="✓" FontSize="13"
                                                               Foreground="{StaticResource InfoBrush}"
                                                               VerticalAlignment="Center"
                                                               Visibility="{x:Bind Verified, Converter={StaticResource BoolToVisibility}}"
                                                               ToolTipService.ToolTip="Verified by Optimizer team"/>
                                                </StackPanel>
                                                <TextBlock Text="{x:Bind Author}"
                                                           FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Orientation="Vertical" Spacing="3" VerticalAlignment="Top">
                                                <Border Background="{ThemeResource HudSurfaceBrush}"
                                                        CornerRadius="4" Padding="6,2">
                                                    <TextBlock Text="{x:Bind Category}" FontSize="10"/>
                                                </Border>
                                                <Border CornerRadius="4" Padding="6,2"
                                                        Background="{x:Bind SourceBadgeColor, Converter={StaticResource StringToBrush}}">
                                                    <TextBlock Text="{x:Bind Source}" FontSize="9" Foreground="White"/>
                                                </Border>
                                            </StackPanel>
                                        </Grid>

                                        <TextBlock Grid.Row="1" Text="{x:Bind Description}"
                                                   TextWrapping="Wrap" FontSize="12"
                                                   MaxLines="4" TextTrimming="CharacterEllipsis"
                                                   ToolTipService.ToolTip="{x:Bind Description}"
                                                   Foreground="{StaticResource MutedBrush}"/>

                                        <TextBlock Grid.Row="2" Text="{x:Bind TagsText}"
                                                   FontSize="10" TextWrapping="Wrap"
                                                   Foreground="{StaticResource MutedBrush}"/>

                                        <Grid Grid.Row="3" ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" VerticalAlignment="Center">
                                                <Run Text="⭐" FontSize="11"/>
                                                <Run Text="{x:Bind RatingText}" FontSize="11"/>
                                            </TextBlock>
                                            <TextBlock Grid.Column="1" VerticalAlignment="Center">
                                                <Run Text="⬇" FontSize="11"/>
                                                <Run Text="{x:Bind DownloadsText}" FontSize="11"/>
                                            </TextBlock>

                                            <Button Grid.Column="3" Content="Install" Tag="{x:Bind Id}"
                                                    Click="Install_Click"
                                                    Style="{ThemeResource AccentButtonStyle}"
                                                    IsEnabled="{x:Bind IsInstalled, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert, Mode=OneWay}"/>
                                        </Grid>

                                        <TextBlock Grid.Row="4" Text="✓ Installed"
                                                   FontSize="11" Foreground="{StaticResource SuccessBrush}"
                                                   Visibility="{x:Bind IsInstalled, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>

                    <!-- Profiles empty state -->
                    <Border CornerRadius="{StaticResource CardCornerRadius}" Padding="32" Margin="0,16,0,0"
                            Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                            Background="{ThemeResource HudSurfaceAltBrush}"
                            BorderBrush="{ThemeResource HudHairlineBrush}" BorderThickness="1">
                        <StackPanel HorizontalAlignment="Center" Spacing="12">
                            <TextBlock Text="&#x1F4ED;" FontSize="48" HorizontalAlignment="Center" Opacity="0.6"/>
                            <TextBlock Text="No matching profiles"
                                       FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            <TextBlock Text="Try a different search term, category, or sort order."
                                       FontSize="12" HorizontalAlignment="Center"
                                       Foreground="{StaticResource MutedBrush}"
                                       TextWrapping="Wrap" MaxWidth="280" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ═════════════════════════════════════════════════════════════
                     PANEL B — Plugins (was PluginsPage)
                ═════════════════════════════════════════════════════════════ -->
                <StackPanel x:Name="PanelPlugins" Visibility="Collapsed" Spacing="20">

                    <!-- Header row -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Community optimization plugins — browse, install, and manage"
                                   Foreground="{StaticResource MutedBrush}" FontSize="13"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="Submit Plugin" VerticalAlignment="Center"
                                Click="SubmitPlugin_Click"
                                Visibility="{x:Bind PluginsVM.CanSubmit, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>
                    </Grid>

                    <!-- INSTALLED section -->
                    <StackPanel Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="INSTALLED" Style="{StaticResource HudMicroStyle}" VerticalAlignment="Center"/>
                            <ProgressRing Width="16" Height="16"
                                          IsActive="{x:Bind PluginsVM.IsLoadingInstalled, Mode=OneWay}"
                                          Visibility="{x:Bind PluginsVM.IsLoadingInstalled, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>
                        </StackPanel>

                        <Border CornerRadius="{StaticResource CardCornerRadius}" Padding="24"
                                Visibility="{x:Bind PluginsVM.IsInstalledEmpty, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                                Background="{ThemeResource HudSurfaceAltBrush}"
                                BorderBrush="{ThemeResource HudHairlineBrush}" BorderThickness="1">
                            <StackPanel HorizontalAlignment="Center" Spacing="8">
                                <FontIcon Glyph="&#xE74C;" FontSize="36" HorizontalAlignment="Center" Opacity="0.4"/>
                                <TextBlock Text="No plugins installed"
                                           FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                <TextBlock Text="Browse available plugins below and click Install to add them."
                                           FontSize="12" HorizontalAlignment="Center"
                                           Foreground="{StaticResource MutedBrush}"
                                           TextWrapping="Wrap" MaxWidth="280" TextAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <ItemsRepeater ItemsSource="{x:Bind PluginsVM.Installed, Mode=OneWay}">
                            <ItemsRepeater.Layout>
                                <StackLayout Spacing="8" Orientation="Vertical"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="vm:InstalledPluginVm">
                                    <Border Background="{ThemeResource HudSurfaceAltBrush}"
                                            CornerRadius="{StaticResource CardCornerRadius}" Padding="16"
                                            BorderBrush="{ThemeResource HudHairlineBrush}" BorderThickness="1">
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Spacing="3">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" FontSize="14"/>
                                                    <Border CornerRadius="4" Padding="5,2"
                                                            Background="{StaticResource DangerBrush}"
                                                            Visibility="{x:Bind HasViolations, Converter={StaticResource BoolToVisibility}}">
                                                        <TextBlock Text="blocked" FontSize="10" Foreground="White"/>
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="{x:Bind Author}"
                                                           FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                                                <TextBlock Text="{x:Bind Description}"
                                                           FontSize="12" Foreground="{StaticResource MutedBrush}"
                                                           TextWrapping="Wrap" MaxLines="2" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock FontSize="11" Foreground="{StaticResource DangerBrush}"
                                                           TextWrapping="Wrap"
                                                           Visibility="{x:Bind HasViolations, Converter={StaticResource BoolToVisibility}}"
                                                           Text="This plugin touches disallowed paths and has been force-disabled."/>
                                            </StackPanel>

                                            <Border Grid.Column="1" CornerRadius="4" Padding="6,2"
                                                    Background="{ThemeResource HudSurfaceBrush}"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{x:Bind Category}" FontSize="10"/>
                                            </Border>

                                            <ToggleSwitch Grid.Column="2"
                                                          IsOn="{x:Bind IsEnabled, Mode=OneWay}"
                                                          IsEnabled="{x:Bind HasViolations, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"
                                                          Toggled="PluginToggle_Toggled" Tag="{x:Bind PluginId}"
                                                          VerticalAlignment="Center" OnContent="" OffContent=""/>

                                            <Button Grid.Column="3" Tag="{x:Bind PluginId}"
                                                    Click="RemovePlugin_Click" VerticalAlignment="Center"
                                                    ToolTipService.ToolTip="Remove plugin">
                                                <FontIcon Glyph="&#xE74D;" FontSize="14"/>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </StackPanel>

                    <!-- AVAILABLE FROM MARKETPLACE section -->
                    <StackPanel Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="AVAILABLE FROM MARKETPLACE" Style="{StaticResource HudMicroStyle}" VerticalAlignment="Center"/>
                            <ProgressRing Width="16" Height="16"
                                          IsActive="{x:Bind PluginsVM.IsLoadingAvailable, Mode=OneWay}"
                                          Visibility="{x:Bind PluginsVM.IsLoadingAvailable, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>
                        </StackPanel>

                        <Border CornerRadius="{StaticResource CardCornerRadius}" Padding="24"
                                Visibility="{x:Bind PluginsVM.ShowNoServer, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                                Background="{ThemeResource HudSurfaceAltBrush}"
                                BorderBrush="{ThemeResource HudHairlineBrush}" BorderThickness="1">
                            <StackPanel HorizontalAlignment="Center" Spacing="8">
                                <FontIcon Glyph="&#xE968;" FontSize="36" HorizontalAlignment="Center" Opacity="0.4"/>
                                <TextBlock Text="Not connected to a server"
                                           FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                <TextBlock Text="Connect to an Optimizer server in Settings to browse community plugins."
                                           FontSize="12" HorizontalAlignment="Center"
                                           Foreground="{StaticResource MutedBrush}"
                                           TextWrapping="Wrap" MaxWidth="300" TextAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border CornerRadius="{StaticResource CardCornerRadius}" Padding="24"
                                Visibility="{x:Bind PluginsVM.IsAvailableEmpty, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                                Background="{ThemeResource HudSurfaceAltBrush}"
                                BorderBrush="{ThemeResource HudHairlineBrush}" BorderThickness="1">
                            <StackPanel HorizontalAlignment="Center" Spacing="8">
                                <TextBlock Text="No plugins available"
                                           FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                <TextBlock Text="The server has no approved plugins yet."
                                           FontSize="12" HorizontalAlignment="Center"
                                           Foreground="{StaticResource MutedBrush}"/>
                            </StackPanel>
                        </Border>

                        <ItemsRepeater x:Name="AvailableRepeater"
                                       ItemsSource="{x:Bind PluginsVM.Available, Mode=OneWay}">
                            <ItemsRepeater.Layout>
                                <UniformGridLayout MinItemWidth="320" MinItemHeight="220"
                                                   MinColumnSpacing="12" MinRowSpacing="12"
                                                   ItemsStretch="Fill"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="vm:RemotePluginVm">
                                    <Border Background="{ThemeResource HudSurfaceAltBrush}"
                                            CornerRadius="{StaticResource CardCornerRadius}" Padding="16"
                                            BorderBrush="{ThemeResource HudHairlineBrush}" BorderThickness="1">
                                        <Grid RowSpacing="8">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Spacing="2">
                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <TextBlock Text="{x:Bind Name}"
                                                                   FontWeight="SemiBold" FontSize="14"
                                                                   TextWrapping="Wrap"/>
                                                        <TextBlock Text="&#x2713;" FontSize="13"
                                                                   Foreground="{StaticResource InfoBrush}"
                                                                   VerticalAlignment="Center"
                                                                   Visibility="{x:Bind Verified, Converter={StaticResource BoolToVisibility}}"
                                                                   ToolTipService.ToolTip="Verified by Optimizer team"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{x:Bind AuthorDisplayName}"
                                                               FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                                                </StackPanel>
                                                <Border Grid.Column="1" CornerRadius="4" Padding="6,2"
                                                        Background="{ThemeResource HudSurfaceBrush}"
                                                        VerticalAlignment="Top">
                                                    <TextBlock Text="{x:Bind Category}" FontSize="10"/>
                                                </Border>
                                            </Grid>

                                            <TextBlock Grid.Row="1" Text="{x:Bind Description}"
                                                       TextWrapping="Wrap" FontSize="12"
                                                       MaxLines="4" TextTrimming="CharacterEllipsis"
                                                       Foreground="{StaticResource MutedBrush}"/>

                                            <Grid Grid.Row="2" ColumnSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" VerticalAlignment="Center">
                                                    <Run Text="&#x2B50;" FontSize="11"/>
                                                    <Run Text="{x:Bind RatingText}" FontSize="11"/>
                                                </TextBlock>
                                                <TextBlock Grid.Column="1" VerticalAlignment="Center">
                                                    <Run Text="&#x2B07;" FontSize="11"/>
                                                    <Run Text="{x:Bind DownloadsText}" FontSize="11"/>
                                                </TextBlock>
                                                <Button Grid.Column="3" Content="Install" Tag="{x:Bind PluginId}"
                                                        Click="InstallPlugin_Click"
                                                        Style="{ThemeResource AccentButtonStyle}"
                                                        IsEnabled="{x:Bind IsAlreadyInstalled, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"/>
                                            </Grid>

                                            <TextBlock Grid.Row="3" Text="&#x2713; Installed"
                                                       FontSize="11" Foreground="{StaticResource SuccessBrush}"
                                                       Visibility="{x:Bind IsAlreadyInstalled, Converter={StaticResource BoolToVisibility}}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </StackPanel>

                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </hud:HudBackdrop>
</Page>
