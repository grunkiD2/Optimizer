<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Optimizer.WinUI.Views.MarketplacePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Optimizer.WinUI.Models"
    xmlns:converters="using:Optimizer.WinUI.Converters"
    Background="Transparent"
    Loaded="Page_Loaded">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="24,16,24,24" Spacing="16">
            <StackPanel.ChildrenTransitions>
                <TransitionCollection>
                    <EntranceThemeTransition FromVerticalOffset="20"/>
                </TransitionCollection>
            </StackPanel.ChildrenTransitions>

            <!-- ── Header ──────────────────────────────────────────────── -->
            <StackPanel Spacing="2">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="{x:Bind ViewModel.CategoryIcon}" FontSize="28" VerticalAlignment="Center"/>
                    <TextBlock Text="{x:Bind ViewModel.CategoryName}" FontSize="28" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="Community-shared optimization profiles"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           FontSize="13"/>
            </StackPanel>

            <!-- ── Filter row ───────────────────────────────────────────── -->
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         PlaceholderText="Search by name, description, or tag…"
                         Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <ComboBox Grid.Column="1"
                          Header="Category"
                          SelectedItem="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}"
                          ItemsSource="{x:Bind ViewModel.CategoryOptions}"
                          MinWidth="150"/>

                <ComboBox Grid.Column="2"
                          Header="Sort by"
                          SelectedItem="{x:Bind ViewModel.SortBy, Mode=TwoWay}"
                          ItemsSource="{x:Bind ViewModel.SortOptions}"
                          MinWidth="170"/>
            </Grid>

            <!-- ── Loading indicator ────────────────────────────────────── -->
            <ProgressBar IsIndeterminate="True"
                         Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>

            <!-- ── Entry count ──────────────────────────────────────────── -->
            <TextBlock x:Name="CountText"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       FontSize="12"/>

            <!-- ── Marketplace grid ─────────────────────────────────────── -->
            <ItemsRepeater x:Name="EntriesRepeater"
                           ItemsSource="{x:Bind ViewModel.Entries, Mode=OneWay}">
                <ItemsRepeater.Layout>
                    <UniformGridLayout MinItemWidth="340" MinItemHeight="240"
                                       MinColumnSpacing="12" MinRowSpacing="12"
                                       ItemsStretch="Fill"/>
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="models:MarketplaceEntry">
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="8" Padding="16"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1">
                            <Grid RowSpacing="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>  <!-- header -->
                                    <RowDefinition Height="*"/>     <!-- description (grows) -->
                                    <RowDefinition Height="Auto"/>  <!-- tags -->
                                    <RowDefinition Height="Auto"/>  <!-- footer: stats + button -->
                                    <RowDefinition Height="Auto"/>  <!-- installed badge -->
                                </Grid.RowDefinitions>

                                <!-- name + verified badge + category pill -->
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <TextBlock Text="{x:Bind Name}"
                                                       FontWeight="SemiBold" FontSize="14"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock Text="✓" FontSize="13"
                                                       Foreground="#1E90FF"
                                                       VerticalAlignment="Center"
                                                       Visibility="{x:Bind Verified, Converter={StaticResource BoolToVisibility}}"
                                                       ToolTipService.ToolTip="Verified by Optimizer team"/>
                                        </StackPanel>
                                        <TextBlock Text="{x:Bind Author}"
                                                   FontSize="11"
                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                    </StackPanel>

                                    <Border Grid.Column="1"
                                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                            CornerRadius="4" Padding="6,2"
                                            VerticalAlignment="Top">
                                        <TextBlock Text="{x:Bind Category}" FontSize="10"/>
                                    </Border>
                                </Grid>

                                <!-- description -->
                                <TextBlock Grid.Row="1"
                                           Text="{x:Bind Description}"
                                           TextWrapping="Wrap" FontSize="12"
                                           MaxLines="4" TextTrimming="CharacterEllipsis"
                                           ToolTipService.ToolTip="{x:Bind Description}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                                <!-- tags -->
                                <TextBlock Grid.Row="2"
                                           Text="{x:Bind TagsText}"
                                           FontSize="10"
                                           TextWrapping="Wrap"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>

                                <!-- stats + install button -->
                                <Grid Grid.Row="3" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" VerticalAlignment="Center">
                                        <Run Text="⭐" FontSize="11"/>
                                        <Run Text="{x:Bind RatingText}" FontSize="11"/>
                                    </TextBlock>

                                    <TextBlock Grid.Column="1" VerticalAlignment="Center">
                                        <Run Text="⬇" FontSize="11"/>
                                        <Run Text="{x:Bind DownloadsText}" FontSize="11"/>
                                    </TextBlock>

                                    <Button Grid.Column="3"
                                            Content="Install"
                                            Tag="{x:Bind Id}"
                                            Click="Install_Click"
                                            Style="{ThemeResource AccentButtonStyle}"
                                            IsEnabled="{x:Bind IsInstalled, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert, Mode=OneWay}"/>
                                </Grid>

                                <!-- installed badge (shown after install) -->
                                <TextBlock Grid.Row="4"
                                           Text="✓ Installed"
                                           FontSize="11" Foreground="Green"
                                           Visibility="{x:Bind IsInstalled, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>

                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

            <!-- ── Empty state ──────────────────────────────────────────── -->
            <Border CornerRadius="8" Padding="32"
                    Margin="0,16,0,0"
                    Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                    Background="{ThemeResource LayerFillColorDefaultBrush}">
                <StackPanel HorizontalAlignment="Center" Spacing="12">
                    <TextBlock Text="&#x1F4ED;" FontSize="48" HorizontalAlignment="Center" Opacity="0.6"/>
                    <TextBlock Text="No matching profiles"
                               FontSize="16" FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Try a different search term, category, or sort order."
                               FontSize="12" HorizontalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap" MaxWidth="280" TextAlignment="Center"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
