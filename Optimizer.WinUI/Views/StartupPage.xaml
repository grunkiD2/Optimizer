<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Optimizer.WinUI.Views.StartupPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:tk="using:CommunityToolkit.WinUI.Controls"
    xmlns:converters="using:Optimizer.WinUI.Converters"
    xmlns:hud="using:Optimizer.WinUI.Controls.Hud"
    xmlns:models="using:Optimizer.WinUI.Models"
    Background="Transparent"
    Loaded="Page_Loaded">

    <Page.Resources>
    </Page.Resources>

    <hud:HudBackdrop>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32,24,32,32">
            <StackPanel Spacing="24" MaxWidth="1360" HorizontalAlignment="Left">
                <StackPanel.ChildrenTransitions>
                    <TransitionCollection>
                        <EntranceThemeTransition FromVerticalOffset="20"/>
                    </TransitionCollection>
                </StackPanel.ChildrenTransitions>

                <!-- ── Page header ──────────────────────────────────────────── -->
                <hud:HudPageHeader Icon="{x:Bind ViewModel.CategoryIcon}"
                                   Title="Startup &amp; Services"
                                   Description="Everything that runs at boot or in the background — startup programs and Windows services in one place.">
                    <Button Content="Refresh" Click="RefreshButton_Click"/>
                </hud:HudPageHeader>

                <!-- ── Section switcher ─────────────────────────────────────── -->
                <tk:Segmented x:Name="SectionSeg" SelectedIndex="0"
                              SelectionChanged="Section_Changed"
                              HorizontalAlignment="Left">
                    <tk:SegmentedItem Content="Startup Programs"/>
                    <tk:SegmentedItem Content="Services"/>
                </tk:Segmented>

                <!-- ═════════════════════════════════════════════════════════════
                     PANEL A — Startup programs (default)
                ═════════════════════════════════════════════════════════════ -->
                <StackPanel x:Name="PanelStartup" Spacing="16">

                    <!-- Stats strip -->
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" CornerRadius="{StaticResource CardCornerRadius}"
                                Padding="16,12" Background="{ThemeResource HudSurfaceAltBrush}"
                                BorderBrush="{ThemeResource HudHairlineBrush}" BorderThickness="1">
                            <StackPanel Spacing="6">
                                <TextBlock Text="Enabled" FontSize="12" Foreground="{StaticResource SuccessBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.EnabledCount, Mode=OneWay}"
                                           Style="{StaticResource HudMetricStyle}"/>
                                <TextBlock Text="at startup" Style="{StaticResource HudCaptionStyle}"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" CornerRadius="{StaticResource CardCornerRadius}"
                                Padding="16,12" Background="{ThemeResource HudSurfaceAltBrush}"
                                BorderBrush="{ThemeResource HudHairlineBrush}" BorderThickness="1">
                            <StackPanel Spacing="6">
                                <TextBlock Text="Total" FontSize="12" Foreground="{StaticResource VioletBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.TotalCount, Mode=OneWay}"
                                           Style="{StaticResource HudMetricStyle}"/>
                                <TextBlock Text="programs found" Style="{StaticResource HudCaptionStyle}"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Boot Performance -->
                    <TextBlock Text="BOOT PERFORMANCE" Style="{StaticResource HudMicroStyle}" Margin="0,8,0,0"/>
                    <hud:HudCard>
                        <Grid ColumnSpacing="20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="LAST BOOT" Style="{StaticResource HudCaptionStyle}"/>
                                <TextBlock Text="{x:Bind ViewModel.LastBoot.BootDurationText, Mode=OneWay, FallbackValue=—}"
                                           Style="{StaticResource HudMetricStyle}"/>
                                <TextBlock Text="{x:Bind ViewModel.LastBoot.BootTimeText, Mode=OneWay, FallbackValue=—}"
                                           FontSize="10" Foreground="{StaticResource MutedBrush}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="AVERAGE (10 BOOTS)" Style="{StaticResource HudCaptionStyle}"/>
                                <TextBlock Text="{x:Bind ViewModel.AverageBootText, Mode=OneWay}"
                                           Style="{StaticResource HudMetricStyle}"/>
                                <TextBlock Text="recent boots" FontSize="10" Foreground="{StaticResource MutedBrush}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="HISTORY" Style="{StaticResource HudCaptionStyle}" Margin="0,0,0,4"/>
                                <ItemsRepeater ItemsSource="{x:Bind ViewModel.BootHistory, Mode=OneWay}" Height="40">
                                    <ItemsRepeater.Layout>
                                        <StackLayout Orientation="Horizontal" Spacing="3"/>
                                    </ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate x:DataType="models:BootMetrics">
                                            <Border Width="8" Height="{x:Bind BarHeight}"
                                                    Background="{StaticResource AccentCyanBrush}"
                                                    VerticalAlignment="Bottom" CornerRadius="2"
                                                    ToolTipService.ToolTip="{x:Bind BootDurationText}"/>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </StackPanel>
                        </Grid>
                    </hud:HudCard>

                    <!-- Startup entries -->
                    <TextBlock Text="STARTUP PROGRAMS" Style="{StaticResource HudMicroStyle}" Margin="0,8,0,0"/>
                    <ListView ItemsSource="{x:Bind ViewModel.Entries, Mode=OneWay}" SelectionMode="None">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:StartupEntry">
                                <Border Background="{ThemeResource HudSurfaceAltBrush}"
                                        CornerRadius="{StaticResource CardCornerRadius}"
                                        Padding="14,10" Margin="0,0,0,4"
                                        BorderBrush="{ThemeResource HudHairlineBrush}" BorderThickness="1">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{x:Bind Command}" FontSize="11"
                                                       Foreground="{StaticResource MutedBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{x:Bind LocationText}" FontSize="10"
                                                       Foreground="{StaticResource MutedBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <TextBlock Grid.Column="1" Text="🛡️" FontSize="16"
                                                   VerticalAlignment="Center"
                                                   Visibility="{x:Bind RequiresAdmin, Converter={StaticResource BoolToVisibility}}"/>

                                        <ToggleSwitch Grid.Column="2" IsOn="{x:Bind Enabled}"
                                                      VerticalAlignment="Center" MinWidth="0"
                                                      Toggled="StartupToggle_Toggled" Tag="{x:Bind Key}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                </StackPanel>

                <!-- ═════════════════════════════════════════════════════════════
                     PANEL B — Services (was the standalone ServicesPage)
                ═════════════════════════════════════════════════════════════ -->
                <StackPanel x:Name="PanelServices" Visibility="Collapsed" Spacing="16">

                    <!-- Summary line -->
                    <TextBlock Foreground="{StaticResource MutedBrush}" FontSize="12">
                        <Run Text="{x:Bind ServicesVM.RunningCount, Mode=OneWay}"/>
                        <Run Text=" / "/>
                        <Run Text="{x:Bind ServicesVM.TotalCount, Mode=OneWay}"/>
                        <Run Text=" services running"/>
                    </TextBlock>

                    <!-- Filter bar -->
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" PlaceholderText="Search services…"
                                 Text="{x:Bind ServicesVM.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <ComboBox Grid.Column="1"
                                  SelectedItem="{x:Bind ServicesVM.FilterStatus, Mode=TwoWay}"
                                  ItemsSource="{x:Bind ServicesVM.StatusOptions}"
                                  MinWidth="120"/>
                        <ComboBox Grid.Column="2"
                                  SelectedItem="{x:Bind ServicesVM.FilterRecommendation, Mode=TwoWay}"
                                  ItemsSource="{x:Bind ServicesVM.RecommendationOptions}"
                                  MinWidth="130"/>
                        <Button Grid.Column="3" Content="Refresh" Click="RefreshServices_Click"/>
                    </Grid>

                    <!-- Loading indicator -->
                    <ProgressRing IsActive="{x:Bind ServicesVM.IsLoading, Mode=OneWay}"
                                  Width="32" Height="32" HorizontalAlignment="Left"
                                  Visibility="{x:Bind ServicesVM.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>

                    <!-- Service list -->
                    <ListView ItemsSource="{x:Bind ServicesVM.Services, Mode=OneWay}" SelectionMode="None">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,4"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:WindowsServiceInfo">
                                <Border Background="{ThemeResource HudSurfaceAltBrush}"
                                        CornerRadius="{StaticResource CardCornerRadius}" Padding="14,10"
                                        BorderBrush="{ThemeResource HudHairlineBrush}" BorderThickness="1">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind DisplayName, Mode=OneWay}"
                                                       FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{x:Bind ServiceName, Mode=OneWay}"
                                                       FontSize="11" Foreground="{StaticResource MutedBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <Border Grid.Column="1" CornerRadius="4" Padding="6,2"
                                                VerticalAlignment="Center"
                                                Background="{ThemeResource HudSurfaceBrush}">
                                            <TextBlock Text="{x:Bind Status, Mode=OneWay}" FontSize="11"/>
                                        </Border>

                                        <ComboBox Grid.Column="2"
                                                  SelectedItem="{x:Bind StartupType, Mode=OneWay}"
                                                  Tag="{x:Bind ServiceName}"
                                                  SelectionChanged="StartupType_Changed"
                                                  VerticalAlignment="Center" MinWidth="120">
                                            <ComboBoxItem Content="Automatic"/>
                                            <ComboBoxItem Content="AutoDelayed"/>
                                            <ComboBoxItem Content="Manual"/>
                                            <ComboBoxItem Content="Disabled"/>
                                        </ComboBox>

                                        <Button Grid.Column="3" Content="Toggle"
                                                Tag="{x:Bind ServiceName}" Click="Toggle_Click"
                                                VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="4" Text="{x:Bind Recommendation}"
                                                   FontSize="10" Foreground="{StaticResource MutedBrush}"
                                                   VerticalAlignment="Center" MinWidth="60"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </hud:HudBackdrop>
</Page>
