<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Optimizer.WinUI.Views.StartupPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Optimizer.WinUI.Models"
    Background="Transparent"
    Loaded="Page_Loaded">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16" Padding="24,16,24,24">

            <!-- ── Page header ──────────────────────────────────────────── -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: icon + title + subtitle -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <TextBlock Text="{x:Bind ViewModel.CategoryIcon}"
                               FontSize="28" VerticalAlignment="Center"/>
                    <StackPanel Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="{x:Bind ViewModel.CategoryName}"
                                   Style="{StaticResource TitleTextBlockStyle}"/>
                        <TextBlock FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                            <Run Text="{x:Bind ViewModel.EnabledCount, Mode=OneWay}"/>
                            <Run Text=" of "/>
                            <Run Text="{x:Bind ViewModel.TotalCount, Mode=OneWay}"/>
                            <Run Text=" entries enabled"/>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>

                <!-- Right: refresh button -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button Content="Refresh" Click="RefreshButton_Click"/>
                </StackPanel>
            </Grid>

            <!-- ── Stats strip ──────────────────────────────────────────── -->
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Enabled count -->
                <Border Grid.Column="0" CornerRadius="8" Padding="16,12">
                    <Border.Background>
                        <SolidColorBrush Color="{ThemeResource LayerFillColorDefaultColor}"/>
                    </Border.Background>
                    <StackPanel Spacing="6">
                        <TextBlock Text="Enabled" FontSize="12" Foreground="#34D399"/>
                        <TextBlock Text="{x:Bind ViewModel.EnabledCount, Mode=OneWay}"
                                   FontSize="22" FontWeight="Bold" FontFamily="Consolas"/>
                        <TextBlock Text="at startup" FontSize="11"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Total count -->
                <Border Grid.Column="1" CornerRadius="8" Padding="16,12">
                    <Border.Background>
                        <SolidColorBrush Color="{ThemeResource LayerFillColorDefaultColor}"/>
                    </Border.Background>
                    <StackPanel Spacing="6">
                        <TextBlock Text="Total" FontSize="12" Foreground="#A78BFA"/>
                        <TextBlock Text="{x:Bind ViewModel.TotalCount, Mode=OneWay}"
                                   FontSize="22" FontWeight="Bold" FontFamily="Consolas"/>
                        <TextBlock Text="programs found" FontSize="11"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── Startup entries list ─────────────────────────────────── -->
            <TextBlock Text="Startup Programs"
                       FontSize="16" FontWeight="SemiBold"
                       Margin="0,8,0,0"/>

            <ListView ItemsSource="{x:Bind ViewModel.Entries, Mode=OneWay}"
                      SelectionMode="None">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:StartupEntry">
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="8" Padding="14,10" Margin="0,0,0,4"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Name + path -->
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{x:Bind Command}" FontSize="11"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{x:Bind LocationText}" FontSize="10"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <!-- Admin shield badge -->
                                <TextBlock Grid.Column="1"
                                           Text="🛡️" FontSize="16"
                                           VerticalAlignment="Center"
                                           Visibility="{x:Bind RequiresAdmin}"/>

                                <!-- Toggle -->
                                <ToggleSwitch Grid.Column="2"
                                             IsOn="{x:Bind Enabled}"
                                             VerticalAlignment="Center"
                                             MinWidth="0"
                                             Toggled="StartupToggle_Toggled"
                                             Tag="{x:Bind Key}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

        </StackPanel>
    </ScrollViewer>
</Page>
