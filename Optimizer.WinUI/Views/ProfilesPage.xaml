<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Optimizer.WinUI.Views.ProfilesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Optimizer.WinUI.Converters"
    xmlns:hud="using:Optimizer.WinUI.Controls.Hud"
    xmlns:models="using:Optimizer.WinUI.Models"
    Background="Transparent"
    Loaded="Page_Loaded">

    <Page.Resources>
        <converters:DateTimeToStringConverter x:Key="DateTimeToString"/>
    </Page.Resources>

    <hud:HudBackdrop>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32,24,32,32">
            <StackPanel Spacing="24" MaxWidth="1360" HorizontalAlignment="Left">
                <StackPanel.ChildrenTransitions>
                    <TransitionCollection>
                        <EntranceThemeTransition FromVerticalOffset="20"/>
                    </TransitionCollection>
                </StackPanel.ChildrenTransitions>

                <!-- ── Page header ──────────────────────────────────────────── -->
                <hud:HudPageHeader Icon="{x:Bind ViewModel.CategoryIcon}"
                                   Title="{x:Bind ViewModel.CategoryName}"
                                   Description="Save and apply optimization snapshots, and auto-switch by time or process.">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Save Snapshot" Style="{StaticResource AccentButtonStyle}"
                                Click="SaveSnapshot_Click"/>
                        <Button Content="Import" Click="Import_Click"/>
                        <Button Content="Export" Click="Export_Click"/>
                    </StackPanel>
                </hud:HudPageHeader>

                <!-- ═════════════════════════════════════════════════════════════
                     Profiles (presets + snapshots + automation rules)
                ═════════════════════════════════════════════════════════════ -->
                <StackPanel x:Name="PanelProfiles" Spacing="16">

                    <!-- Status / busy -->
                    <ProgressBar IsIndeterminate="True"
                                 Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>
                    <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                               FontSize="12" Foreground="{StaticResource MutedBrush}"
                               Visibility="{x:Bind ViewModel.HasStatusMessage, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>

                    <TextBlock Foreground="{StaticResource MutedBrush}" FontSize="12">
                        <Run Text="{x:Bind ViewModel.PresetCount, Mode=OneWay}"/>
                        <Run Text=" built-in presets · "/>
                        <Run Text="{x:Bind ViewModel.SnapshotCount, Mode=OneWay}"/>
                        <Run Text=" saved snapshots"/>
                    </TextBlock>

                    <!-- BUILT-IN PRESETS -->
                    <TextBlock Text="BUILT-IN PRESETS" Style="{StaticResource HudMicroStyle}" Margin="0,8,0,0"/>

                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.Presets, Mode=OneWay}">
                            <ItemsRepeater.Layout>
                                <StackLayout Orientation="Horizontal" Spacing="8"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="models:SettingsProfile">
                                    <Border Background="{ThemeResource HudSurfaceAltBrush}"
                                            CornerRadius="{StaticResource CardCornerRadius}"
                                            Padding="16,12"
                                            BorderBrush="{ThemeResource HudHairlineBrush}"
                                            BorderThickness="1"
                                            Width="220" MinHeight="160">
                                        <Grid RowSpacing="4">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Text="{x:Bind Name}"
                                                       FontWeight="SemiBold" FontSize="14" TextWrapping="Wrap"/>
                                            <TextBlock Grid.Row="1" Text="{x:Bind ProfileType}"
                                                       FontSize="10"
                                                       Foreground="{StaticResource InfoBrush}"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Grid.Row="2" Text="{x:Bind Description}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource MutedBrush}"
                                                       TextWrapping="Wrap" MaxLines="4"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTipService.ToolTip="{x:Bind Description}"/>
                                            <Button Grid.Row="3" Content="APPLY"
                                                    Style="{StaticResource AccentButtonStyle}"
                                                    HorizontalAlignment="Left" Margin="0,6,0,0"
                                                    Click="PresetApply_Click" Tag="{x:Bind Id}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </ScrollViewer>

                    <!-- Empty-state for presets -->
                    <Border CornerRadius="{StaticResource CardCornerRadius}" Padding="24,16"
                            Background="{ThemeResource HudSurfaceAltBrush}"
                            BorderBrush="{ThemeResource HudHairlineBrush}" BorderThickness="1"
                            Visibility="{x:Bind ViewModel.NoPresets, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="No built-in presets available"
                                   FontSize="13" Foreground="{StaticResource MutedBrush}"
                                   HorizontalAlignment="Center"/>
                    </Border>

                    <!-- MY SNAPSHOTS -->
                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="MY SNAPSHOTS"
                                   Style="{StaticResource HudMicroStyle}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" FontSize="11"
                                   Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center">
                            <Run Text="{x:Bind ViewModel.SnapshotCount, Mode=OneWay}"/>
                            <Run Text=" snapshots"/>
                        </TextBlock>
                    </Grid>

                    <ItemsRepeater x:Name="SnapshotsRepeater"
                                   ItemsSource="{x:Bind ViewModel.Snapshots, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Vertical" Spacing="4"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="models:SettingsProfile">
                                <Border Background="{ThemeResource HudSurfaceAltBrush}"
                                        CornerRadius="{StaticResource CardCornerRadius}"
                                        Padding="16,10"
                                        BorderBrush="{ThemeResource HudHairlineBrush}" BorderThickness="1">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold"
                                                       FontSize="13" TextTrimming="CharacterEllipsis"/>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock FontSize="11" Foreground="{StaticResource MutedBrush}">
                                                    <Run Text="Created "/>
                                                    <Run Text="{x:Bind CreatedAt, Converter={StaticResource DateTimeToString}}"/>
                                                </TextBlock>
                                                <TextBlock FontSize="11" Foreground="{StaticResource MutedBrush}">
                                                    <Run Text="· Last applied "/>
                                                    <Run Text="{x:Bind LastAppliedAt, Converter={StaticResource DateTimeToString}}"/>
                                                </TextBlock>
                                            </StackPanel>
                                            <TextBlock FontSize="11" Foreground="{StaticResource MutedBrush}">
                                                <Run Text="{x:Bind Optimizations.Count}"/>
                                                <Run Text=" optimizations"/>
                                            </TextBlock>
                                        </StackPanel>

                                        <Button Grid.Column="1" Content="APPLY"
                                                Style="{StaticResource AccentButtonStyle}"
                                                VerticalAlignment="Center"
                                                Click="SnapshotApply_Click" Tag="{x:Bind Id}"/>
                                        <Button Grid.Column="2" Content="Update"
                                                VerticalAlignment="Center"
                                                ToolTipService.ToolTip="Refresh this snapshot to the current applied state"
                                                Click="SnapshotUpdate_Click" Tag="{x:Bind Id}"/>
                                        <Button Grid.Column="3" Content="Delete"
                                                VerticalAlignment="Center"
                                                Foreground="{StaticResource DangerBrush}"
                                                Click="SnapshotDelete_Click" Tag="{x:Bind Id}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>

                    <Border x:Name="SnapshotsEmptyState"
                            CornerRadius="{StaticResource CardCornerRadius}" Padding="32"
                            Background="{ThemeResource HudSurfaceAltBrush}"
                            BorderBrush="{ThemeResource HudHairlineBrush}" BorderThickness="1"
                            Visibility="Collapsed">
                        <StackPanel HorizontalAlignment="Center" Spacing="12">
                            <TextBlock Text="&#x1F4F8;" FontSize="48" HorizontalAlignment="Center" Opacity="0.6"/>
                            <TextBlock Text="No saved snapshots"
                                       FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            <TextBlock Text="Click Save Snapshot to capture your current optimization state."
                                       FontSize="12" Foreground="{StaticResource MutedBrush}"
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap" MaxWidth="300" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- AUTO-SWITCHING RULES -->
                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="AUTO-SWITCHING RULES" Style="{StaticResource HudMicroStyle}"/>
                            <TextBlock FontSize="11" Foreground="{StaticResource MutedBrush}">
                                <Run Text="{x:Bind ViewModel.RuleCount, Mode=OneWay}"/>
                                <Run Text=" active rules — checked every 15 seconds"/>
                            </TextBlock>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Add Rule"
                                Style="{StaticResource AccentButtonStyle}"
                                Click="AddRule_Click"/>
                    </Grid>

                    <ItemsRepeater x:Name="RulesRepeater"
                                   ItemsSource="{x:Bind ViewModel.AutomationRules, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Vertical" Spacing="4"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="models:ProfileRule">
                                <Border Background="{ThemeResource HudSurfaceAltBrush}"
                                        CornerRadius="{StaticResource CardCornerRadius}"
                                        Padding="16,10"
                                        BorderBrush="{ThemeResource HudHairlineBrush}" BorderThickness="1">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold"
                                                       FontSize="13" TextTrimming="CharacterEllipsis"/>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Border CornerRadius="4" Padding="6,2"
                                                        Background="{ThemeResource HudSurfaceBrush}">
                                                    <TextBlock Text="{x:Bind Trigger}"
                                                               FontSize="10" FontWeight="SemiBold"
                                                               Foreground="{StaticResource InfoBrush}"/>
                                                </Border>
                                                <TextBlock FontSize="11"
                                                           Foreground="{StaticResource MutedBrush}"
                                                           VerticalAlignment="Center">
                                                    <Run Text="Apply: "/>
                                                    <Run Text="{x:Bind ProfileName}"/>
                                                </TextBlock>
                                            </StackPanel>
                                            <TextBlock x:Name="RuleDetail"
                                                       FontSize="11" Foreground="{StaticResource MutedBrush}"
                                                       Tag="{x:Bind Id}" Loaded="RuleDetail_Loaded"/>
                                        </StackPanel>

                                        <ToggleButton Grid.Column="1"
                                                      Content="{x:Bind IsEnabled, Mode=OneWay}"
                                                      IsChecked="{x:Bind IsEnabled, Mode=OneWay}"
                                                      VerticalAlignment="Center"
                                                      Click="RuleToggle_Click" Tag="{x:Bind Id}"/>
                                        <Button Grid.Column="2" Content="Delete"
                                                VerticalAlignment="Center"
                                                Foreground="{StaticResource DangerBrush}"
                                                Click="RuleDelete_Click" Tag="{x:Bind Id}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>

                    <Border x:Name="RulesEmptyState"
                            CornerRadius="{StaticResource CardCornerRadius}" Padding="32"
                            Background="{ThemeResource HudSurfaceAltBrush}"
                            BorderBrush="{ThemeResource HudHairlineBrush}" BorderThickness="1"
                            Visibility="Collapsed">
                        <StackPanel HorizontalAlignment="Center" Spacing="12">
                            <TextBlock Text="&#x23F2;&#xFE0F;" FontSize="48" HorizontalAlignment="Center" Opacity="0.6"/>
                            <TextBlock Text="No automation rules configured"
                                       FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            <TextBlock Text="Click Add Rule to automatically switch profiles based on time of day or running processes."
                                       FontSize="12" Foreground="{StaticResource MutedBrush}"
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap" MaxWidth="320" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </hud:HudBackdrop>
</Page>
