<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Optimizer.WinUI.Views.UpdatesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Optimizer.WinUI.Converters"
    xmlns:models="using:Optimizer.WinUI.Models"
    Background="Transparent"
    Loaded="Page_Loaded">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:DateTimeToStringConverter x:Key="DateTimeToString"/>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16" Padding="24,16,24,24">

            <!-- ── Page header ───────────────────────────────────────────────── -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <TextBlock Text="{x:Bind ViewModel.CategoryIcon}"
                               FontSize="28" VerticalAlignment="Center"/>
                    <StackPanel Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="{x:Bind ViewModel.CategoryName}"
                                   Style="{StaticResource TitleTextBlockStyle}"/>
                        <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                                   FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>

                <Button Grid.Column="1" Content="Refresh" VerticalAlignment="Center"
                        Click="Refresh_Click"/>
            </Grid>

            <!-- ── Loading indicator ────────────────────────────────────────── -->
            <ProgressBar IsIndeterminate="True"
                         Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>

            <!-- ═══════════════════════════════════════════════════════════════ -->
            <!--  SECTION 1 — Windows Update                                   -->
            <!-- ═══════════════════════════════════════════════════════════════ -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">

                    <!-- Section header -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE777;" FontSize="18" VerticalAlignment="Center"/>
                            <TextBlock Text="Windows Update"
                                       FontSize="16" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Content="Open Windows Update"
                                Style="{ThemeResource AccentButtonStyle}"
                                Click="OpenWindowsUpdate_Click"/>
                    </Grid>

                    <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                    <!-- Empty state -->
                    <TextBlock Text="No updates found in the last 60 days."
                               FontSize="13"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Visibility="{x:Bind ViewModel.HasNoRecentUpdates, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>

                    <!-- Update list -->
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.RecentUpdates, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Vertical" Spacing="6"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="models:WindowsUpdateInfo">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Spacing="1">
                                        <TextBlock Text="{x:Bind Title}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{x:Bind KbNumber}"
                                                   FontSize="11"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>

                                    <Border Grid.Column="1"
                                            Background="#10B981" CornerRadius="4" Padding="8,3"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Status}"
                                                   FontSize="10" FontWeight="SemiBold"
                                                   Foreground="White"/>
                                    </Border>

                                    <TextBlock Grid.Column="2"
                                               Text="{x:Bind InstalledOn, Converter={StaticResource DateTimeToString}}"
                                               FontSize="12"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>

                </StackPanel>
            </Border>

            <!-- ═══════════════════════════════════════════════════════════════ -->
            <!--  SECTION 2 — Application Updates (winget)                     -->
            <!-- ═══════════════════════════════════════════════════════════════ -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">

                    <!-- Section header -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE74C;" FontSize="18" VerticalAlignment="Center"/>
                            <TextBlock Text="Application Updates"
                                       FontSize="16" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <Border Background="{ThemeResource AccentFillColorDefaultBrush}"
                                    CornerRadius="10" Padding="8,2"
                                    VerticalAlignment="Center"
                                    Visibility="{x:Bind ViewModel.HasAppUpdates, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="{x:Bind ViewModel.AppUpdates.Count, Mode=OneWay}"
                                           FontSize="11" FontWeight="Bold" Foreground="White"/>
                            </Border>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Content="Upgrade All"
                                Style="{ThemeResource AccentButtonStyle}"
                                Click="UpgradeAll_Click"
                                IsEnabled="{x:Bind ViewModel.HasAppUpdates, Mode=OneWay}"
                                Visibility="{x:Bind ViewModel.HasAppUpdates, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>
                    </Grid>

                    <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                    <!-- All up to date -->
                    <StackPanel Spacing="8" HorizontalAlignment="Center"
                                Visibility="{x:Bind ViewModel.HasNoAppUpdates, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                        <FontIcon Glyph="&#xE930;" FontSize="32" HorizontalAlignment="Center"
                                  Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                        <TextBlock Text="All apps are up to date"
                                   FontSize="14" FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="winget found no pending upgrades."
                                   FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- App update list -->
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.AppUpdates, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Vertical" Spacing="6"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="models:AppUpdateInfo">
                                <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                                        CornerRadius="6" Padding="12,10">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Name + Id -->
                                        <StackPanel Grid.Column="0" Spacing="1" VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind Name}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{x:Bind Id}"
                                                       FontSize="11"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <!-- Current version -->
                                        <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                                            <TextBlock Text="Current"
                                                       FontSize="10"
                                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                            <TextBlock Text="{x:Bind CurrentVersion}"
                                                       FontSize="12"/>
                                        </StackPanel>

                                        <!-- Available version -->
                                        <StackPanel Grid.Column="2" Spacing="1" VerticalAlignment="Center">
                                            <TextBlock Text="Available"
                                                       FontSize="10"
                                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                            <TextBlock Text="{x:Bind AvailableVersion}"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                        </StackPanel>

                                        <!-- Upgrade button -->
                                        <Button Grid.Column="3"
                                                Content="Upgrade"
                                                VerticalAlignment="Center"
                                                Tag="{x:Bind}"
                                                Click="UpgradeApp_Click"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>

                </StackPanel>
            </Border>

            <!-- ═══════════════════════════════════════════════════════════════ -->
            <!--  SECTION 3 — BIOS / Firmware                                  -->
            <!-- ═══════════════════════════════════════════════════════════════ -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE950;" FontSize="18" VerticalAlignment="Center"/>
                        <TextBlock Text="BIOS / Firmware"
                                   FontSize="16" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                    <TextBlock Text="{x:Bind ViewModel.BiosInfo, Mode=OneWay}"
                               FontFamily="Consolas"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                    <TextBlock FontSize="12"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               TextWrapping="Wrap">
                        To update your BIOS/UEFI firmware, visit your motherboard manufacturer's support website. Search for your board model in the information above.
                    </TextBlock>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
