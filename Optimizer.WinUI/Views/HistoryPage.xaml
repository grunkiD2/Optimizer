<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Optimizer.WinUI.Views.HistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Optimizer.WinUI.Converters"
    xmlns:vm="using:Optimizer.WinUI.ViewModels"
    Background="Transparent"
    Loaded="Page_Loaded">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:StringToSolidColorBrushConverter x:Key="StringToBrush"/>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16" Padding="24,16,24,24">

            <!-- ── Page header ────────────────────────────────────────────── -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <TextBlock Text="{x:Bind ViewModel.CategoryIcon}"
                               FontSize="28" VerticalAlignment="Center"/>
                    <StackPanel Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="{x:Bind ViewModel.CategoryName}"
                                   Style="{StaticResource TitleTextBlockStyle}"/>
                        <TextBlock FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                            <Run Text="{x:Bind ViewModel.TotalCount, Mode=OneWay}"/>
                            <Run Text=" total entries"/>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button Content="Refresh"
                            Click="Refresh_Click"/>
                    <Button Content="Clear History"
                            Click="ClearHistory_Click"/>
                </StackPanel>
            </Grid>

            <!-- ── Status message ─────────────────────────────────────────── -->
            <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                       FontSize="12"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Visibility="{x:Bind ViewModel.HasStatusMessage, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>

            <!-- ── Loading indicator ───────────────────────────────────────── -->
            <ProgressBar IsIndeterminate="True"
                         Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>

            <!-- ── Empty state ─────────────────────────────────────────────── -->
            <Border CornerRadius="8" Padding="32"
                    Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" Background="{ThemeResource LayerFillColorDefaultBrush}">
                <StackPanel HorizontalAlignment="Center" Spacing="8">
                    <TextBlock Text="&#x1F4DC;" FontSize="40" HorizontalAlignment="Center"/>
                    <TextBlock Text="No history yet"
                               FontSize="16" FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Applied optimizations will appear here."
                               FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- ── Grouped history entries ─────────────────────────────────── -->
            <ItemsRepeater ItemsSource="{x:Bind ViewModel.GroupedEntries, Mode=OneWay}">
                <ItemsRepeater.Layout>
                    <StackLayout Orientation="Vertical" Spacing="16"/>
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="vm:HistoryEntryGroup">

                        <StackPanel Spacing="6">

                            <!-- Group header: date -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="{x:Bind DateHeaderText}"
                                           FontSize="13" FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>

                                <Rectangle Grid.Column="1"
                                           Height="1" Margin="10,0"
                                           VerticalAlignment="Center"
                                           Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                                <TextBlock Grid.Column="2"
                                           FontSize="11" VerticalAlignment="Center"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}">
                                    <Run Text="{x:Bind Count}"/>
                                    <Run Text=" entries"/>
                                </TextBlock>
                            </Grid>

                            <!-- Entry rows for this day -->
                            <ItemsRepeater ItemsSource="{x:Bind Entries}">
                                <ItemsRepeater.Layout>
                                    <StackLayout Orientation="Vertical" Spacing="4"/>
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="vm:HistoryEntryViewModel">

                                        <Border CornerRadius="8" Padding="14,10"
                                                BorderThickness="1"
                                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">

                                            <Grid ColumnSpacing="10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Title + category + time -->
                                                <StackPanel Grid.Column="0" Spacing="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{x:Bind Title}"
                                                               FontWeight="SemiBold" FontSize="13"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{x:Bind Category}"
                                                               FontSize="11"
                                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                    <TextBlock Text="{x:Bind TimeText}"
                                                               FontSize="10" Margin="0,3,0,0"
                                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                                </StackPanel>

                                                <!-- Action badge -->
                                                <Border Grid.Column="1"
                                                        Background="{x:Bind ActionBadgeColor, Converter={StaticResource StringToBrush}}"
                                                        CornerRadius="4" Padding="7,3"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{x:Bind ActionText}"
                                                               FontSize="10" Foreground="White"
                                                               FontWeight="SemiBold"/>
                                                </Border>

                                                <!-- REVERSIBLE badge -->
                                                <Border Grid.Column="2"
                                                        Background="#7C3AED"
                                                        CornerRadius="4" Padding="7,3"
                                                        VerticalAlignment="Center"
                                                        Visibility="{x:Bind IsReversible, Converter={StaticResource BoolToVisibility}}">
                                                    <TextBlock Text="REVERSIBLE"
                                                               FontSize="10" Foreground="White"
                                                               FontWeight="SemiBold"/>
                                                </Border>

                                                <!-- Undo button -->
                                                <Button Grid.Column="3"
                                                        Content="&#x21B6; UNDO"
                                                        MinWidth="72"
                                                        VerticalAlignment="Center"
                                                        Tag="{x:Bind}"
                                                        Click="UndoEntry_Click"
                                                        Visibility="{x:Bind CanUndo, Converter={StaticResource BoolToVisibility}}"/>
                                            </Grid>
                                        </Border>

                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>

                        </StackPanel>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

        </StackPanel>
    </ScrollViewer>
</Page>
