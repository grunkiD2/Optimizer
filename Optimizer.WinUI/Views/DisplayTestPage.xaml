<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Optimizer.WinUI.Views.DisplayTestPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Black">

    <Grid x:Name="RootGrid" Background="Black">
        <!-- Color fill overlay — visible when a test is active -->
        <Border x:Name="ColorFill"
                Visibility="Collapsed"
                Tapped="ColorFill_Tapped"/>

        <!-- Menu panel — shown when no test is active -->
        <StackPanel x:Name="MenuPanel"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="20"
                    MaxWidth="560">

            <!-- Back button -->
            <Button Content="&#xE72B; Back"
                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                    Click="Back_Click"
                    HorizontalAlignment="Left"/>

            <TextBlock Text="Display Test"
                       FontSize="36"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Foreground="White"/>

            <TextBlock Text="Select a colour to fill the screen. Tap anywhere or press Esc to return to this menu."
                       Foreground="#CCCCCC"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       FontSize="14"/>

            <!-- Colour buttons -->
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Tag="White"
                        Content="White"
                        Background="White"
                        Foreground="Black"
                        HorizontalAlignment="Stretch"
                        Padding="0,20"
                        Click="Color_Click"/>

                <Button Grid.Column="1"
                        Tag="Black"
                        Content="Black"
                        Background="#111111"
                        Foreground="White"
                        HorizontalAlignment="Stretch"
                        Padding="0,20"
                        Click="Color_Click"/>

                <Button Grid.Column="2"
                        Tag="Red"
                        Content="Red"
                        Background="#EF4444"
                        Foreground="White"
                        HorizontalAlignment="Stretch"
                        Padding="0,20"
                        Click="Color_Click"/>

                <Button Grid.Column="3"
                        Tag="Green"
                        Content="Green"
                        Background="#22C55E"
                        Foreground="White"
                        HorizontalAlignment="Stretch"
                        Padding="0,20"
                        Click="Color_Click"/>

                <Button Grid.Column="4"
                        Tag="Blue"
                        Content="Blue"
                        Background="#3B82F6"
                        Foreground="White"
                        HorizontalAlignment="Stretch"
                        Padding="0,20"
                        Click="Color_Click"/>
            </Grid>

            <TextBlock Text="Dead Pixel Scan Tip: cycle through White, Black, Red, Green, Blue and look for pixels that stay a different colour."
                       Foreground="#999999"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       FontSize="12"/>
        </StackPanel>
    </Grid>
</Page>
