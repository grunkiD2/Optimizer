<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Optimizer.WinUI.Views.FleetPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Optimizer.WinUI.Models"
    xmlns:converters="using:Optimizer.WinUI.Converters"
    Background="Transparent"
    Loaded="Page_Loaded">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:StringToSolidColorBrushConverter x:Key="ColorToBrush"/>
    </Page.Resources>

    <Grid Margin="24,16,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Page header ──────────────────────────────────────────────── -->
        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <TextBlock Text="{x:Bind ViewModel.CategoryIcon}" FontSize="28" VerticalAlignment="Center"/>
                <TextBlock Text="{x:Bind ViewModel.CategoryName}"
                           Style="{StaticResource TitleTextBlockStyle}" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Text="Multi-machine roster, status monitoring, and CSV import/export."
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
        </StackPanel>

        <!-- ── Toolbar ───────────────────────────────────────────────────── -->
        <Grid Grid.Row="1" ColumnSpacing="8" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     PlaceholderText="Search machines…"
                     Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <Button Grid.Column="1" Content="Import CSV"  Click="ImportCsv_Click"/>
            <Button Grid.Column="2" Content="Add Machine" Click="AddMachine_Click"/>
            <Button Grid.Column="3" Content="Ping All"    Click="PingAll_Click"/>
            <Button Grid.Column="4" Content="Export CSV"  Click="ExportCsv_Click"/>
            <Button Grid.Column="5" Content="Refresh"     Click="Refresh_Click"/>
        </Grid>

        <!-- ── Status / loading ──────────────────────────────────────────── -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                          Width="20" Height="20"
                          Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>
            <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       FontSize="12" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- ── Column headers ───────────────────────────────────────────── -->
        <Grid Grid.Row="3" Margin="14,0,14,4" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Machine" FontWeight="SemiBold" FontSize="11"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <TextBlock Grid.Column="1" Text="Host / IP" FontWeight="SemiBold" FontSize="11"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <TextBlock Grid.Column="2" Text="Status" FontWeight="SemiBold" FontSize="11"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <TextBlock Grid.Column="3" Text="Department" FontWeight="SemiBold" FontSize="11"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <TextBlock Grid.Column="4" Text="Last Seen" FontWeight="SemiBold" FontSize="11"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <TextBlock Grid.Column="5" Text="Ping" FontWeight="SemiBold" FontSize="11"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <TextBlock Grid.Column="6" Text="Remove" FontWeight="SemiBold" FontSize="11"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Grid>

        <!-- ── Machine list ──────────────────────────────────────────────── -->
        <ListView Grid.Row="4"
                  ItemsSource="{x:Bind ViewModel.Machines, Mode=OneWay}"
                  SelectionMode="None">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0,0,0,4"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:FleetMachine">
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8" Padding="14,10"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>

                            <!-- Name + owner -->
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind Name, Mode=OneWay}"
                                           FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{x:Bind Owner, Mode=OneWay}"
                                           FontSize="11"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>

                            <!-- Host / IP -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind HostName, Mode=OneWay}"
                                           FontSize="12" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{x:Bind IpAddress, Mode=OneWay}"
                                           FontSize="11"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                            </StackPanel>

                            <!-- Status pill -->
                            <Border Grid.Column="2"
                                    CornerRadius="4" Padding="6,3"
                                    VerticalAlignment="Center" HorizontalAlignment="Left"
                                    Background="{x:Bind StatusColor, Mode=OneWay, Converter={StaticResource ColorToBrush}}">
                                <TextBlock Text="{x:Bind Status, Mode=OneWay}"
                                           FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                            </Border>

                            <!-- Department -->
                            <TextBlock Grid.Column="3"
                                       Text="{x:Bind Department, Mode=OneWay}"
                                       VerticalAlignment="Center" FontSize="12"
                                       TextTrimming="CharacterEllipsis"/>

                            <!-- Last seen -->
                            <TextBlock Grid.Column="4"
                                       Text="{x:Bind LastSeen, Mode=OneWay}"
                                       VerticalAlignment="Center" FontSize="11"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                            <!-- Ping button -->
                            <Button Grid.Column="5"
                                    Content="Ping"
                                    Tag="{x:Bind}"
                                    Click="Ping_Click"
                                    VerticalAlignment="Center"
                                    FontSize="11"/>

                            <!-- Delete button -->
                            <Button Grid.Column="6"
                                    Content="Remove"
                                    Tag="{x:Bind Name}"
                                    Click="Delete_Click"
                                    VerticalAlignment="Center"
                                    FontSize="11"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <!-- ── Empty state ─────────────────────────────────────────────── -->
        <Border Grid.Row="5" CornerRadius="8" Padding="32"
                Margin="0,8,0,0"
                Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                Background="{ThemeResource LayerFillColorDefaultBrush}">
            <StackPanel HorizontalAlignment="Center" Spacing="12">
                <TextBlock Text="&#x1F5A5;&#xFE0F;" FontSize="48" HorizontalAlignment="Center" Opacity="0.6"/>
                <TextBlock Text="No machines yet"
                           FontSize="16" FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Import a CSV roster or click Add Machine to build your fleet."
                           FontSize="12" HorizontalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap" MaxWidth="300" TextAlignment="Center"/>
            </StackPanel>
        </Border>

    </Grid>
</Page>
