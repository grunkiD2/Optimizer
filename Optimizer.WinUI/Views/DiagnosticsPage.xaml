<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Optimizer.WinUI.Views.DiagnosticsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Optimizer.WinUI.Models"
    xmlns:converters="using:Optimizer.WinUI.Converters"
    xmlns:local="using:Optimizer.WinUI.Converters"
    xmlns:svc="using:Optimizer.WinUI.Services"
    Background="Transparent">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:StringToSolidColorBrushConverter x:Key="StringToSolidColorBrush"/>
    </Page.Resources>


    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="24,16,24,24" Spacing="16">

            <!-- ── Header ────────────────────────────────────────────────── -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="2">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="{x:Bind ViewModel.CategoryIcon}"
                                   FontSize="28" VerticalAlignment="Center"/>
                        <TextBlock Text="{x:Bind ViewModel.CategoryName}"
                                   Style="{StaticResource TitleTextBlockStyle}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="System health analysis"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               FontSize="13"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Quick Scan"
                        VerticalAlignment="Bottom"
                        Click="QuickScan_Click"/>
                <Button Grid.Column="2"
                        Content="Full Scan"
                        Style="{ThemeResource AccentButtonStyle}"
                        Margin="8,0,0,0"
                        VerticalAlignment="Bottom"
                        Click="FullScan_Click"/>
            </Grid>

            <!-- ── Progress ──────────────────────────────────────────────── -->
            <ProgressBar IsIndeterminate="True"
                         Visibility="{x:Bind ViewModel.IsScanning, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>
            <TextBlock Text="{x:Bind ViewModel.ProgressText, Mode=OneWay}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       FontSize="12"
                       Visibility="{x:Bind ViewModel.IsScanning, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>

            <!-- ── Summary cards ─────────────────────────────────────────── -->
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#EF4444" CornerRadius="8" Padding="16">
                    <StackPanel>
                        <TextBlock Text="CRITICAL" FontSize="10" Foreground="White" Opacity="0.85"/>
                        <TextBlock Text="{x:Bind ViewModel.CriticalCount, Mode=OneWay}"
                                   FontSize="32" FontWeight="Bold" Foreground="White"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="#F59E0B" CornerRadius="8" Padding="16">
                    <StackPanel>
                        <TextBlock Text="WARNINGS" FontSize="10" Foreground="White" Opacity="0.85"/>
                        <TextBlock Text="{x:Bind ViewModel.WarningCount, Mode=OneWay}"
                                   FontSize="32" FontWeight="Bold" Foreground="White"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="#3B82F6" CornerRadius="8" Padding="16">
                    <StackPanel>
                        <TextBlock Text="INFO" FontSize="10" Foreground="White" Opacity="0.85"/>
                        <TextBlock Text="{x:Bind ViewModel.InfoCount, Mode=OneWay}"
                                   FontSize="32" FontWeight="Bold" Foreground="White"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── Filter bar ────────────────────────────────────────────── -->
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Findings"
                           FontSize="18" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>

                <ComboBox Grid.Column="1"
                          ItemsSource="{x:Bind ViewModel.SeverityOptions}"
                          SelectedItem="{x:Bind ViewModel.FilterSeverity, Mode=TwoWay}"
                          MinWidth="120"/>

                <ComboBox Grid.Column="2"
                          ItemsSource="{x:Bind ViewModel.CategoryOptions}"
                          SelectedItem="{x:Bind ViewModel.FilterCategory, Mode=TwoWay}"
                          MinWidth="140"/>
            </Grid>

            <!-- ── No findings empty state ──────────────────────────────── -->
            <Border CornerRadius="8" Padding="32"
                    Visibility="{x:Bind ViewModel.IsFindingsEmpty, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                    Background="{ThemeResource LayerFillColorDefaultBrush}">
                <StackPanel HorizontalAlignment="Center" Spacing="12">
                    <TextBlock Text="&#x2705;" FontSize="48" HorizontalAlignment="Center" Opacity="0.8"/>
                    <TextBlock Text="No issues found"
                               FontSize="16" FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Your system is healthy! Run a full scan periodically to stay on top of any changes."
                               FontSize="12" HorizontalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap" MaxWidth="320" TextAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- ── Findings list ─────────────────────────────────────────── -->
            <ItemsRepeater x:Name="FindingsRepeater"
                           ItemsSource="{x:Bind ViewModel.Findings, Mode=OneWay}">
                <ItemsRepeater.Layout>
                    <StackLayout Orientation="Vertical" Spacing="8"/>
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="models:DiagnosticFinding">
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="8" Padding="16"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1">
                            <StackPanel Spacing="8">
                                <!-- Title row -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="{x:Bind CategoryIcon}"
                                               FontSize="20"
                                               Margin="0,0,12,0"
                                               VerticalAlignment="Center"/>

                                    <TextBlock Grid.Column="1"
                                               Text="{x:Bind Title, Mode=OneWay}"
                                               FontWeight="SemiBold"
                                               FontSize="14"
                                               VerticalAlignment="Center"
                                               TextWrapping="Wrap"/>

                                    <Border Grid.Column="2"
                                            CornerRadius="4" Padding="8,3"
                                            VerticalAlignment="Center"
                                            Background="{x:Bind SeverityColor, Converter={StaticResource StringToSolidColorBrush}}">
                                        <TextBlock Text="{x:Bind SeverityBadge}"
                                                   FontSize="10" FontWeight="Bold"
                                                   Foreground="White"/>
                                    </Border>
                                </Grid>

                                <!-- Description -->
                                <TextBlock Text="{x:Bind Description, Mode=OneWay}"
                                           TextWrapping="Wrap"
                                           FontSize="13"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                                <!-- Recommendation -->
                                <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                        CornerRadius="4" Padding="10,8">
                                    <StackPanel Spacing="3">
                                        <TextBlock Text="RECOMMENDATION"
                                                   FontSize="10" FontWeight="Bold"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Text="{x:Bind Recommendation, Mode=OneWay}"
                                                   TextWrapping="Wrap" FontSize="12"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

            <!-- ══════════════════════════════════════════════════════════════ -->
            <!-- ── Driver Conflicts section ──────────────────────────────── -->
            <!-- ══════════════════════════════════════════════════════════════ -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="🔌 Driver Conflicts" FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock Text="Scan Device Manager for problem devices and outdated drivers."
                                       FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="Scan Drivers"
                                VerticalAlignment="Center"
                                Click="ScanDrivers_Click"/>
                    </Grid>

                    <ProgressBar IsIndeterminate="True"
                                 Visibility="{x:Bind ViewModel.IsDriverScanning, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>

                    <TextBlock Text="{x:Bind ViewModel.DriverScanStatus, Mode=OneWay}"
                               FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.DriverIssues, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Vertical" Spacing="6"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="models:DriverIssue">
                                <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                        CornerRadius="6" Padding="12">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Spacing="2">
                                            <TextBlock Text="{x:Bind DeviceName}" FontWeight="SemiBold" FontSize="13" TextWrapping="Wrap"/>
                                            <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                                <Run Text="{x:Bind DeviceClass}"/>
                                                <Run Text=" · "/>
                                                <Run Text="{x:Bind ErrorMessage}"/>
                                            </TextBlock>
                                            <TextBlock Text="{x:Bind DriverDateDisplay}"
                                                       FontSize="11"
                                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                        </StackPanel>
                                        <Border Grid.Column="1"
                                                CornerRadius="4" Padding="8,3"
                                                VerticalAlignment="Top"
                                                Background="{x:Bind SeverityColor, Converter={StaticResource StringToSolidColorBrush}}">
                                            <TextBlock Text="{x:Bind SeverityLabel}"
                                                       FontSize="10" FontWeight="Bold"
                                                       Foreground="White"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>
            </Border>

            <!-- ══════════════════════════════════════════════════════════════ -->
            <!-- ── Performance Bottleneck section ───────────────────────── -->
            <!-- ══════════════════════════════════════════════════════════════ -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="⚡ Performance Bottlenecks" FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock Text="Detect memory leaks, high-CPU and memory-hungry processes (30 s sample)."
                                       FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="Detect Bottlenecks"
                                VerticalAlignment="Center"
                                Click="DetectBottlenecks_Click"/>
                    </Grid>

                    <ProgressBar IsIndeterminate="True"
                                 Visibility="{x:Bind ViewModel.IsBottleneckRunning, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>

                    <TextBlock Text="{x:Bind ViewModel.BottleneckStatus, Mode=OneWay}"
                               FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                    <TextBlock Text="{x:Bind ViewModel.BottleneckSummary, Mode=OneWay}"
                               FontSize="13" FontWeight="SemiBold"/>

                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.Bottlenecks, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Vertical" Spacing="6"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="models:ProcessBottleneck">
                                <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                        CornerRadius="6" Padding="12">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Spacing="2">
                                            <TextBlock Text="{x:Bind ProcessName}" FontWeight="SemiBold" FontSize="13"/>
                                            <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                                <Run Text="PID "/>
                                                <Run Text="{x:Bind Pid}"/>
                                                <Run Text=" · "/>
                                                <Run Text="{x:Bind BottleneckType}"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1"
                                                   Text="{x:Bind DisplayValue}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                        <Border Grid.Column="2"
                                                CornerRadius="4" Padding="8,3"
                                                VerticalAlignment="Center"
                                                Background="{x:Bind SeverityColor, Converter={StaticResource StringToSolidColorBrush}}">
                                            <TextBlock Text="{x:Bind Severity}"
                                                       FontSize="10" FontWeight="Bold"
                                                       Foreground="White"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>
            </Border>

            <!-- ══════════════════════════════════════════════════════════════ -->
            <!-- ── Network Deep Diagnostics section ──────────────────────── -->
            <!-- ══════════════════════════════════════════════════════════════ -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="🌐 Network Deep Diagnostics" FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock Text="Traceroute, MTU discovery, and 100-ping packet loss test to 1.1.1.1."
                                       FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="Run Network Test"
                                VerticalAlignment="Center"
                                Click="RunNetworkDeep_Click"/>
                    </Grid>

                    <ProgressBar IsIndeterminate="True"
                                 Visibility="{x:Bind ViewModel.IsNetworkDeepRunning, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>

                    <TextBlock Text="{x:Bind ViewModel.NetworkDeepStatus, Mode=OneWay}"
                               FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.NetworkDiagnostics, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Vertical" Spacing="6"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="models:NetworkDiagnostic">
                                <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                        CornerRadius="6" Padding="12">
                                    <StackPanel Spacing="6">
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{x:Bind StatusIcon}"
                                                       FontSize="16"
                                                       VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1" Spacing="1">
                                                <TextBlock Text="{x:Bind Type}" FontWeight="SemiBold" FontSize="13"/>
                                                <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                                    <Run Text="Target: "/>
                                                    <Run Text="{x:Bind Target}"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                      VerticalScrollBarVisibility="Disabled"
                                                      MaxHeight="200">
                                            <TextBlock Text="{x:Bind Result}"
                                                       FontFamily="Consolas"
                                                       FontSize="11"
                                                       TextWrapping="Wrap"/>
                                        </ScrollViewer>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>
            </Border>

            <!-- ══════════════════════════════════════════════════════════════ -->
            <!-- ── PREDICTIONS section ───────────────────────────────────── -->
            <!-- ══════════════════════════════════════════════════════════════ -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="12">

                    <!-- Header -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="&#x1F52E; Predictions" FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock Text="Drive-space exhaustion forecast and disk-health risk assessment."
                                       FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="Refresh Forecasts"
                                VerticalAlignment="Center"
                                Click="LoadPredictions_Click"/>
                    </Grid>

                    <ProgressBar IsIndeterminate="True"
                                 Visibility="{x:Bind ViewModel.IsPredictionLoading, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>

                    <TextBlock Text="{x:Bind ViewModel.PredictionStatus, Mode=OneWay}"
                               FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                    <!-- Drive-space forecasts -->
                    <TextBlock Text="Drive Space Forecasts"
                               FontSize="14" FontWeight="SemiBold"/>

                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.DriveForecasts, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Vertical" Spacing="6"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="svc:DriveSpaceForecast">
                                <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                        CornerRadius="6" Padding="12">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Drive letter badge -->
                                        <Border Grid.Column="0"
                                                Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                CornerRadius="6" Width="40" Height="40">
                                            <TextBlock Text="{x:Bind Drive}"
                                                       FontSize="16" FontWeight="Bold"
                                                       Foreground="White"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- Stats -->
                                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                            <TextBlock FontSize="13" FontWeight="SemiBold">
                                                <Run Text="{x:Bind FreeGbText}"/>
                                                <Run Text=" free of "/>
                                                <Run Text="{x:Bind TotalGbText}"/>
                                            </TextBlock>
                                            <TextBlock Text="{x:Bind GbPerDayText}"
                                                       FontSize="11"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>

                                        <!-- Days-until-full badge -->
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center"
                                                    HorizontalAlignment="Right" Spacing="2">
                                            <TextBlock Text="{x:Bind DaysUntilFullText}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       HorizontalAlignment="Right"/>
                                            <TextBlock Text="until full"
                                                       FontSize="10"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       HorizontalAlignment="Right"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>

                    <!-- Disk-health forecasts -->
                    <TextBlock Text="Disk Health Forecasts"
                               FontSize="14" FontWeight="SemiBold"
                               Margin="0,8,0,0"/>

                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.DiskForecasts, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Vertical" Spacing="6"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="svc:DiskFailureForecast">
                                <Border CornerRadius="6" Padding="12"
                                        Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Spacing="3">
                                            <TextBlock Text="{x:Bind Model}"
                                                       FontWeight="SemiBold" FontSize="13"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock Text="{x:Bind Reason}"
                                                       FontSize="11" TextWrapping="Wrap"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                                    HorizontalAlignment="Right" Spacing="2">
                                            <TextBlock Text="{x:Bind HealthScoreText}"
                                                       FontSize="14" FontWeight="Bold"
                                                       HorizontalAlignment="Right"/>
                                            <TextBlock Text="{x:Bind RiskBadge}"
                                                       FontSize="10" FontWeight="Bold"
                                                       HorizontalAlignment="Right"
                                                       Foreground="{x:Bind RiskColor, Converter={StaticResource StringToSolidColorBrush}}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>

                </StackPanel>
            </Border>

            <!-- ══════════════════════════════════════════════════════════════ -->
            <!-- ── Display Test launch ───────────────────────────────────── -->
            <!-- ══════════════════════════════════════════════════════════════ -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Text="🖥️ Display Test" FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock Text="Full-screen colour panels to check for dead pixels and colour accuracy."
                                   FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Content="Open Display Test"
                            Style="{ThemeResource AccentButtonStyle}"
                            VerticalAlignment="Center"
                            Click="OpenDisplayTest_Click"/>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
