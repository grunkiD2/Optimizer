<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Optimizer.WinUI.Views.DiagnosticsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Optimizer.WinUI.Models"
    xmlns:converters="using:Optimizer.WinUI.Converters"
    Background="Transparent">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:StringToSolidColorBrushConverter x:Key="StringToSolidColorBrush"/>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" Spacing="16">

            <!-- ── Header ────────────────────────────────────────────────── -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="2">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="{x:Bind ViewModel.CategoryIcon}"
                                   FontSize="28" VerticalAlignment="Center"/>
                        <TextBlock Text="{x:Bind ViewModel.CategoryName}"
                                   Style="{StaticResource TitleTextBlockStyle}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="System health analysis"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               FontSize="13"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Quick Scan"
                        VerticalAlignment="Bottom"
                        Click="QuickScan_Click"/>
                <Button Grid.Column="2"
                        Content="Full Scan"
                        Style="{ThemeResource AccentButtonStyle}"
                        Margin="8,0,0,0"
                        VerticalAlignment="Bottom"
                        Click="FullScan_Click"/>
            </Grid>

            <!-- ── Progress ──────────────────────────────────────────────── -->
            <ProgressBar IsIndeterminate="True"
                         Visibility="{x:Bind ViewModel.IsScanning, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>
            <TextBlock Text="{x:Bind ViewModel.ProgressText, Mode=OneWay}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       FontSize="12"
                       Visibility="{x:Bind ViewModel.IsScanning, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>

            <!-- ── Summary cards ─────────────────────────────────────────── -->
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#EF4444" CornerRadius="8" Padding="16">
                    <StackPanel>
                        <TextBlock Text="CRITICAL" FontSize="10" Foreground="White" Opacity="0.85"/>
                        <TextBlock Text="{x:Bind ViewModel.CriticalCount, Mode=OneWay}"
                                   FontSize="32" FontWeight="Bold" Foreground="White"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="#F59E0B" CornerRadius="8" Padding="16">
                    <StackPanel>
                        <TextBlock Text="WARNINGS" FontSize="10" Foreground="White" Opacity="0.85"/>
                        <TextBlock Text="{x:Bind ViewModel.WarningCount, Mode=OneWay}"
                                   FontSize="32" FontWeight="Bold" Foreground="White"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="#3B82F6" CornerRadius="8" Padding="16">
                    <StackPanel>
                        <TextBlock Text="INFO" FontSize="10" Foreground="White" Opacity="0.85"/>
                        <TextBlock Text="{x:Bind ViewModel.InfoCount, Mode=OneWay}"
                                   FontSize="32" FontWeight="Bold" Foreground="White"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── Filter bar ────────────────────────────────────────────── -->
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Findings"
                           FontSize="18" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>

                <ComboBox Grid.Column="1"
                          ItemsSource="{x:Bind ViewModel.SeverityOptions}"
                          SelectedItem="{x:Bind ViewModel.FilterSeverity, Mode=TwoWay}"
                          MinWidth="120"/>

                <ComboBox Grid.Column="2"
                          ItemsSource="{x:Bind ViewModel.CategoryOptions}"
                          SelectedItem="{x:Bind ViewModel.FilterCategory, Mode=TwoWay}"
                          MinWidth="140"/>
            </Grid>

            <!-- ── Findings list ─────────────────────────────────────────── -->
            <ItemsRepeater x:Name="FindingsRepeater"
                           ItemsSource="{x:Bind ViewModel.Findings, Mode=OneWay}">
                <ItemsRepeater.Layout>
                    <StackLayout Orientation="Vertical" Spacing="8"/>
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="models:DiagnosticFinding">
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="8" Padding="16"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1">
                            <StackPanel Spacing="8">
                                <!-- Title row -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="{x:Bind CategoryIcon}"
                                               FontSize="20"
                                               Margin="0,0,12,0"
                                               VerticalAlignment="Center"/>

                                    <TextBlock Grid.Column="1"
                                               Text="{x:Bind Title, Mode=OneWay}"
                                               FontWeight="SemiBold"
                                               FontSize="14"
                                               VerticalAlignment="Center"
                                               TextWrapping="Wrap"/>

                                    <Border Grid.Column="2"
                                            CornerRadius="4" Padding="8,3"
                                            VerticalAlignment="Center"
                                            Background="{x:Bind SeverityColor, Converter={StaticResource StringToSolidColorBrush}}">
                                        <TextBlock Text="{x:Bind SeverityBadge}"
                                                   FontSize="10" FontWeight="Bold"
                                                   Foreground="White"/>
                                    </Border>
                                </Grid>

                                <!-- Description -->
                                <TextBlock Text="{x:Bind Description, Mode=OneWay}"
                                           TextWrapping="Wrap"
                                           FontSize="13"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                                <!-- Recommendation -->
                                <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                        CornerRadius="4" Padding="10,8">
                                    <StackPanel Spacing="3">
                                        <TextBlock Text="RECOMMENDATION"
                                                   FontSize="9" FontWeight="Bold"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Text="{x:Bind Recommendation, Mode=OneWay}"
                                                   TextWrapping="Wrap" FontSize="12"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

        </StackPanel>
    </ScrollViewer>
</Page>
