<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Optimizer.WinUI.Views.TuningPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Optimizer.WinUI.Converters"
    xmlns:models="using:Optimizer.WinUI.Models"
    xmlns:services="using:Optimizer.WinUI.Services"
    Background="Transparent"
    Loaded="Page_Loaded">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:BoolToInstalledBrushConverter x:Key="BoolToInstalledBrush"/>
        <converters:BoolToInstalledTextConverter  x:Key="BoolToInstalledText"/>
        <converters:BoolToActionTextConverter     x:Key="BoolToActionText"/>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16" Padding="24,16,24,24">

            <!-- ── Page header ─────────────────────────────────────────────── -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <TextBlock Text="{x:Bind ViewModel.CategoryIcon}"
                               FontSize="28" VerticalAlignment="Center"/>
                    <StackPanel Spacing="2" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind ViewModel.CategoryName}"
                                       Style="{StaticResource TitleTextBlockStyle}"/>
                            <Border CornerRadius="4" Padding="6,2"
                                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                    VerticalAlignment="Center">
                                <TextBlock FontSize="10" FontWeight="SemiBold">
                                    <Run Text="CPU: "/>
                                    <Run Text="{x:Bind ViewModel.CpuVendor, Mode=OneWay}"/>
                                </TextBlock>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="CPU power management tuning, GPU info, RAM info, stress test"
                                   FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Revert to Defaults"
                        Click="Revert_Click"
                        VerticalAlignment="Center"
                        IsEnabled="{x:Bind ViewModel.IsApplying, Mode=OneWay, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"/>
            </Grid>

            <!-- ── Loading indicator ───────────────────────────────────────── -->
            <ProgressBar IsIndeterminate="True"
                         Visibility="{x:Bind ViewModel.IsApplying, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>

            <!-- ── Status message ──────────────────────────────────────────── -->
            <InfoBar x:Name="StatusInfoBar"
                     Severity="Informational"
                     IsClosable="True"
                     IsOpen="{x:Bind ViewModel.HasStatusMessage, Mode=OneWay}"
                     Title="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"/>

            <!-- ── Disclaimer banner ───────────────────────────────────────── -->
            <InfoBar Severity="Warning"
                     IsOpen="True"
                     IsClosable="False"
                     Title="Warranty and stability notice">
                <InfoBar.Content>
                    <StackPanel Spacing="8" Margin="0,4,0,8">
                        <TextBlock TextWrapping="Wrap" FontSize="12">
                            CPU tuning changes Windows power management settings that affect processor frequency,
                            boost behavior, and heat output. Aggressive presets may increase power consumption,
                            reduce CPU lifespan on sustained loads, and trigger thermal throttling on
                            cooling-limited systems. Use the Stock preset to revert at any time.
                            Administrator privileges are required to apply changes.
                        </TextBlock>
                        <CheckBox Content="I understand the risks and want to proceed"
                                  IsChecked="{x:Bind ViewModel.HasReadDisclaimer, Mode=TwoWay}"/>
                    </StackPanel>
                </InfoBar.Content>
            </InfoBar>

            <!-- ═══════════════════════════════════════════════════════════════
                 POWER BUDGET (READ-ONLY)
            ════════════════════════════════════════════════════════════════ -->
            <TextBlock Text="POWER BUDGET (READ-ONLY)"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="0,8,0,0"/>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <Grid ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="2">
                        <TextBlock Text="PL1 (Sustained TDP)" FontSize="10"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="{x:Bind ViewModel.Pl1Display, Mode=OneWay}"
                                   FontSize="18" FontWeight="Bold"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="2">
                        <TextBlock Text="PL2 (Burst TDP)" FontSize="10"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="{x:Bind ViewModel.Pl2Display, Mode=OneWay}"
                                   FontSize="18" FontWeight="Bold"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="PL1/PL2 values require RAPL kernel access (N/A via standard WMI)."
                                   FontSize="11" TextWrapping="Wrap"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══════════════════════════════════════════════════════════════
                 STRESS TEST
            ════════════════════════════════════════════════════════════════ -->
            <TextBlock Text="STRESS TEST"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="0,8,0,0"/>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="12">

                    <!-- Controls row -->
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="4">
                            <TextBlock Text="DURATION (s)" FontSize="10"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <NumberBox Value="{x:Bind ViewModel.StressDurationSeconds, Mode=TwoWay}"
                                       Minimum="10" Maximum="600" SpinButtonPlacementMode="Inline"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Text="WATCHDOG (°C)" FontSize="10"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <NumberBox Value="{x:Bind ViewModel.WatchdogTempLimit, Mode=TwoWay}"
                                       Minimum="60" Maximum="105" SpinButtonPlacementMode="Inline"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" VerticalAlignment="Bottom" Spacing="4">
                            <Button x:Name="RunBuiltInBtn"
                                    Content="Run Built-in Test"
                                    Click="RunBuiltIn_Click"
                                    Style="{ThemeResource AccentButtonStyle}"
                                    HorizontalAlignment="Stretch"
                                    IsEnabled="{x:Bind ViewModel.HasReadDisclaimer, Mode=OneWay}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Progress bar (visible while running) -->
                    <Grid ColumnSpacing="8"
                          Visibility="{x:Bind ViewModel.IsStressTesting, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ProgressBar Maximum="{x:Bind ViewModel.StressDurationSeconds, Mode=OneWay}"
                                     Value="{x:Bind ViewModel.StressElapsedSec, Mode=OneWay}"
                                     VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="Stop" Click="StopStress_Click"/>
                    </Grid>

                    <!-- Live stats row -->
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2">
                            <TextBlock Text="CURRENT TEMP" FontSize="10"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{x:Bind ViewModel.CurrentTempDisplay, Mode=OneWay}"
                                       FontSize="18" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="MAX TEMP" FontSize="10"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{x:Bind ViewModel.MaxTempDisplay, Mode=OneWay}"
                                       FontSize="18" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="2">
                            <TextBlock Text="CPU LOAD" FontSize="10"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{x:Bind ViewModel.CurrentLoadDisplay, Mode=OneWay}"
                                       FontSize="18" FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>

                    <!-- Status message -->
                    <TextBlock Text="{x:Bind ViewModel.StressStatus, Mode=OneWay}"
                               FontSize="11"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap"/>

                    <!-- External tool launchers -->
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Content="Launch Prime95"
                                Click="LaunchPrime95_Click"
                                HorizontalAlignment="Stretch"/>
                        <Button Grid.Column="1"
                                Content="Launch Cinebench"
                                Click="LaunchCinebench_Click"
                                HorizontalAlignment="Stretch"/>
                    </Grid>

                </StackPanel>
            </Border>

            <!-- ═══════════════════════════════════════════════════════════════
                 TUNING PRESETS
            ════════════════════════════════════════════════════════════════ -->
            <TextBlock Text="TUNING PRESETS"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="0,8,0,0"/>

            <ItemsRepeater ItemsSource="{x:Bind ViewModel.Presets}">
                <ItemsRepeater.Layout>
                    <UniformGridLayout MinItemWidth="270" MinItemHeight="180"
                                       MinColumnSpacing="8" MinRowSpacing="8"
                                       ItemsStretch="Fill"/>
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="models:TuningPreset">
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="14">
                            <Grid RowSpacing="6">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>  <!-- header: name + risk badge -->
                                    <RowDefinition Height="*"/>     <!-- description (grows) -->
                                    <RowDefinition Height="Auto"/>  <!-- metadata row -->
                                    <RowDefinition Height="Auto"/>  <!-- apply button -->
                                </Grid.RowDefinitions>

                                <!-- Name + risk badge -->
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{x:Bind Name}"
                                               FontWeight="SemiBold" FontSize="14"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center"/>
                                    <Border Grid.Column="1"
                                            CornerRadius="4" Padding="6,2"
                                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Risk}" FontSize="10" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>

                                <!-- Description -->
                                <TextBlock Grid.Row="1"
                                           Text="{x:Bind Description}"
                                           FontSize="12" TextWrapping="Wrap"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                                <!-- Optional metadata row -->
                                <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="6">
                                    <Border CornerRadius="4" Padding="5,2"
                                            Background="{ThemeResource SubtleFillColorTransparentBrush}"
                                            BorderBrush="{ThemeResource SubtleFillColorSecondaryBrush}"
                                            BorderThickness="1">
                                        <TextBlock Text="{x:Bind CpuVendor}" FontSize="10"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </Border>
                                    <TextBlock Text="Laptop-friendly" FontSize="10"
                                               Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Apply button — always at bottom -->
                                <Button Grid.Row="3"
                                        Content="Apply"
                                        Tag="{x:Bind Id}"
                                        Click="ApplyPreset_Click"
                                        Style="{ThemeResource AccentButtonStyle}"
                                        HorizontalAlignment="Stretch"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

            <!-- ═══════════════════════════════════════════════════════════════
                 CPU MANUAL TUNING
            ════════════════════════════════════════════════════════════════ -->
            <TextBlock Text="CPU MANUAL TUNING"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="0,8,0,0"/>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16">
                <StackPanel Spacing="14">

                    <!-- Min Processor State -->
                    <StackPanel Spacing="4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Minimum Processor State"
                                       FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="1"
                                       FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                <Run Text="{x:Bind ViewModel.CurrentCpu.MinProcessorState, Mode=OneWay}"/>
                                <Run Text="%"/>
                            </TextBlock>
                        </Grid>
                        <Slider x:Name="MinStateSlider"
                                Value="{x:Bind ViewModel.CurrentCpu.MinProcessorState, Mode=TwoWay}"
                                Minimum="0" Maximum="100"
                                StepFrequency="5"
                                TickFrequency="25"
                                TickPlacement="Outside"/>
                    </StackPanel>

                    <!-- Max Processor State -->
                    <StackPanel Spacing="4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Maximum Processor State"
                                       FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="1"
                                       FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                <Run Text="{x:Bind ViewModel.CurrentCpu.MaxProcessorState, Mode=OneWay}"/>
                                <Run Text="%"/>
                            </TextBlock>
                        </Grid>
                        <Slider x:Name="MaxStateSlider"
                                Value="{x:Bind ViewModel.CurrentCpu.MaxProcessorState, Mode=TwoWay}"
                                Minimum="20" Maximum="100"
                                StepFrequency="5"
                                TickFrequency="20"
                                TickPlacement="Outside"/>
                    </StackPanel>

                    <!-- Boost Mode -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Processor Performance Boost Mode"
                                   FontWeight="SemiBold"/>
                        <ComboBox x:Name="BoostModeCombo"
                                  HorizontalAlignment="Stretch"
                                  SelectionChanged="BoostModeCombo_SelectionChanged">
                            <ComboBoxItem Content="Disabled"                           Tag="0"/>
                            <ComboBoxItem Content="Enabled"                            Tag="1"/>
                            <ComboBoxItem Content="Aggressive"                         Tag="2"/>
                            <ComboBoxItem Content="Efficient Enabled"                  Tag="3"/>
                            <ComboBoxItem Content="Efficient Aggressive"               Tag="4"/>
                            <ComboBoxItem Content="Aggressive at Guaranteed"           Tag="5"/>
                            <ComboBoxItem Content="Efficient Aggressive at Guaranteed" Tag="6"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Boost Policy -->
                    <StackPanel Spacing="4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Processor Performance Boost Policy"
                                       FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="1"
                                       FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                <Run Text="{x:Bind ViewModel.CurrentCpu.BoostPolicy, Mode=OneWay}"/>
                                <Run Text="%"/>
                            </TextBlock>
                        </Grid>
                        <Slider x:Name="BoostPolicySlider"
                                Value="{x:Bind ViewModel.CurrentCpu.BoostPolicy, Mode=TwoWay}"
                                Minimum="0" Maximum="100"
                                StepFrequency="5"
                                TickFrequency="25"
                                TickPlacement="Outside"/>
                    </StackPanel>

                    <!-- Action buttons -->
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="1"
                                Content="Revert Defaults"
                                Click="Revert_Click"
                                IsEnabled="{x:Bind ViewModel.IsApplying, Mode=OneWay, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"/>
                        <Button Grid.Column="2"
                                Content="Apply CPU Tuning"
                                Click="ApplyCpu_Click"
                                Style="{ThemeResource AccentButtonStyle}"
                                IsEnabled="{x:Bind ViewModel.IsApplying, Mode=OneWay, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"/>
                    </Grid>

                </StackPanel>
            </Border>

            <!-- ═══════════════════════════════════════════════════════════════
                 GPU OVERCLOCKING (EXPERIMENTAL)
            ════════════════════════════════════════════════════════════════ -->
            <TextBlock Text="GPU OVERCLOCKING (EXPERIMENTAL)"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="0,8,0,0"/>

            <!-- Live GPU Telemetry — always shown if LHM available -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE7F4;" FontSize="16" VerticalAlignment="Center"/>
                        <TextBlock Text="{x:Bind ViewModel.GpuName, Mode=OneWay}"
                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock Text="(live telemetry via LibreHardwareMonitor)"
                                   FontSize="10"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2">
                            <TextBlock Text="CORE" FontSize="10"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{x:Bind ViewModel.GpuCoreClock, Mode=OneWay}"
                                       FontSize="16" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="MEMORY" FontSize="10"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{x:Bind ViewModel.GpuMemClock, Mode=OneWay}"
                                       FontSize="16" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="2">
                            <TextBlock Text="TEMP" FontSize="10"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{x:Bind ViewModel.GpuTemp, Mode=OneWay}"
                                       FontSize="16" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="3" Spacing="2">
                            <TextBlock Text="POWER" FontSize="10"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{x:Bind ViewModel.GpuPower, Mode=OneWay}"
                                       FontSize="16" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4" Spacing="2">
                            <TextBlock Text="FAN" FontSize="10"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{x:Bind ViewModel.GpuFan, Mode=OneWay}"
                                       FontSize="16" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="5" Spacing="2">
                            <TextBlock Text="LOAD" FontSize="10"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{x:Bind ViewModel.GpuLoad, Mode=OneWay}"
                                       FontSize="16" FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- OC Write Controls — only shown when a backend can write -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    Visibility="{x:Bind ViewModel.GpuOcWriteAvailable, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                <StackPanel Spacing="12">

                    <!-- Experimental warning -->
                    <InfoBar Severity="Warning"
                             IsOpen="True"
                             IsClosable="False"
                             Title="Experimental — applies real GPU settings"
                             Message="These controls write to hardware registers via NVAPI or ADL. Incorrect values can cause instability, crashes, or hardware damage. Verify stability with a stress test. Use 'Reset to Default' to undo. This feature is UNSUPPORTED — verify on your hardware."/>

                    <!-- Core clock offset -->
                    <StackPanel Spacing="4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Core Clock Offset (MHz)" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="1" FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                <Run Text="{x:Bind ViewModel.GpuCoreOffsetMhz, Mode=OneWay}"/>
                                <Run Text=" MHz"/>
                            </TextBlock>
                        </Grid>
                        <Slider Value="{x:Bind ViewModel.GpuCoreOffsetMhz, Mode=TwoWay}"
                                Minimum="-200" Maximum="300"
                                StepFrequency="5" TickFrequency="100" TickPlacement="Outside"
                                IsEnabled="{x:Bind ViewModel.HasReadDisclaimer, Mode=OneWay}"/>
                    </StackPanel>

                    <!-- Memory clock offset -->
                    <StackPanel Spacing="4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Memory Clock Offset (MHz)" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="1" FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                <Run Text="{x:Bind ViewModel.GpuMemOffsetMhz, Mode=OneWay}"/>
                                <Run Text=" MHz"/>
                            </TextBlock>
                        </Grid>
                        <Slider Value="{x:Bind ViewModel.GpuMemOffsetMhz, Mode=TwoWay}"
                                Minimum="-500" Maximum="1500"
                                StepFrequency="10" TickFrequency="500" TickPlacement="Outside"
                                IsEnabled="{x:Bind ViewModel.HasReadDisclaimer, Mode=OneWay}"/>
                    </StackPanel>

                    <!-- Power limit -->
                    <StackPanel Spacing="4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Power Limit (%)" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="1" FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                <Run Text="{x:Bind ViewModel.GpuPowerLimitPct, Mode=OneWay}"/>
                                <Run Text="%"/>
                            </TextBlock>
                        </Grid>
                        <Slider Value="{x:Bind ViewModel.GpuPowerLimitPct, Mode=TwoWay}"
                                Minimum="50" Maximum="120"
                                StepFrequency="5" TickFrequency="10" TickPlacement="Outside"
                                IsEnabled="{x:Bind ViewModel.HasReadDisclaimer, Mode=OneWay}"/>
                    </StackPanel>

                    <!-- Temp limit -->
                    <StackPanel Spacing="4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Temperature Limit (°C)" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="1" FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                <Run Text="{x:Bind ViewModel.GpuTempLimitC, Mode=OneWay}"/>
                                <Run Text="°C"/>
                            </TextBlock>
                        </Grid>
                        <Slider Value="{x:Bind ViewModel.GpuTempLimitC, Mode=TwoWay}"
                                Minimum="60" Maximum="95"
                                StepFrequency="1" TickFrequency="10" TickPlacement="Outside"
                                IsEnabled="{x:Bind ViewModel.HasReadDisclaimer, Mode=OneWay}"/>
                    </StackPanel>

                    <!-- Watchdog controls -->
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="4">
                            <TextBlock Text="WATCHDOG LIMIT (°C)" FontSize="10"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <NumberBox Value="{x:Bind ViewModel.GpuWatchdogTempC, Mode=TwoWay}"
                                       Minimum="60" Maximum="105" SpinButtonPlacementMode="Inline"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Text="TEST DURATION (s)" FontSize="10"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <NumberBox Value="{x:Bind ViewModel.GpuWatchdogDurationSec, Mode=TwoWay}"
                                       Minimum="10" Maximum="300" SpinButtonPlacementMode="Inline"/>
                        </StackPanel>
                    </Grid>

                    <!-- Action buttons -->
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Content="Apply"
                                Click="ApplyGpuOc_Click"
                                Style="{ThemeResource AccentButtonStyle}"
                                HorizontalAlignment="Stretch"
                                IsEnabled="{x:Bind ViewModel.HasReadDisclaimer, Mode=OneWay}"/>
                        <Button Grid.Column="1"
                                Content="Apply + Watchdog Test"
                                Click="ApplyGpuOcWatchdog_Click"
                                HorizontalAlignment="Stretch"
                                IsEnabled="{x:Bind ViewModel.HasReadDisclaimer, Mode=OneWay}"/>
                        <Button Grid.Column="2"
                                Content="Reset to Default"
                                Click="ResetGpuOc_Click"
                                HorizontalAlignment="Stretch"/>
                        <Button Grid.Column="3"
                                Content="Stop Watchdog"
                                Click="StopGpuWatchdog_Click"
                                Visibility="{x:Bind ViewModel.IsGpuWatchdogRunning, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>
                    </Grid>

                    <!-- Status -->
                    <TextBlock Text="{x:Bind ViewModel.GpuOcStatus, Mode=OneWay}"
                               FontSize="11" TextWrapping="Wrap"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                </StackPanel>
            </Border>

            <!-- Fallback: OC write not available — show reason + vendor tool button -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    Visibility="{x:Bind ViewModel.GpuOcWriteAvailable, Mode=OneWay, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                <StackPanel Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE783;" FontSize="16" VerticalAlignment="Center"
                                  Foreground="{ThemeResource SystemFillColorCautionBrush}"/>
                        <TextBlock Text="In-app GPU OC not available" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="{x:Bind ViewModel.GpuOcUnavailableReason, Mode=OneWay}"
                               FontSize="12" TextWrapping="Wrap"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="Use a vendor GPU tool (MSI Afterburner, NVIDIA App, AMD Adrenalin) for overclocking. Telemetry above is still live when LibreHardwareMonitor is available."
                               FontSize="12" TextWrapping="Wrap"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <Button Content="Open GPU Vendor Tool"
                            Click="OpenGpuVendorTool_Click"
                            Style="{ThemeResource AccentButtonStyle}"/>
                </StackPanel>
            </Border>

            <!-- ═══════════════════════════════════════════════════════════════
                 GPU OVERCLOCKING TOOLS
            ════════════════════════════════════════════════════════════════ -->
            <TextBlock Text="GPU OVERCLOCKING TOOLS"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="0,8,0,0"/>
            <TextBlock Text="Launch installed GPU OC tools or download official vendor software"
                       FontSize="12"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

            <ItemsRepeater ItemsSource="{x:Bind ViewModel.GpuTools, Mode=OneWay}">
                <ItemsRepeater.Layout>
                    <UniformGridLayout MinItemWidth="320" MinItemHeight="80"
                                       MinColumnSpacing="8" MinRowSpacing="8"
                                       ItemsStretch="Fill"/>
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="services:VendorTool">
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="8" Padding="14"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <Border Grid.Column="1" CornerRadius="4" Padding="6,2" VerticalAlignment="Center"
                                                Background="{x:Bind IsInstalled, Converter={StaticResource BoolToInstalledBrush}}">
                                            <TextBlock Text="{x:Bind IsInstalled, Converter={StaticResource BoolToInstalledText}}"
                                                       FontSize="10" FontWeight="Bold" Foreground="White"/>
                                        </Border>
                                    </Grid>
                                    <TextBlock Text="{x:Bind Description}" FontSize="11" TextWrapping="Wrap"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                                <Button Grid.Column="1" VerticalAlignment="Center"
                                        Click="LaunchTool_Click" Tag="{x:Bind Name}">
                                    <TextBlock Text="{x:Bind IsInstalled, Converter={StaticResource BoolToActionText}}"/>
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

            <!-- ── Detected GPU names (read-only WMI info) ─────────────────── -->
            <TextBlock Text="DETECTED GPUs"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="0,8,0,0"/>

            <ItemsRepeater ItemsSource="{x:Bind ViewModel.Gpus}">
                <ItemsRepeater.Layout>
                    <StackLayout Orientation="Vertical" Spacing="4"/>
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="services:GpuClockInfo">
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="12,8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE7F4;" FontSize="16" VerticalAlignment="Center"/>
                                <TextBlock Text="{x:Bind Name}"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

            <!-- ═══════════════════════════════════════════════════════════════
                 MEMORY DIAGNOSTICS
            ════════════════════════════════════════════════════════════════ -->
            <TextBlock Text="MEMORY DIAGNOSTICS"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="0,8,0,0"/>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="14"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Memory Diagnostics" FontWeight="SemiBold"/>
                        <TextBlock Text="Schedule Windows Memory Diagnostic to test RAM on next reboot"
                                   FontSize="11"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="Launch mdsched" Click="MemoryTest_Click"
                            VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- ═══════════════════════════════════════════════════════════════
                 RAM (READ-ONLY)
            ════════════════════════════════════════════════════════════════ -->
            <TextBlock Text="RAM (READ-ONLY)"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="0,8,0,0"/>

            <InfoBar Severity="Informational"
                     IsOpen="True"
                     IsClosable="False"
                     Title="For RAM tuning, use BIOS XMP / DOCP / EXPO"
                     Message="RAM frequency, timings, and voltage can only be configured in BIOS firmware. Enable XMP (Intel) / DOCP (AMD) / EXPO (AMD AM5) profiles in your motherboard BIOS for safe, vendor-validated RAM overclocking."/>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12,10">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE950;" FontSize="16" VerticalAlignment="Center"/>
                    <TextBlock VerticalAlignment="Center">
                        <Run Text="Detected speed:" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <Run Text=" "/>
                        <Run Text="{x:Bind ViewModel.RamInfo.FrequencyMhz, Mode=OneWay}" FontWeight="SemiBold"/>
                        <Run Text=" MHz"/>
                    </TextBlock>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
