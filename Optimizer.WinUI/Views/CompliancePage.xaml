<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Optimizer.WinUI.Views.CompliancePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Optimizer.WinUI.Models"
    xmlns:hud="using:Optimizer.WinUI.Controls.Hud"
    xmlns:converters="using:Optimizer.WinUI.Converters"
    Background="Transparent"
    Loaded="Page_Loaded">

    <Page.Resources>
        <converters:StringToSolidColorBrushConverter x:Key="ColorToBrush"/>
    </Page.Resources>

    <hud:HudBackdrop>
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Page header ──────────────────────────────────────────────── -->
        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <TextBlock Text="{x:Bind ViewModel.CategoryIcon}" FontSize="28" VerticalAlignment="Center"/>
                <TextBlock Text="{x:Bind ViewModel.CategoryName}"
                           Style="{StaticResource TitleTextBlockStyle}" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Text="CIS Benchmark, NIST 800-171, HIPAA, and SOC 2 compliance checks."
                       Foreground="{StaticResource MutedBrush}" FontSize="12"/>
        </StackPanel>

        <!-- ── Toolbar ───────────────────────────────────────────────────── -->
        <Grid Grid.Row="1" ColumnSpacing="8" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ComboBox Grid.Column="0"
                      Header="Framework"
                      SelectedItem="{x:Bind ViewModel.SelectedFramework, Mode=TwoWay}"
                      ItemsSource="{x:Bind ViewModel.Frameworks}"
                      MinWidth="180"/>

            <Button Grid.Column="1" Content="Run Checks"
                    Click="RunChecks_Click"
                    VerticalAlignment="Bottom"/>

            <Button Grid.Column="2" Content="Export HTML Report"
                    Click="ExportReport_Click"
                    VerticalAlignment="Bottom"/>
        </Grid>

        <!-- ── Status / loading ──────────────────────────────────────────── -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                          Width="20" Height="20"
                          Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>
            <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                       Foreground="{StaticResource MutedBrush}"
                       FontSize="12" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- ── Summary badges ────────────────────────────────────────────── -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
            <Border CornerRadius="6" Padding="10,4" Background="#D1FAE5">
                <TextBlock FontWeight="SemiBold" FontSize="12" Foreground="#065F46">
                    <Run Text="{x:Bind ViewModel.PassCount, Mode=OneWay}"/>
                    <Run Text=" Pass"/>
                </TextBlock>
            </Border>
            <Border CornerRadius="6" Padding="10,4" Background="#FEE2E2">
                <TextBlock FontWeight="SemiBold" FontSize="12" Foreground="#991B1B">
                    <Run Text="{x:Bind ViewModel.FailCount, Mode=OneWay}"/>
                    <Run Text=" Fail"/>
                </TextBlock>
            </Border>
            <Border CornerRadius="6" Padding="10,4" Background="{ThemeResource HudSurfaceBrush}">
                <TextBlock FontWeight="SemiBold" FontSize="12">
                    <Run Text="{x:Bind ViewModel.NaCount, Mode=OneWay}"/>
                    <Run Text=" N/A"/>
                </TextBlock>
            </Border>
        </StackPanel>

        <!-- ── Checks list ────────────────────────────────────────────────── -->
        <ListView Grid.Row="4"
                  ItemsSource="{x:Bind ViewModel.Checks, Mode=OneWay}"
                  SelectionMode="None">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0,0,0,4"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:ComplianceCheck">
                    <Border Background="{ThemeResource HudSurfaceAltBrush}"
                            CornerRadius="8" Padding="14,10"
                            BorderBrush="{ThemeResource HudHairlineBrush}"
                            BorderThickness="1">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="200"/>
                            </Grid.ColumnDefinitions>

                            <!-- Control ID -->
                            <TextBlock Grid.Column="0"
                                       Text="{x:Bind ControlId, Mode=OneWay}"
                                       FontFamily="Consolas"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap"/>

                            <!-- Framework badge -->
                            <Border Grid.Column="1"
                                    CornerRadius="4" Padding="6,2"
                                    VerticalAlignment="Center" HorizontalAlignment="Left"
                                    Background="{ThemeResource HudSurfaceBrush}">
                                <TextBlock Text="{x:Bind Framework, Mode=OneWay}" FontSize="11"/>
                            </Border>

                            <!-- Title + description -->
                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind Title, Mode=OneWay}"
                                           FontWeight="SemiBold" FontSize="13"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="{x:Bind Description, Mode=OneWay}"
                                           FontSize="11"
                                           Foreground="{StaticResource MutedBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <!-- Status badge -->
                            <Border Grid.Column="3"
                                    CornerRadius="4" Padding="6,3"
                                    VerticalAlignment="Center" HorizontalAlignment="Left"
                                    Background="{x:Bind StatusColor, Mode=OneWay, Converter={StaticResource ColorToBrush}}">
                                <TextBlock Text="{x:Bind StatusLabel, Mode=OneWay}"
                                           FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                            </Border>

                            <!-- Evidence -->
                            <TextBlock Grid.Column="4"
                                       Text="{x:Bind Evidence, Mode=OneWay}"
                                       FontSize="11"
                                       Foreground="{StaticResource MutedBrush}"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
    </hud:HudBackdrop>
</Page>
