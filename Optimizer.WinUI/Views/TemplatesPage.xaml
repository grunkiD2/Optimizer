<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Optimizer.WinUI.Views.TemplatesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Optimizer.WinUI.Models"
    xmlns:converters="using:Optimizer.WinUI.Converters"
    Background="Transparent"
    Loaded="Page_Loaded">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </Page.Resources>

    <Grid Margin="24,16,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Page header ──────────────────────────────────────────────── -->
        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <TextBlock Text="{x:Bind ViewModel.CategoryIcon}" FontSize="28" VerticalAlignment="Center"/>
                <TextBlock Text="{x:Bind ViewModel.CategoryName}"
                           Style="{StaticResource TitleTextBlockStyle}" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Text="Save current state as DSC, Intune, or WinGet configuration templates."
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
        </StackPanel>

        <!-- ── Toolbar ───────────────────────────────────────────────────── -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
            <Button Content="Create from Current State" Click="CreateTemplate_Click"/>
            <Button Content="Refresh" Click="Refresh_Click"/>
        </StackPanel>

        <!-- ── Status / loading ──────────────────────────────────────────── -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                          Width="20" Height="20"
                          Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>
            <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       FontSize="12" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- ── Templates list ────────────────────────────────────────────── -->
        <ListView Grid.Row="3"
                  ItemsSource="{x:Bind ViewModel.Templates, Mode=OneWay}"
                  SelectionMode="None">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0,0,0,6"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:ConfigTemplate">
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8" Padding="16,12"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Name + description -->
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind Name, Mode=OneWay}"
                                           FontWeight="SemiBold" FontSize="14"
                                           TextWrapping="Wrap"
                                           MaxLines="1" TextTrimming="CharacterEllipsis"
                                           ToolTipService.ToolTip="{x:Bind Name}"/>
                                <TextBlock Text="{x:Bind Description, Mode=OneWay}"
                                           FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           MaxLines="2" TextTrimming="CharacterEllipsis"
                                           ToolTipService.ToolTip="{x:Bind Description}"/>
                                <TextBlock FontSize="11"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}">
                                    <Run Text="Created: "/>
                                    <Run Text="{x:Bind CreatedAt, Mode=OneWay}"/>
                                    <Run Text=" · "/>
                                    <Run Text="{x:Bind RegistryChanges.Count, Mode=OneWay}"/>
                                    <Run Text=" registry entries"/>
                                </TextBlock>
                            </StackPanel>

                            <!-- Export DSC -->
                            <Button Grid.Column="1"
                                    Content="Export DSC"
                                    Tag="{x:Bind}"
                                    Click="ExportDsc_Click"
                                    VerticalAlignment="Center"/>

                            <!-- Export Intune -->
                            <Button Grid.Column="2"
                                    Content="Export Intune"
                                    Tag="{x:Bind}"
                                    Click="ExportIntune_Click"
                                    VerticalAlignment="Center"/>

                            <!-- Export WinGet -->
                            <Button Grid.Column="3"
                                    Content="Export WinGet"
                                    Tag="{x:Bind}"
                                    Click="ExportWinget_Click"
                                    VerticalAlignment="Center"/>

                            <!-- Delete -->
                            <Button Grid.Column="4"
                                    Content="Delete"
                                    Tag="{x:Bind Id}"
                                    Click="Delete_Click"
                                    VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <!-- ── Empty state ─────────────────────────────────────────────── -->
        <Border Grid.Row="4" CornerRadius="8" Padding="32"
                Margin="0,8,0,0"
                Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                Background="{ThemeResource LayerFillColorDefaultBrush}">
            <StackPanel HorizontalAlignment="Center" Spacing="12">
                <TextBlock Text="&#x1F4CB;" FontSize="48" HorizontalAlignment="Center" Opacity="0.6"/>
                <TextBlock Text="No templates yet"
                           FontSize="16" FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Click Create from Current State to save your settings as a DSC, Intune, or WinGet template."
                           FontSize="12" HorizontalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap" MaxWidth="320" TextAlignment="Center"/>
            </StackPanel>
        </Border>

    </Grid>
</Page>
