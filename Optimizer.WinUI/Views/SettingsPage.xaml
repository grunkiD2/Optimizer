<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Optimizer.WinUI.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:settingsControls="using:CommunityToolkit.WinUI.Controls"
    xmlns:converters="using:Optimizer.WinUI.Converters"
    Background="Transparent"
    Loaded="Page_Loaded">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="20" Padding="24,16,24,24">

            <!-- ── Page header ──────────────────────────────────────────────── -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <TextBlock Text="{x:Bind ViewModel.CategoryIcon}"
                               FontSize="28" VerticalAlignment="Center"/>
                    <StackPanel Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="{x:Bind ViewModel.CategoryName}"
                                   Style="{StaticResource TitleTextBlockStyle}"/>
                        <TextBlock Text="Application preferences and behaviour"
                                   FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Reset Defaults"
                        VerticalAlignment="Center"
                        Click="ResetSettings_Click"/>
            </Grid>

            <!-- ── APPEARANCE ─────────────────────────────────────────────── -->
            <TextBlock Text="APPEARANCE"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="0,8,0,0"/>

            <settingsControls:SettingsCard Header="Theme"
                                           Description="Choose light, dark, or follow the system setting">
                <ComboBox ItemsSource="{x:Bind ViewModel.ThemeOptions}"
                          SelectedItem="{x:Bind ViewModel.SelectedTheme, Mode=TwoWay}"
                          MinWidth="140"
                          VerticalAlignment="Center"/>
            </settingsControls:SettingsCard>

            <settingsControls:SettingsCard Header="Window Backdrop"
                                           Description="Background material applied to the main window">
                <ComboBox ItemsSource="{x:Bind ViewModel.BackdropOptions}"
                          SelectedItem="{x:Bind ViewModel.SelectedBackdrop, Mode=TwoWay}"
                          MinWidth="140"
                          VerticalAlignment="Center"/>
            </settingsControls:SettingsCard>

            <settingsControls:SettingsCard x:Uid="Settings_Language"
                                           Header="Language"
                                           Description="Application display language (restart required)">
                <ComboBox ItemsSource="{x:Bind ViewModel.LanguageOptions}"
                          SelectedItem="{x:Bind ViewModel.SelectedLanguage, Mode=TwoWay}"
                          MinWidth="140"
                          VerticalAlignment="Center"/>
            </settingsControls:SettingsCard>

            <settingsControls:SettingsCard Header="Accent Color"
                                           Description="Hex value used for highlights and charts">
                <ColorPicker x:Name="AccentColorPicker"
                             ColorSpectrumShape="Box"
                             IsAlphaEnabled="False"
                             IsHexInputVisible="True"
                             IsColorSliderVisible="True"
                             IsColorChannelTextInputVisible="False"
                             MaxWidth="280"
                             ColorChanged="AccentColorPicker_ColorChanged"/>
            </settingsControls:SettingsCard>

            <!-- ── MONITORING ─────────────────────────────────────────────── -->
            <TextBlock Text="MONITORING"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="0,8,0,0"/>

            <settingsControls:SettingsCard Header="Metrics Refresh Interval"
                                           Description="How often live metrics are polled (seconds)">
                <NumberBox Value="{x:Bind ViewModel.MetricsRefreshSeconds, Mode=TwoWay}"
                           Minimum="1" Maximum="60" SpinButtonPlacementMode="Inline"
                           SmallChange="1" LargeChange="5"
                           MinWidth="130"
                           VerticalAlignment="Center"/>
            </settingsControls:SettingsCard>

            <settingsControls:SettingsCard Header="Chart History Duration"
                                           Description="Number of seconds of data kept in trend charts">
                <NumberBox Value="{x:Bind ViewModel.ChartHistorySeconds, Mode=TwoWay}"
                           Minimum="10" Maximum="600" SpinButtonPlacementMode="Inline"
                           SmallChange="10" LargeChange="30"
                           MinWidth="130"
                           VerticalAlignment="Center"/>
            </settingsControls:SettingsCard>

            <!-- ── NOTIFICATIONS ──────────────────────────────────────────── -->
            <TextBlock Text="NOTIFICATIONS"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="0,8,0,0"/>

            <settingsControls:SettingsCard Header="Performance Alerts"
                                           Description="High CPU usage sustained for over 2 minutes">
                <ToggleSwitch IsOn="{x:Bind ViewModel.NotifyPerformance, Mode=TwoWay}"
                              OnContent="" OffContent=""
                              VerticalAlignment="Center"/>
            </settingsControls:SettingsCard>

            <settingsControls:SettingsCard Header="Storage Warnings"
                                           Description="Drive space above 95% full">
                <ToggleSwitch IsOn="{x:Bind ViewModel.NotifyStorage, Mode=TwoWay}"
                              OnContent="" OffContent=""
                              VerticalAlignment="Center"/>
            </settingsControls:SettingsCard>

            <settingsControls:SettingsCard Header="Hardware Warnings"
                                           Description="SMART drive failure prediction and CPU thermal alerts (>90°C)">
                <ToggleSwitch IsOn="{x:Bind ViewModel.NotifyHardware, Mode=TwoWay}"
                              OnContent="" OffContent=""
                              VerticalAlignment="Center"/>
            </settingsControls:SettingsCard>

            <settingsControls:SettingsCard Header="Security Alerts"
                                           Description="Security scan results and threat detections">
                <ToggleSwitch IsOn="{x:Bind ViewModel.NotifySecurity, Mode=TwoWay}"
                              OnContent="" OffContent=""
                              VerticalAlignment="Center"/>
            </settingsControls:SettingsCard>

            <settingsControls:SettingsCard Header="New Recommendations"
                                           Description="Notify when new optimization recommendations are available">
                <ToggleSwitch IsOn="{x:Bind ViewModel.NotifyRecommendations, Mode=TwoWay}"
                              OnContent="" OffContent=""
                              VerticalAlignment="Center"/>
            </settingsControls:SettingsCard>

            <settingsControls:SettingsCard Header="Optimization Applied"
                                           Description="Confirm when an optimization has been successfully applied">
                <ToggleSwitch IsOn="{x:Bind ViewModel.NotifyOptimizations, Mode=TwoWay}"
                              OnContent="" OffContent=""
                              VerticalAlignment="Center"/>
            </settingsControls:SettingsCard>

            <!-- ── DATA ───────────────────────────────────────────────────── -->
            <TextBlock Text="DATA"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="0,8,0,0"/>

            <settingsControls:SettingsCard Header="Start With Windows"
                                           Description="Launch Optimizer automatically when you sign in">
                <ToggleSwitch IsOn="{x:Bind ViewModel.StartWithWindows, Mode=TwoWay}"
                              OnContent="" OffContent=""
                              VerticalAlignment="Center"/>
            </settingsControls:SettingsCard>

            <settingsControls:SettingsCard Header="Confirm Before Apply"
                                           Description="Show a confirmation dialog before applying optimizations">
                <ToggleSwitch IsOn="{x:Bind ViewModel.ConfirmBeforeApply, Mode=TwoWay}"
                              OnContent="" OffContent=""
                              VerticalAlignment="Center"/>
            </settingsControls:SettingsCard>

            <settingsControls:SettingsCard Header="Minimize to System Tray"
                                           Description="Closing the window minimizes to tray instead of exiting">
                <ToggleSwitch IsOn="{x:Bind ViewModel.MinimizeToTray, Mode=TwoWay}"
                              OnContent="" OffContent=""
                              VerticalAlignment="Center"/>
            </settingsControls:SettingsCard>

            <settingsControls:SettingsCard Header="Start Minimized"
                                           Description="Launch Optimizer minimized to the system tray">
                <ToggleSwitch IsOn="{x:Bind ViewModel.StartMinimized, Mode=TwoWay}"
                              OnContent="" OffContent=""
                              VerticalAlignment="Center"/>
            </settingsControls:SettingsCard>

            <settingsControls:SettingsCard Header="Clear Change History"
                                           Description="Permanently remove all recorded optimization events">
                <Button Content="Clear History"
                        Click="ClearHistory_Click"
                        VerticalAlignment="Center"/>
            </settingsControls:SettingsCard>

            <!-- ── CLOUD SYNC ─────────────────────────────────────────────── -->
            <TextBlock Text="CLOUD SYNC"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="0,8,0,0"/>

            <!-- Server URL (always shown) -->
            <settingsControls:SettingsCard Header="Server URL"
                                           Description="URL of your Optimizer.Server instance">
                <TextBox Text="{x:Bind ViewModel.CloudServerUrl, Mode=TwoWay}"
                         MinWidth="280" PlaceholderText="http://localhost:5000"
                         VerticalAlignment="Center"/>
            </settingsControls:SettingsCard>

            <!-- Sign-in panel (shown when NOT authenticated) -->
            <settingsControls:SettingsCard Header="Sign In"
                                           Description="Enter your email to receive a magic link"
                                           Visibility="{x:Bind ViewModel.CloudIsAuthenticated, Mode=OneWay, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                <StackPanel Orientation="Vertical" Spacing="8" MinWidth="280">
                    <TextBox x:Name="CloudEmailBox"
                             Text="{x:Bind ViewModel.CloudEmail, Mode=TwoWay}"
                             PlaceholderText="you@example.com"
                             InputScope="EmailSmtpAddress"/>
                    <Button Content="Send Magic Link"
                            Click="SendMagicLink_Click"
                            HorizontalAlignment="Stretch"/>
                </StackPanel>
            </settingsControls:SettingsCard>

            <!-- Token verify panel (shown after link sent, before verified) -->
            <settingsControls:SettingsCard Header="Paste Verification Token"
                                           Description="Paste the ?token= value from the magic link URL"
                                           Visibility="{x:Bind ViewModel.CloudMagicLinkSent, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                <StackPanel Orientation="Vertical" Spacing="8" MinWidth="280">
                    <TextBox Text="{x:Bind ViewModel.CloudVerifyToken, Mode=TwoWay}"
                             PlaceholderText="Paste token here"/>
                    <Button Content="Verify"
                            Click="VerifyCloudToken_Click"
                            HorizontalAlignment="Stretch"/>
                </StackPanel>
            </settingsControls:SettingsCard>

            <!-- Signed-in panel -->
            <settingsControls:SettingsCard Header="Cloud Sync Enabled"
                                           Description="{x:Bind ViewModel.CloudSyncStatus, Mode=OneWay}"
                                           Visibility="{x:Bind ViewModel.CloudIsAuthenticated, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                <ToggleSwitch IsOn="{x:Bind ViewModel.CloudSyncEnabled, Mode=TwoWay}"
                              OnContent="" OffContent=""
                              VerticalAlignment="Center"/>
            </settingsControls:SettingsCard>

            <settingsControls:SettingsCard Header="Last Sync"
                                           Description="{x:Bind ViewModel.CloudLastSync, Mode=OneWay}"
                                           Visibility="{x:Bind ViewModel.CloudIsAuthenticated, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Sync Now"
                            Click="SyncNow_Click"
                            VerticalAlignment="Center"/>
                    <Button Content="Sign Out"
                            Click="CloudSignOut_Click"
                            VerticalAlignment="Center"/>
                </StackPanel>
            </settingsControls:SettingsCard>

            <!-- ── PRIVACY-PRESERVING COMMUNITY INSIGHTS ─────────────────── -->
            <TextBlock Text="PRIVACY &amp; AI"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="0,8,0,0"/>

            <settingsControls:SettingsCard
                    Header="Privacy-Preserving Community Insights"
                    Description="When enabled, your device shares differentially-private, anonymized statistics — never raw data or system info — to help improve recommendation defaults for everyone. Contributions are protected by the Laplace differential-privacy mechanism before leaving your device. You can turn this off anytime. Default: Off.">
                <ToggleSwitch IsOn="{x:Bind ViewModel.FederatedLearningEnabled, Mode=TwoWay}"
                              OnContent="" OffContent=""
                              VerticalAlignment="Center"/>
            </settingsControls:SettingsCard>

            <!-- ── REMOTE API ──────────────────────────────────────────────── -->
            <TextBlock Text="REMOTE API"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="0,8,0,0"/>

            <settingsControls:SettingsCard Header="Enable REST API"
                                           Description="Allows remote control via HTTP on localhost. Disabled by default for security.">
                <ToggleSwitch IsOn="{x:Bind ViewModel.ApiEnabled, Mode=TwoWay}"
                              OnContent="" OffContent=""
                              VerticalAlignment="Center"/>
            </settingsControls:SettingsCard>

            <settingsControls:SettingsCard Header="API Port"
                                           Description="Port Kestrel listens on. Default 8765. Restart the API to apply changes.">
                <NumberBox Value="{x:Bind ViewModel.ApiPort, Mode=TwoWay}"
                           Minimum="1024" Maximum="65535"
                           SpinButtonPlacementMode="Inline"
                           SmallChange="1" LargeChange="100"
                           MinWidth="130"
                           VerticalAlignment="Center"/>
            </settingsControls:SettingsCard>

            <settingsControls:SettingsCard Header="Status"
                                           Description="{x:Bind ViewModel.ApiStatus, Mode=OneWay}"/>

            <settingsControls:SettingsCard Header="Bearer Token"
                                           Description="Open the web dashboard at http://localhost:8765/ and paste this token.">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Copy Token"
                            Click="CopyToken_Click"
                            VerticalAlignment="Center"/>
                    <Button Content="Regenerate"
                            Click="RegenerateToken_Click"
                            VerticalAlignment="Center"/>
                </StackPanel>
            </settingsControls:SettingsCard>

            <!-- ── AI ASSISTANT ─────────────────────────────────────────────── -->
            <TextBlock Text="AI ASSISTANT"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="0,8,0,0"/>

            <settingsControls:SettingsCard Header="Enable AI Assistant"
                                           Description="Chat with Claude to control and inspect your PC (opt-in; uses your Anthropic API key).">
                <ToggleSwitch IsOn="{x:Bind ViewModel.AssistantEnabled, Mode=TwoWay}"
                              OnContent="" OffContent="" VerticalAlignment="Center"/>
            </settingsControls:SettingsCard>

            <settingsControls:SettingsCard Header="Allow the assistant to perform actions"
                                           Description="When off, the assistant can only answer questions and navigate — it cannot change the system.">
                <ToggleSwitch IsOn="{x:Bind ViewModel.AssistantAllowActions, Mode=TwoWay}"
                              OnContent="" OffContent="" VerticalAlignment="Center"/>
            </settingsControls:SettingsCard>

            <settingsControls:SettingsCard Header="Model" Description="Claude model used for the assistant.">
                <ComboBox ItemsSource="{x:Bind ViewModel.AssistantModelOptions}"
                          SelectedItem="{x:Bind ViewModel.AssistantModel, Mode=TwoWay}"
                          MinWidth="220" VerticalAlignment="Center"/>
            </settingsControls:SettingsCard>

            <settingsControls:SettingsCard Header="Anthropic API key"
                                           Description="Stored encrypted on this PC (Windows DPAPI). Your messages and a short system-metrics summary are sent to Anthropic.">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <PasswordBox x:Name="ApiKeyBox" PlaceholderText="sk-ant-…" MinWidth="240"
                                 PasswordChanged="ApiKeyBox_PasswordChanged"/>
                    <Button Content="Save" Click="SaveApiKey_Click"/>
                    <Button Content="Clear" Click="ClearApiKey_Click"/>
                    <FontIcon Glyph="&#xE73E;" Foreground="#22C55E"
                              Visibility="{x:Bind ViewModel.HasApiKey, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>
                </StackPanel>
            </settingsControls:SettingsCard>

            <settingsControls:SettingsCard Header="Set up billing &amp; get a key"
                                           Description="Opens the Anthropic Console billing page to add a payment method or credits. Once billing is active, create a key on the API Keys tab and paste it above. Usage is billed by Anthropic directly to your own account — Optimizer never sees your payment details.">
                <Button Click="GetApiKey_Click" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE8A7;" FontSize="14"/>
                        <TextBlock Text="Set up billing"/>
                    </StackPanel>
                </Button>
            </settingsControls:SettingsCard>

        </StackPanel>
    </ScrollViewer>
</Page>
