<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Optimizer.WinUI.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:settingsControls="using:CommunityToolkit.WinUI.Controls"
    Background="Transparent"
    Loaded="Page_Loaded">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="20" Padding="24,16,24,24">

            <!-- ── Page header ──────────────────────────────────────────────── -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <TextBlock Text="{x:Bind ViewModel.CategoryIcon}"
                               FontSize="28" VerticalAlignment="Center"/>
                    <StackPanel Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="{x:Bind ViewModel.CategoryName}"
                                   Style="{StaticResource TitleTextBlockStyle}"/>
                        <TextBlock Text="Application preferences and behaviour"
                                   FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Reset Defaults"
                        VerticalAlignment="Center"
                        Click="ResetSettings_Click"/>
            </Grid>

            <!-- ── APPEARANCE ─────────────────────────────────────────────── -->
            <TextBlock Text="APPEARANCE"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="0,8,0,0"/>

            <settingsControls:SettingsCard Header="Theme"
                                           Description="Choose light, dark, or follow the system setting">
                <ComboBox ItemsSource="{x:Bind ViewModel.ThemeOptions}"
                          SelectedItem="{x:Bind ViewModel.SelectedTheme, Mode=TwoWay}"
                          MinWidth="140"
                          VerticalAlignment="Center"/>
            </settingsControls:SettingsCard>

            <settingsControls:SettingsCard Header="Window Backdrop"
                                           Description="Background material applied to the main window">
                <ComboBox ItemsSource="{x:Bind ViewModel.BackdropOptions}"
                          SelectedItem="{x:Bind ViewModel.SelectedBackdrop, Mode=TwoWay}"
                          MinWidth="140"
                          VerticalAlignment="Center"/>
            </settingsControls:SettingsCard>

            <settingsControls:SettingsCard Header="Accent Color"
                                           Description="Hex value used for highlights and charts">
                <ColorPicker x:Name="AccentColorPicker"
                             ColorSpectrumShape="Box"
                             IsAlphaEnabled="False"
                             IsHexInputVisible="True"
                             IsColorSliderVisible="True"
                             IsColorChannelTextInputVisible="False"
                             MaxWidth="280"
                             ColorChanged="AccentColorPicker_ColorChanged"/>
            </settingsControls:SettingsCard>

            <!-- ── MONITORING ─────────────────────────────────────────────── -->
            <TextBlock Text="MONITORING"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="0,8,0,0"/>

            <settingsControls:SettingsCard Header="Metrics Refresh Interval"
                                           Description="How often live metrics are polled (seconds)">
                <NumberBox Value="{x:Bind ViewModel.MetricsRefreshSeconds, Mode=TwoWay}"
                           Minimum="1" Maximum="60" SpinButtonPlacementMode="Inline"
                           SmallChange="1" LargeChange="5"
                           MinWidth="130"
                           VerticalAlignment="Center"/>
            </settingsControls:SettingsCard>

            <settingsControls:SettingsCard Header="Chart History Duration"
                                           Description="Number of seconds of data kept in trend charts">
                <NumberBox Value="{x:Bind ViewModel.ChartHistorySeconds, Mode=TwoWay}"
                           Minimum="10" Maximum="600" SpinButtonPlacementMode="Inline"
                           SmallChange="10" LargeChange="30"
                           MinWidth="130"
                           VerticalAlignment="Center"/>
            </settingsControls:SettingsCard>

            <!-- ── DATA ───────────────────────────────────────────────────── -->
            <TextBlock Text="DATA"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="0,8,0,0"/>

            <settingsControls:SettingsCard Header="Start With Windows"
                                           Description="Launch Optimizer automatically when you sign in">
                <ToggleSwitch IsOn="{x:Bind ViewModel.StartWithWindows, Mode=TwoWay}"
                              OnContent="" OffContent=""
                              VerticalAlignment="Center"/>
            </settingsControls:SettingsCard>

            <settingsControls:SettingsCard Header="Confirm Before Apply"
                                           Description="Show a confirmation dialog before applying optimizations">
                <ToggleSwitch IsOn="{x:Bind ViewModel.ConfirmBeforeApply, Mode=TwoWay}"
                              OnContent="" OffContent=""
                              VerticalAlignment="Center"/>
            </settingsControls:SettingsCard>

            <settingsControls:SettingsCard Header="Clear Change History"
                                           Description="Permanently remove all recorded optimization events">
                <Button Content="Clear History"
                        Click="ClearHistory_Click"
                        VerticalAlignment="Center"/>
            </settingsControls:SettingsCard>

        </StackPanel>
    </ScrollViewer>
</Page>
