<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Optimizer.WinUI.Views.PerformancePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:tk="using:CommunityToolkit.WinUI.Controls"
    xmlns:controls="using:Optimizer.WinUI.Controls"
    xmlns:converters="using:Optimizer.WinUI.Converters"
    xmlns:hud="using:Optimizer.WinUI.Controls.Hud"
    xmlns:vm="using:Optimizer.WinUI.ViewModels"
    xmlns:services="using:Optimizer.WinUI.Services"
    xmlns:models="using:Optimizer.WinUI.Models"
    Background="Transparent"
    Loaded="Page_Loaded">

    <Page.Resources>
        <converters:BoolToInstalledBrushConverter    x:Key="BoolToInstalledBrush"/>
        <converters:BoolToInstalledTextConverter     x:Key="BoolToInstalledText"/>
        <converters:BoolToActionTextConverter        x:Key="BoolToActionText"/>
        <converters:BoolToInfoBarSeverityConverter   x:Key="BoolToInfoBarSeverity"/>
    </Page.Resources>

    <hud:HudBackdrop>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32,24,32,32">
            <StackPanel Spacing="24" MaxWidth="1360" HorizontalAlignment="Left">
                <StackPanel.ChildrenTransitions>
                    <TransitionCollection>
                        <EntranceThemeTransition FromVerticalOffset="20"/>
                    </TransitionCollection>
                </StackPanel.ChildrenTransitions>

                <!-- ── Page header ──────────────────────────────────────────── -->
                <hud:HudPageHeader Icon="{x:Bind ViewModel.CategoryIcon}"
                                   Title="CPU &amp; Power"
                                   Description="Power plans, optimizations, per-process priority, CPU/GPU tuning, and stress testing — one place.">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Apply All" Style="{StaticResource AccentButtonStyle}"
                                Command="{x:Bind ViewModel.ApplyAllCommand}"/>
                        <Button Content="Undo Category" Command="{x:Bind ViewModel.UndoCategoryCommand}"/>
                    </StackPanel>
                </hud:HudPageHeader>

                <!-- Audit Batch 2: apply/undo results are no longer silent. -->
                <InfoBar IsOpen="{x:Bind ViewModel.HasStatus, Mode=OneWay}"
                         Message="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                         Severity="{x:Bind ViewModel.StatusIsError, Mode=OneWay, Converter={StaticResource BoolToInfoBarSeverity}}"
                         IsClosable="True"/>

                <!-- ── Shared vitals (live sparklines) ──────────────────────── -->
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <hud:StatTile x:Name="CpuTile" Grid.Column="0" Label="CPU" Unit="%" Value="--" Status="Info"/>
                    <hud:StatTile x:Name="MemTile" Grid.Column="1" Label="MEMORY" Unit="%" Value="--" Status="Success"/>
                    <hud:StatTile x:Name="OptTile" Grid.Column="2" Label="OPTIMIZATIONS ACTIVE" Value="--" Status="Accent"/>
                </Grid>

                <!-- ── Sub-section switcher: Optimizations & Power | Advanced Tuning ── -->
                <tk:Segmented x:Name="SectionSeg" SelectedIndex="0"
                              SelectionChanged="Section_Changed"
                              HorizontalAlignment="Left">
                    <tk:SegmentedItem Content="Optimizations &amp; Power"/>
                    <tk:SegmentedItem Content="Advanced Tuning"/>
                </tk:Segmented>

                <!-- ═════════════════════════════════════════════════════════════
                     PANEL A — Optimizations &amp; Power (default)
                ═════════════════════════════════════════════════════════════ -->
                <Grid x:Name="PanelOptimizations" ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: optimizations -->
                    <StackPanel Grid.Column="0" Spacing="12">
                        <StackPanel Spacing="2">
                            <TextBlock Text="OPTIMIZATIONS" Style="{StaticResource HudMicroStyle}"/>
                            <TextBlock Text="Toggle individual tweaks. Each card shows exactly what it changes and the trade-offs."
                                       Style="{StaticResource HudCaptionStyle}"/>
                        </StackPanel>
                        <ItemsRepeater x:Name="OptimizationsRepeater"
                                       ItemsSource="{x:Bind ViewModel.Optimizations, Mode=OneWay}">
                            <ItemsRepeater.Layout>
                                <StackLayout Orientation="Vertical" Spacing="0"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="vm:OptimizationCardModel">
                                    <controls:OptimizationCard Tag="{x:Bind Id}" Loaded="OptimizationCard_Loaded"/>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </StackPanel>

                    <!-- Right: power + processes -->
                    <StackPanel Grid.Column="1" Spacing="24">
                        <hud:HudCard Header="POWER" Description="Choose a Windows power plan and toggle Game Mode.">
                            <StackPanel Spacing="12">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Active plan" Style="{StaticResource HudCaptionStyle}"/>
                                        <TextBlock Text="{x:Bind ViewModel.ActivePowerPlan.Name, Mode=OneWay, FallbackValue=Loading...}"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <ToggleSwitch Grid.Column="1" Header="Game Mode"
                                                  IsOn="{x:Bind ViewModel.GameModeEnabled, Mode=TwoWay}"/>
                                </Grid>

                                <ItemsRepeater ItemsSource="{x:Bind ViewModel.PowerPlans, Mode=OneWay}">
                                    <ItemsRepeater.Layout>
                                        <UniformGridLayout MinItemWidth="150" MinColumnSpacing="8" MinRowSpacing="8"/>
                                    </ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate x:DataType="services:PowerPlan">
                                            <Button Click="PowerPlan_Click" Tag="{x:Bind Guid}"
                                                    HorizontalAlignment="Stretch" Padding="12,8">
                                                <StackPanel>
                                                    <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="ACTIVE" FontSize="10" FontWeight="SemiBold"
                                                               Foreground="{StaticResource AccentCyanBrush}"
                                                               Visibility="{x:Bind IsActive, Converter={StaticResource BoolToVisibility}}"/>
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>

                                <Button Content="Enable Ultimate Performance" HorizontalAlignment="Stretch"
                                        Click="UltimatePerf_Click"/>
                            </StackPanel>
                        </hud:HudCard>

                        <hud:HudCard Header="RUNNING PROCESSES" Description="Set priority or per-core CPU affinity for any process.">
                            <ListView x:Name="ProcessListView"
                                      ItemsSource="{x:Bind ViewModel.Processes, Mode=OneWay}"
                                      SelectionMode="None" MaxHeight="420">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="models:ProcessPriorityInfo">
                                        <Border Padding="6,8" BorderBrush="{ThemeResource HudHairlineBrush}" BorderThickness="0,0,0,1">
                                            <Border.ContextFlyout>
                                                <MenuFlyout>
                                                    <MenuFlyoutItem Text="Åbn filplacering" Click="ProcOpenLocation_Click"/>
                                                    <MenuFlyoutItem Text="Afslut proces" Click="ProcEndTask_Click"/>
                                                </MenuFlyout>
                                            </Border.ContextFlyout>
                                            <Grid ColumnSpacing="10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Style="{StaticResource HudMonoSmallStyle}" Foreground="{StaticResource MutedBrush}">
                                                        <Run Text="PID"/>
                                                        <Run Text="{x:Bind PidText}"/>
                                                        <Run Text="·"/>
                                                        <Run Text="{x:Bind MemoryText}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                                <ComboBox Grid.Column="1" Tag="{x:Bind Pid}"
                                                          SelectionChanged="Priority_Changed"
                                                          SelectedItem="{x:Bind Priority, Mode=OneWay}" MinWidth="116">
                                                    <ComboBoxItem Content="High"/>
                                                    <ComboBoxItem Content="AboveNormal"/>
                                                    <ComboBoxItem Content="Normal"/>
                                                    <ComboBoxItem Content="BelowNormal"/>
                                                    <ComboBoxItem Content="Idle"/>
                                                </ComboBox>
                                                <Button Grid.Column="2" Tag="{x:Bind Pid}" Content="Affinity"
                                                        VerticalAlignment="Center" Click="Affinity_Click"
                                                        ToolTipService.ToolTip="Set per-core CPU affinity"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </hud:HudCard>
                    </StackPanel>
                </Grid>

                <!-- ═════════════════════════════════════════════════════════════
                     PANEL B — Advanced Tuning (was the standalone TuningPage)
                ═════════════════════════════════════════════════════════════ -->
                <StackPanel x:Name="PanelTuning" Visibility="Collapsed" Spacing="16">

                    <!-- Loading indicator -->
                    <ProgressBar IsIndeterminate="True"
                                 Visibility="{x:Bind TuningVM.IsApplying, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>

                    <!-- Status message -->
                    <InfoBar x:Name="TuningStatusInfoBar"
                             Severity="Informational"
                             IsClosable="True"
                             IsOpen="{x:Bind TuningVM.HasStatusMessage, Mode=OneWay}"
                             Title="{x:Bind TuningVM.StatusMessage, Mode=OneWay}"/>

                    <!-- Disclaimer banner -->
                    <InfoBar Severity="Warning"
                             IsOpen="True"
                             IsClosable="False"
                             Title="Warranty and stability notice">
                        <InfoBar.Content>
                            <StackPanel Spacing="8" Margin="0,4,0,8">
                                <TextBlock TextWrapping="Wrap" FontSize="12">
                                    CPU tuning changes Windows power management settings that affect processor frequency,
                                    boost behavior, and heat output. Aggressive presets may increase power consumption,
                                    reduce CPU lifespan on sustained loads, and trigger thermal throttling on
                                    cooling-limited systems. Use the Stock preset to revert at any time.
                                    Administrator privileges are required to apply changes.
                                </TextBlock>
                                <CheckBox Content="I understand the risks and want to proceed"
                                          IsChecked="{x:Bind TuningVM.HasReadDisclaimer, Mode=TwoWay}"/>
                            </StackPanel>
                        </InfoBar.Content>
                    </InfoBar>

                    <!-- POWER BUDGET (READ-ONLY) -->
                    <TextBlock Text="POWER BUDGET (READ-ONLY)" Style="{StaticResource HudMicroStyle}" Margin="0,8,0,0"/>
                    <hud:HudCard>
                        <Grid ColumnSpacing="24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="2">
                                <TextBlock Text="PL1 (Sustained TDP)" Style="{StaticResource HudCaptionStyle}"/>
                                <TextBlock Text="{x:Bind TuningVM.Pl1Display, Mode=OneWay}" FontSize="18" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock Text="PL2 (Burst TDP)" Style="{StaticResource HudCaptionStyle}"/>
                                <TextBlock Text="{x:Bind TuningVM.Pl2Display, Mode=OneWay}" FontSize="18" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="2" VerticalAlignment="Center">
                                <TextBlock Text="PL1/PL2 values require RAPL kernel access (N/A via standard WMI)."
                                           Style="{StaticResource HudCaptionStyle}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </hud:HudCard>

                    <!-- Undervolting guidance -->
                    <hud:HudCard>
                        <StackPanel Spacing="8">
                            <TextBlock Text="Undervolting and Power-Limit (PL1/PL2) changes"
                                       FontWeight="SemiBold" FontSize="13"/>
                            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource MutedBrush}">
                                CPU undervolting and direct PL1/PL2 power-limit writes require a signed ring-0
                                kernel driver (e.g. WinRing0) which Optimizer does not bundle for security and
                                code-signing reasons. To undervolt or change power limits, use your system BIOS
                                or a vendor tool such as Intel XTU (Intel CPUs) or AMD Ryzen Master (AMD CPUs).
                                The values shown above are read-only display.
                            </TextBlock>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="Launch Intel XTU" Click="LaunchXtu_Click"
                                        Visibility="{x:Bind TuningVM.HasIntelXtu, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>
                                <Button Content="Launch Ryzen Master" Click="LaunchRyzenMaster_Click"
                                        Visibility="{x:Bind TuningVM.HasRyzenMaster, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>
                            </StackPanel>
                        </StackPanel>
                    </hud:HudCard>

                    <!-- STRESS TEST -->
                    <TextBlock Text="STRESS TEST" Style="{StaticResource HudMicroStyle}" Margin="0,8,0,0"/>
                    <hud:HudCard>
                        <StackPanel Spacing="12">

                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="DURATION (s)" Style="{StaticResource HudCaptionStyle}"/>
                                    <NumberBox Value="{x:Bind TuningVM.StressDurationSeconds, Mode=TwoWay}"
                                               Minimum="10" Maximum="600" SpinButtonPlacementMode="Inline"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="WATCHDOG (°C)" Style="{StaticResource HudCaptionStyle}"/>
                                    <NumberBox Value="{x:Bind TuningVM.WatchdogTempLimit, Mode=TwoWay}"
                                               Minimum="60" Maximum="105" SpinButtonPlacementMode="Inline"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" VerticalAlignment="Bottom" Spacing="4">
                                    <Button x:Name="RunBuiltInBtn"
                                            Content="Run Built-in Test" Click="RunBuiltIn_Click"
                                            Style="{ThemeResource AccentButtonStyle}"
                                            HorizontalAlignment="Stretch"
                                            IsEnabled="{x:Bind TuningVM.HasReadDisclaimer, Mode=OneWay}"/>
                                </StackPanel>
                            </Grid>

                            <Grid ColumnSpacing="8"
                                  Visibility="{x:Bind TuningVM.IsStressTesting, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ProgressBar Maximum="{x:Bind TuningVM.StressDurationSeconds, Mode=OneWay}"
                                             Value="{x:Bind TuningVM.StressElapsedSec, Mode=OneWay}"
                                             VerticalAlignment="Center"/>
                                <Button Grid.Column="1" Content="Stop" Click="StopStress_Click"/>
                            </Grid>

                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="CURRENT TEMP" Style="{StaticResource HudCaptionStyle}"/>
                                    <TextBlock Text="{x:Bind TuningVM.CurrentTempDisplay, Mode=OneWay}" FontSize="18" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="MAX TEMP" Style="{StaticResource HudCaptionStyle}"/>
                                    <TextBlock Text="{x:Bind TuningVM.MaxTempDisplay, Mode=OneWay}" FontSize="18" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="2">
                                    <TextBlock Text="CPU LOAD" Style="{StaticResource HudCaptionStyle}"/>
                                    <TextBlock Text="{x:Bind TuningVM.CurrentLoadDisplay, Mode=OneWay}" FontSize="18" FontWeight="Bold"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="{x:Bind TuningVM.StressStatus, Mode=OneWay}"
                                       Style="{StaticResource HudCaptionStyle}" TextWrapping="Wrap"/>

                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Content="Launch Prime95" Click="LaunchPrime95_Click" HorizontalAlignment="Stretch"/>
                                <Button Grid.Column="1" Content="Launch Cinebench" Click="LaunchCinebench_Click" HorizontalAlignment="Stretch"/>
                            </Grid>
                        </StackPanel>
                    </hud:HudCard>

                    <!-- TUNING PRESETS -->
                    <TextBlock Text="TUNING PRESETS" Style="{StaticResource HudMicroStyle}" Margin="0,8,0,0"/>
                    <ItemsRepeater ItemsSource="{x:Bind TuningVM.Presets}">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout MinItemWidth="270" MinItemHeight="180"
                                               MinColumnSpacing="8" MinRowSpacing="8"
                                               ItemsStretch="Fill"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="models:TuningPreset">
                                <Border Background="{ThemeResource HudSurfaceAltBrush}"
                                        BorderBrush="{ThemeResource HudHairlineBrush}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource CardCornerRadius}"
                                        Padding="14">
                                    <Grid RowSpacing="6">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{x:Bind Name}"
                                                       FontWeight="SemiBold" FontSize="14"
                                                       TextWrapping="Wrap" VerticalAlignment="Center"/>
                                            <Border Grid.Column="1" CornerRadius="4" Padding="6,2"
                                                    Background="{ThemeResource HudSurfaceBrush}" VerticalAlignment="Center">
                                                <TextBlock Text="{x:Bind Risk}" FontSize="10" FontWeight="SemiBold"/>
                                            </Border>
                                        </Grid>

                                        <TextBlock Grid.Row="1" Text="{x:Bind Description}"
                                                   FontSize="12" TextWrapping="Wrap"
                                                   Foreground="{StaticResource MutedBrush}"/>

                                        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="6">
                                            <Border CornerRadius="4" Padding="5,2"
                                                    BorderBrush="{ThemeResource HudHairlineBrush}" BorderThickness="1">
                                                <TextBlock Text="{x:Bind CpuVendor}" FontSize="10"
                                                           Foreground="{StaticResource MutedBrush}"/>
                                            </Border>
                                            <TextBlock Text="Laptop-friendly" FontSize="10"
                                                       Foreground="{StaticResource AccentCyanBrush}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <Button Grid.Row="3" Content="Apply" Tag="{x:Bind Id}"
                                                Click="ApplyPreset_Click"
                                                Style="{ThemeResource AccentButtonStyle}"
                                                HorizontalAlignment="Stretch"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>

                    <!-- CPU MANUAL TUNING -->
                    <TextBlock Text="CPU MANUAL TUNING" Style="{StaticResource HudMicroStyle}" Margin="0,8,0,0"/>
                    <hud:HudCard>
                        <StackPanel Spacing="14">

                            <StackPanel Spacing="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Minimum Processor State" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="1" FontSize="12" Foreground="{StaticResource MutedBrush}">
                                        <Run Text="{x:Bind TuningVM.CurrentCpu.MinProcessorState, Mode=OneWay}"/>
                                        <Run Text="%"/>
                                    </TextBlock>
                                </Grid>
                                <Slider x:Name="MinStateSlider"
                                        Value="{x:Bind TuningVM.CurrentCpu.MinProcessorState, Mode=TwoWay}"
                                        Minimum="0" Maximum="100" StepFrequency="5"
                                        TickFrequency="25" TickPlacement="Outside"/>
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Maximum Processor State" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="1" FontSize="12" Foreground="{StaticResource MutedBrush}">
                                        <Run Text="{x:Bind TuningVM.CurrentCpu.MaxProcessorState, Mode=OneWay}"/>
                                        <Run Text="%"/>
                                    </TextBlock>
                                </Grid>
                                <Slider x:Name="MaxStateSlider"
                                        Value="{x:Bind TuningVM.CurrentCpu.MaxProcessorState, Mode=TwoWay}"
                                        Minimum="20" Maximum="100" StepFrequency="5"
                                        TickFrequency="20" TickPlacement="Outside"/>
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Text="Processor Performance Boost Mode" FontWeight="SemiBold"/>
                                <ComboBox x:Name="BoostModeCombo"
                                          HorizontalAlignment="Stretch"
                                          SelectionChanged="BoostModeCombo_SelectionChanged">
                                    <ComboBoxItem Content="Disabled"                           Tag="0"/>
                                    <ComboBoxItem Content="Enabled"                            Tag="1"/>
                                    <ComboBoxItem Content="Aggressive"                         Tag="2"/>
                                    <ComboBoxItem Content="Efficient Enabled"                  Tag="3"/>
                                    <ComboBoxItem Content="Efficient Aggressive"               Tag="4"/>
                                    <ComboBoxItem Content="Aggressive at Guaranteed"           Tag="5"/>
                                    <ComboBoxItem Content="Efficient Aggressive at Guaranteed" Tag="6"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Processor Performance Boost Policy" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="1" FontSize="12" Foreground="{StaticResource MutedBrush}">
                                        <Run Text="{x:Bind TuningVM.CurrentCpu.BoostPolicy, Mode=OneWay}"/>
                                        <Run Text="%"/>
                                    </TextBlock>
                                </Grid>
                                <Slider x:Name="BoostPolicySlider"
                                        Value="{x:Bind TuningVM.CurrentCpu.BoostPolicy, Mode=TwoWay}"
                                        Minimum="0" Maximum="100" StepFrequency="5"
                                        TickFrequency="25" TickPlacement="Outside"/>
                            </StackPanel>

                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="1" Content="Revert Defaults" Click="Revert_Click"
                                        IsEnabled="{x:Bind TuningVM.IsApplying, Mode=OneWay, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"/>
                                <Button Grid.Column="2" Content="Apply CPU Tuning" Click="ApplyCpu_Click"
                                        Style="{ThemeResource AccentButtonStyle}"
                                        IsEnabled="{x:Bind TuningVM.IsApplying, Mode=OneWay, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"/>
                            </Grid>
                        </StackPanel>
                    </hud:HudCard>

                    <!-- GPU OVERCLOCKING (EXPERIMENTAL) -->
                    <TextBlock Text="GPU OVERCLOCKING (EXPERIMENTAL)" Style="{StaticResource HudMicroStyle}" Margin="0,8,0,0"/>

                    <hud:HudCard>
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE7F4;" FontSize="16" VerticalAlignment="Center"/>
                                <TextBlock Text="{x:Bind TuningVM.GpuName, Mode=OneWay}"
                                           FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <TextBlock Text="(live telemetry via LibreHardwareMonitor)"
                                           Style="{StaticResource HudCaptionStyle}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="CORE" Style="{StaticResource HudCaptionStyle}"/>
                                    <TextBlock Text="{x:Bind TuningVM.GpuCoreClock, Mode=OneWay}" FontSize="16" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="MEMORY" Style="{StaticResource HudCaptionStyle}"/>
                                    <TextBlock Text="{x:Bind TuningVM.GpuMemClock, Mode=OneWay}" FontSize="16" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="2">
                                    <TextBlock Text="TEMP" Style="{StaticResource HudCaptionStyle}"/>
                                    <TextBlock Text="{x:Bind TuningVM.GpuTemp, Mode=OneWay}" FontSize="16" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="3" Spacing="2">
                                    <TextBlock Text="POWER" Style="{StaticResource HudCaptionStyle}"/>
                                    <TextBlock Text="{x:Bind TuningVM.GpuPower, Mode=OneWay}" FontSize="16" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="4" Spacing="2">
                                    <TextBlock Text="FAN" Style="{StaticResource HudCaptionStyle}"/>
                                    <TextBlock Text="{x:Bind TuningVM.GpuFan, Mode=OneWay}" FontSize="16" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="5" Spacing="2">
                                    <TextBlock Text="LOAD" Style="{StaticResource HudCaptionStyle}"/>
                                    <TextBlock Text="{x:Bind TuningVM.GpuLoad, Mode=OneWay}" FontSize="16" FontWeight="Bold"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </hud:HudCard>

                    <!-- GPU OC write controls (visible only when backend can write) -->
                    <hud:HudCard Visibility="{x:Bind TuningVM.GpuOcWriteAvailable, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel Spacing="12">
                            <InfoBar Severity="Warning" IsOpen="True" IsClosable="False"
                                     Title="Experimental — applies real GPU settings"
                                     Message="These controls write to hardware registers via NVAPI or ADL. Incorrect values can cause instability, crashes, or hardware damage. Verify stability with a stress test. Use 'Reset to Default' to undo. This feature is UNSUPPORTED — verify on your hardware."/>

                            <StackPanel Spacing="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Core Clock Offset (MHz)" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="1" FontSize="12" Foreground="{StaticResource MutedBrush}">
                                        <Run Text="{x:Bind TuningVM.GpuCoreOffsetMhz, Mode=OneWay}"/>
                                        <Run Text=" MHz"/>
                                    </TextBlock>
                                </Grid>
                                <Slider Value="{x:Bind TuningVM.GpuCoreOffsetMhz, Mode=TwoWay}"
                                        Minimum="-200" Maximum="300" StepFrequency="5"
                                        TickFrequency="100" TickPlacement="Outside"
                                        IsEnabled="{x:Bind TuningVM.HasReadDisclaimer, Mode=OneWay}"/>
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Memory Clock Offset (MHz)" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="1" FontSize="12" Foreground="{StaticResource MutedBrush}">
                                        <Run Text="{x:Bind TuningVM.GpuMemOffsetMhz, Mode=OneWay}"/>
                                        <Run Text=" MHz"/>
                                    </TextBlock>
                                </Grid>
                                <Slider Value="{x:Bind TuningVM.GpuMemOffsetMhz, Mode=TwoWay}"
                                        Minimum="-500" Maximum="1500" StepFrequency="10"
                                        TickFrequency="500" TickPlacement="Outside"
                                        IsEnabled="{x:Bind TuningVM.HasReadDisclaimer, Mode=OneWay}"/>
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Power Limit (%)" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="1" FontSize="12" Foreground="{StaticResource MutedBrush}">
                                        <Run Text="{x:Bind TuningVM.GpuPowerLimitPct, Mode=OneWay}"/>
                                        <Run Text="%"/>
                                    </TextBlock>
                                </Grid>
                                <Slider Value="{x:Bind TuningVM.GpuPowerLimitPct, Mode=TwoWay}"
                                        Minimum="50" Maximum="120" StepFrequency="5"
                                        TickFrequency="10" TickPlacement="Outside"
                                        IsEnabled="{x:Bind TuningVM.HasReadDisclaimer, Mode=OneWay}"/>
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Temperature Limit (°C)" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="1" FontSize="12" Foreground="{StaticResource MutedBrush}">
                                        <Run Text="{x:Bind TuningVM.GpuTempLimitC, Mode=OneWay}"/>
                                        <Run Text="°C"/>
                                    </TextBlock>
                                </Grid>
                                <Slider Value="{x:Bind TuningVM.GpuTempLimitC, Mode=TwoWay}"
                                        Minimum="60" Maximum="95" StepFrequency="1"
                                        TickFrequency="10" TickPlacement="Outside"
                                        IsEnabled="{x:Bind TuningVM.HasReadDisclaimer, Mode=OneWay}"/>
                            </StackPanel>

                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="WATCHDOG LIMIT (°C)" Style="{StaticResource HudCaptionStyle}"/>
                                    <NumberBox Value="{x:Bind TuningVM.GpuWatchdogTempC, Mode=TwoWay}"
                                               Minimum="60" Maximum="105" SpinButtonPlacementMode="Inline"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="TEST DURATION (s)" Style="{StaticResource HudCaptionStyle}"/>
                                    <NumberBox Value="{x:Bind TuningVM.GpuWatchdogDurationSec, Mode=TwoWay}"
                                               Minimum="10" Maximum="300" SpinButtonPlacementMode="Inline"/>
                                </StackPanel>
                            </Grid>

                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button Content="Apply" Click="ApplyGpuOc_Click"
                                        Style="{ThemeResource AccentButtonStyle}" HorizontalAlignment="Stretch"
                                        IsEnabled="{x:Bind TuningVM.HasReadDisclaimer, Mode=OneWay}"/>
                                <Button Grid.Column="1" Content="Apply + Watchdog Test" Click="ApplyGpuOcWatchdog_Click"
                                        HorizontalAlignment="Stretch"
                                        IsEnabled="{x:Bind TuningVM.HasReadDisclaimer, Mode=OneWay}"/>
                                <Button Grid.Column="2" Content="Reset to Default" Click="ResetGpuOc_Click"
                                        HorizontalAlignment="Stretch"/>
                                <Button Grid.Column="3" Content="Stop Watchdog" Click="StopGpuWatchdog_Click"
                                        Visibility="{x:Bind TuningVM.IsGpuWatchdogRunning, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>
                            </Grid>

                            <TextBlock Text="{x:Bind TuningVM.GpuOcStatus, Mode=OneWay}"
                                       Style="{StaticResource HudCaptionStyle}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </hud:HudCard>

                    <!-- GPU OC fallback (write unavailable) -->
                    <hud:HudCard Visibility="{x:Bind TuningVM.GpuOcWriteAvailable, Mode=OneWay, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                        <StackPanel Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE783;" FontSize="16" VerticalAlignment="Center"
                                          Foreground="{StaticResource WarningBrush}"/>
                                <TextBlock Text="In-app GPU OC not available" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{x:Bind TuningVM.GpuOcUnavailableReason, Mode=OneWay}"
                                       FontSize="12" TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}"/>
                            <TextBlock Text="Use a vendor GPU tool (MSI Afterburner, NVIDIA App, AMD Adrenalin) for overclocking. Telemetry above is still live when LibreHardwareMonitor is available."
                                       FontSize="12" TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}"/>
                            <Button Content="Open GPU Vendor Tool" Click="OpenGpuVendorTool_Click"
                                    Style="{ThemeResource AccentButtonStyle}"/>
                        </StackPanel>
                    </hud:HudCard>

                    <!-- GPU OVERCLOCKING TOOLS -->
                    <TextBlock Text="GPU OVERCLOCKING TOOLS" Style="{StaticResource HudMicroStyle}" Margin="0,8,0,0"/>
                    <TextBlock Text="Launch installed GPU OC tools or download official vendor software"
                               Style="{StaticResource HudCaptionStyle}"/>

                    <ItemsRepeater ItemsSource="{x:Bind TuningVM.GpuTools, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout MinItemWidth="320" MinItemHeight="80"
                                               MinColumnSpacing="8" MinRowSpacing="8"
                                               ItemsStretch="Fill"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="services:VendorTool">
                                <Border Background="{ThemeResource HudSurfaceAltBrush}"
                                        BorderBrush="{ThemeResource HudHairlineBrush}"
                                        BorderThickness="1" CornerRadius="{StaticResource CardCornerRadius}"
                                        Padding="14">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Spacing="4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                <Border Grid.Column="1" CornerRadius="4" Padding="6,2" VerticalAlignment="Center"
                                                        Background="{x:Bind IsInstalled, Converter={StaticResource BoolToInstalledBrush}}">
                                                    <TextBlock Text="{x:Bind IsInstalled, Converter={StaticResource BoolToInstalledText}}"
                                                               FontSize="10" FontWeight="Bold" Foreground="White"/>
                                                </Border>
                                            </Grid>
                                            <TextBlock Text="{x:Bind Description}" FontSize="11" TextWrapping="Wrap"
                                                       Foreground="{StaticResource MutedBrush}"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" VerticalAlignment="Center"
                                                Click="LaunchTool_Click" Tag="{x:Bind Name}">
                                            <TextBlock Text="{x:Bind IsInstalled, Converter={StaticResource BoolToActionText}}"/>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>

                    <!-- Detected GPUs -->
                    <TextBlock Text="DETECTED GPUs" Style="{StaticResource HudMicroStyle}" Margin="0,8,0,0"/>
                    <ItemsRepeater ItemsSource="{x:Bind TuningVM.Gpus}">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Vertical" Spacing="4"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="services:GpuClockInfo">
                                <Border Background="{ThemeResource HudSurfaceAltBrush}"
                                        BorderBrush="{ThemeResource HudHairlineBrush}"
                                        BorderThickness="1" CornerRadius="6" Padding="12,8">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE7F4;" FontSize="16" VerticalAlignment="Center"/>
                                        <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>

                    <!-- MEMORY DIAGNOSTICS -->
                    <TextBlock Text="MEMORY DIAGNOSTICS" Style="{StaticResource HudMicroStyle}" Margin="0,8,0,0"/>
                    <hud:HudCard>
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Memory Diagnostics" FontWeight="SemiBold"/>
                                <TextBlock Text="Schedule Windows Memory Diagnostic to test RAM on next reboot"
                                           Style="{StaticResource HudCaptionStyle}"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Launch mdsched" Click="MemoryTest_Click" VerticalAlignment="Center"/>
                        </Grid>
                    </hud:HudCard>

                    <!-- RAM (READ-ONLY) -->
                    <TextBlock Text="RAM (READ-ONLY)" Style="{StaticResource HudMicroStyle}" Margin="0,8,0,0"/>

                    <InfoBar Severity="Informational" IsOpen="True" IsClosable="False"
                             Title="For RAM tuning, use BIOS XMP / DOCP / EXPO"
                             Message="RAM frequency, timings, and voltage can only be configured in BIOS firmware. Enable XMP (Intel) / DOCP (AMD) / EXPO (AMD AM5) profiles in your motherboard BIOS for safe, vendor-validated RAM overclocking."/>

                    <hud:HudCard>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE950;" FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock VerticalAlignment="Center">
                                <Run Text="Detected speed:" Foreground="{StaticResource MutedBrush}"/>
                                <Run Text=" "/>
                                <Run Text="{x:Bind TuningVM.RamInfo.FrequencyMhz, Mode=OneWay}" FontWeight="SemiBold"/>
                                <Run Text=" MHz"/>
                            </TextBlock>
                        </StackPanel>
                    </hud:HudCard>

                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </hud:HudBackdrop>
</Page>
