<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Optimizer.WinUI.Views.PerformancePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Optimizer.WinUI.Controls"
    xmlns:converters="using:Optimizer.WinUI.Converters"
    xmlns:vm="using:Optimizer.WinUI.ViewModels"
    xmlns:services="using:Optimizer.WinUI.Services"
    xmlns:models="using:Optimizer.WinUI.Models"
    Background="Transparent"
    Loaded="Page_Loaded">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16" Padding="24,16,24,24">
            <StackPanel.ChildrenTransitions>
                <TransitionCollection>
                    <EntranceThemeTransition FromVerticalOffset="20"/>
                </TransitionCollection>
            </StackPanel.ChildrenTransitions>

            <!-- ── Page header ──────────────────────────────────────────── -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: icon + title + subtitle -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <TextBlock Text="{x:Bind ViewModel.CategoryIcon}"
                               FontSize="28" VerticalAlignment="Center"/>
                    <StackPanel Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="{x:Bind ViewModel.CategoryName}"
                                   Style="{StaticResource TitleTextBlockStyle}"/>
                        <TextBlock FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                            <Run Text="{x:Bind ViewModel.ActiveCount, Mode=OneWay}"/>
                            <Run Text=" of "/>
                            <Run Text="{x:Bind ViewModel.TotalCount, Mode=OneWay}"/>
                            <Run Text=" optimizations active"/>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>

                <!-- Right: action buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button Content="Apply All"
                            Style="{StaticResource AccentButtonStyle}"
                            Command="{x:Bind ViewModel.ApplyAllCommand}"/>
                    <Button Content="Undo Category"
                            Command="{x:Bind ViewModel.UndoCategoryCommand}"/>
                </StackPanel>
            </Grid>

            <!-- ── Local metrics strip ──────────────────────────────────── -->
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- CPU Usage -->
                <Border Grid.Column="0" CornerRadius="8" Padding="16,12" Background="{ThemeResource LayerFillColorDefaultBrush}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="CPU Usage" FontSize="12" Foreground="#60A5FA"/>
                        <TextBlock Text="{x:Bind ViewModel.CpuText, Mode=OneWay}"
                                   FontSize="22" FontWeight="Bold" FontFamily="Consolas"/>
                        <ProgressBar Value="{x:Bind ViewModel.CpuUsage, Mode=OneWay}"
                                     Maximum="100" Height="4" CornerRadius="2"
                                     Foreground="#60A5FA"/>
                    </StackPanel>
                </Border>

                <!-- Memory Usage -->
                <Border Grid.Column="1" CornerRadius="8" Padding="16,12" Background="{ThemeResource LayerFillColorDefaultBrush}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Memory" FontSize="12" Foreground="#34D399"/>
                        <TextBlock Text="{x:Bind ViewModel.MemoryText, Mode=OneWay}"
                                   FontSize="22" FontWeight="Bold" FontFamily="Consolas"/>
                        <TextBlock Text="{x:Bind ViewModel.UsedMemoryText, Mode=OneWay}"
                                   FontSize="11"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <ProgressBar Value="{x:Bind ViewModel.MemoryUsage, Mode=OneWay}"
                                     Maximum="100" Height="4" CornerRadius="2"
                                     Foreground="#34D399"/>
                    </StackPanel>
                </Border>

                <!-- Optimizations Active -->
                <Border Grid.Column="2" CornerRadius="8" Padding="16,12" Background="{ThemeResource LayerFillColorDefaultBrush}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Optimizations" FontSize="12" Foreground="#A78BFA"/>
                        <TextBlock FontSize="22" FontWeight="Bold" FontFamily="Consolas">
                            <Run Text="{x:Bind ViewModel.ActiveCount, Mode=OneWay}"/>
                            <Run Text=" / "/>
                            <Run Text="{x:Bind ViewModel.TotalCount, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Text="active" FontSize="11"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── Power Plan ───────────────────────────────────────────── -->
            <TextBlock Text="POWER PLAN" FontSize="11" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,8,0,4"/>
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="14"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="10">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Active Plan" FontWeight="SemiBold"/>
                            <TextBlock Text="{x:Bind ViewModel.ActivePowerPlan.Name, Mode=OneWay, FallbackValue=Loading...}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                        </StackPanel>

                        <ToggleSwitch Grid.Column="1" Header="Game Mode"
                                      IsOn="{x:Bind ViewModel.GameModeEnabled, Mode=TwoWay}"/>

                        <Button Grid.Column="2" Content="Enable Ultimate Perf"
                                VerticalAlignment="Center"
                                Click="UltimatePerf_Click"/>
                    </Grid>

                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.PowerPlans, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout MinItemWidth="180" MinColumnSpacing="8" MinRowSpacing="8"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="services:PowerPlan">
                                <Button Click="PowerPlan_Click" Tag="{x:Bind Guid}"
                                        HorizontalAlignment="Stretch" Padding="12,8">
                                    <StackPanel>
                                        <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="ACTIVE" FontSize="10"
                                                   Foreground="{ThemeResource SystemAccentColor}"
                                                   Visibility="{x:Bind IsActive, Converter={StaticResource BoolToVisibility}}"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>
            </Border>

            <!-- ── Process Priority Manager ─────────────────────────────── -->
            <TextBlock Text="RUNNING PROCESSES" FontSize="11" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,8,0,4"/>
            <ListView x:Name="ProcessListView"
                      ItemsSource="{x:Bind ViewModel.Processes, Mode=OneWay}"
                      SelectionMode="None" MaxHeight="400">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:ProcessPriorityInfo">
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="6" Padding="10,6" Margin="0,0,0,2">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock FontSize="10" Foreground="{ThemeResource TextFillColorTertiaryBrush}">
                                        <Run Text="PID:"/>
                                        <Run Text="{x:Bind PidText}"/>
                                    </TextBlock>
                                </StackPanel>

                                <TextBlock Grid.Column="1" Text="{x:Bind MemoryText}"
                                           FontSize="11" VerticalAlignment="Center"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                                <TextBlock Grid.Column="2" Text="{x:Bind Priority}"
                                           FontSize="11" VerticalAlignment="Center"
                                           MinWidth="80"/>

                                <ComboBox Grid.Column="3" Tag="{x:Bind Pid}"
                                          SelectionChanged="Priority_Changed"
                                          SelectedItem="{x:Bind Priority, Mode=OneWay}"
                                          MinWidth="120">
                                    <ComboBoxItem Content="High"/>
                                    <ComboBoxItem Content="AboveNormal"/>
                                    <ComboBoxItem Content="Normal"/>
                                    <ComboBoxItem Content="BelowNormal"/>
                                    <ComboBoxItem Content="Idle"/>
                                </ComboBox>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- ── Optimization cards ───────────────────────────────────── -->
            <TextBlock Text="Optimizations"
                       FontSize="16" FontWeight="SemiBold"
                       Margin="0,8,0,0"/>

            <ItemsRepeater x:Name="OptimizationsRepeater"
                           ItemsSource="{x:Bind ViewModel.Optimizations, Mode=OneWay}">
                <ItemsRepeater.Layout>
                    <StackLayout Orientation="Vertical" Spacing="0"/>
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="vm:OptimizationCardModel">
                        <controls:OptimizationCard
                            Tag="{x:Bind Id}"
                            Loaded="OptimizationCard_Loaded"/>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

        </StackPanel>
    </ScrollViewer>
</Page>
