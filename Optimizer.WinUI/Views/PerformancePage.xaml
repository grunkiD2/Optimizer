<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Optimizer.WinUI.Views.PerformancePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Optimizer.WinUI.Controls"
    xmlns:converters="using:Optimizer.WinUI.Converters"
    xmlns:hud="using:Optimizer.WinUI.Controls.Hud"
    xmlns:vm="using:Optimizer.WinUI.ViewModels"
    xmlns:services="using:Optimizer.WinUI.Services"
    xmlns:models="using:Optimizer.WinUI.Models"
    Background="Transparent"
    Loaded="Page_Loaded">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </Page.Resources>

    <hud:HudBackdrop>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32,24,32,32">
            <StackPanel Spacing="24" MaxWidth="1360" HorizontalAlignment="Left">
                <StackPanel.ChildrenTransitions>
                    <TransitionCollection>
                        <EntranceThemeTransition FromVerticalOffset="20"/>
                    </TransitionCollection>
                </StackPanel.ChildrenTransitions>

                <!-- ── Page header ──────────────────────────────────────────── -->
                <hud:HudPageHeader Icon="{x:Bind ViewModel.CategoryIcon}"
                                   Title="{x:Bind ViewModel.CategoryName}"
                                   Description="Tune CPU, memory, power mode, and per-process priority for snappier response.">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Apply All" Style="{StaticResource AccentButtonStyle}"
                                Command="{x:Bind ViewModel.ApplyAllCommand}"/>
                        <Button Content="Undo Category" Command="{x:Bind ViewModel.UndoCategoryCommand}"/>
                    </StackPanel>
                </hud:HudPageHeader>

                <!-- ── Vitals (live sparklines) ─────────────────────────────── -->
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <hud:StatTile x:Name="CpuTile" Grid.Column="0" Label="CPU" Unit="%" Value="--" Status="Info"/>
                    <hud:StatTile x:Name="MemTile" Grid.Column="1" Label="MEMORY" Unit="%" Value="--" Status="Success"/>
                    <hud:StatTile x:Name="OptTile" Grid.Column="2" Label="OPTIMIZATIONS ACTIVE" Value="--" Status="Accent"/>
                </Grid>

                <!-- ── Bento body: optimizations | (power + processes) ──────── -->
                <Grid ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: optimizations -->
                    <StackPanel Grid.Column="0" Spacing="12">
                        <StackPanel Spacing="2">
                            <TextBlock Text="OPTIMIZATIONS" Style="{StaticResource HudMicroStyle}"/>
                            <TextBlock Text="Toggle individual tweaks. Each card shows exactly what it changes and the trade-offs."
                                       Style="{StaticResource HudCaptionStyle}"/>
                        </StackPanel>
                        <ItemsRepeater x:Name="OptimizationsRepeater"
                                       ItemsSource="{x:Bind ViewModel.Optimizations, Mode=OneWay}">
                            <ItemsRepeater.Layout>
                                <StackLayout Orientation="Vertical" Spacing="0"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="vm:OptimizationCardModel">
                                    <controls:OptimizationCard Tag="{x:Bind Id}" Loaded="OptimizationCard_Loaded"/>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </StackPanel>

                    <!-- Right: power + processes -->
                    <StackPanel Grid.Column="1" Spacing="24">
                        <hud:HudCard Header="POWER" Description="Choose a Windows power plan and toggle Game Mode.">
                            <StackPanel Spacing="12">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Active plan" Style="{StaticResource HudCaptionStyle}"/>
                                        <TextBlock Text="{x:Bind ViewModel.ActivePowerPlan.Name, Mode=OneWay, FallbackValue=Loading...}"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <ToggleSwitch Grid.Column="1" Header="Game Mode"
                                                  IsOn="{x:Bind ViewModel.GameModeEnabled, Mode=TwoWay}"/>
                                </Grid>

                                <ItemsRepeater ItemsSource="{x:Bind ViewModel.PowerPlans, Mode=OneWay}">
                                    <ItemsRepeater.Layout>
                                        <UniformGridLayout MinItemWidth="150" MinColumnSpacing="8" MinRowSpacing="8"/>
                                    </ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate x:DataType="services:PowerPlan">
                                            <Button Click="PowerPlan_Click" Tag="{x:Bind Guid}"
                                                    HorizontalAlignment="Stretch" Padding="12,8">
                                                <StackPanel>
                                                    <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="ACTIVE" FontSize="10" FontWeight="SemiBold"
                                                               Foreground="{StaticResource AccentCyanBrush}"
                                                               Visibility="{x:Bind IsActive, Converter={StaticResource BoolToVisibility}}"/>
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>

                                <Button Content="Enable Ultimate Performance" HorizontalAlignment="Stretch"
                                        Click="UltimatePerf_Click"/>
                            </StackPanel>
                        </hud:HudCard>

                        <hud:HudCard Header="RUNNING PROCESSES" Description="Set priority or per-core CPU affinity for any process.">
                            <ListView x:Name="ProcessListView"
                                      ItemsSource="{x:Bind ViewModel.Processes, Mode=OneWay}"
                                      SelectionMode="None" MaxHeight="420">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="models:ProcessPriorityInfo">
                                        <Border Padding="6,8" BorderBrush="{ThemeResource HudHairlineBrush}" BorderThickness="0,0,0,1">
                                            <Grid ColumnSpacing="10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Style="{StaticResource HudMonoSmallStyle}" Foreground="{StaticResource MutedBrush}">
                                                        <Run Text="PID"/>
                                                        <Run Text="{x:Bind PidText}"/>
                                                        <Run Text="·"/>
                                                        <Run Text="{x:Bind MemoryText}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                                <ComboBox Grid.Column="1" Tag="{x:Bind Pid}"
                                                          SelectionChanged="Priority_Changed"
                                                          SelectedItem="{x:Bind Priority, Mode=OneWay}" MinWidth="116">
                                                    <ComboBoxItem Content="High"/>
                                                    <ComboBoxItem Content="AboveNormal"/>
                                                    <ComboBoxItem Content="Normal"/>
                                                    <ComboBoxItem Content="BelowNormal"/>
                                                    <ComboBoxItem Content="Idle"/>
                                                </ComboBox>
                                                <Button Grid.Column="2" Tag="{x:Bind Pid}" Content="Affinity"
                                                        VerticalAlignment="Center" Click="Affinity_Click"
                                                        ToolTipService.ToolTip="Set per-core CPU affinity"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </hud:HudCard>
                    </StackPanel>
                </Grid>

            </StackPanel>
        </ScrollViewer>
    </hud:HudBackdrop>
</Page>
