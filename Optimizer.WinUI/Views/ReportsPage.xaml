<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Optimizer.WinUI.Views.ReportsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Optimizer.WinUI.ViewModels"
    xmlns:hud="using:Optimizer.WinUI.Controls.Hud"
    xmlns:converters="using:Optimizer.WinUI.Converters"
    Background="Transparent">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </Page.Resources>

    <hud:HudBackdrop>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Header ──────────────────────────────────────────────────────── -->
        <Grid Grid.Row="0" Margin="24,16,24,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="{x:Bind ViewModel.CategoryIcon}"
                               FontSize="28" VerticalAlignment="Center"/>
                    <TextBlock Text="{x:Bind ViewModel.CategoryName}"
                               Style="{StaticResource TitleTextBlockStyle}"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="Generate exportable system reports"
                           Foreground="{StaticResource MutedBrush}"
                           FontSize="13"/>
            </StackPanel>

            <!-- Format selector -->
            <ComboBox Grid.Column="1"
                      ItemsSource="{x:Bind ViewModel.FormatOptions}"
                      SelectedItem="{x:Bind ViewModel.SelectedFormatLabel, Mode=TwoWay}"
                      PlaceholderText="Format"
                      MinWidth="110"
                      VerticalAlignment="Center"
                      Margin="0,0,8,0"/>

            <!-- Generate button -->
            <Button Grid.Column="2"
                    Content="Generate"
                    Style="{ThemeResource AccentButtonStyle}"
                    Command="{x:Bind ViewModel.GenerateCommand}"
                    IsEnabled="{x:Bind ViewModel.IsNotBusy, Mode=OneWay}"
                    VerticalAlignment="Center"/>
        </Grid>

        <!-- ── Report type cards ───────────────────────────────────────────── -->
        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled"
                      Margin="24,16,24,0">
            <ItemsRepeater ItemsSource="{x:Bind ViewModel.ReportTypes}">
                <ItemsRepeater.Layout>
                    <StackLayout Orientation="Horizontal" Spacing="12"/>
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="vm:ReportTypeItem">
                        <Button Click="ReportTypeCard_Click"
                                Tag="{x:Bind Type}"
                                MinWidth="168"
                                Padding="16,12">
                            <StackPanel Spacing="4">
                                <TextBlock Text="{x:Bind Name}"
                                           FontWeight="SemiBold"
                                           TextWrapping="NoWrap"/>
                                <TextBlock Text="{x:Bind Description}"
                                           FontSize="11"
                                           Foreground="{StaticResource MutedBrush}"
                                           TextWrapping="Wrap"
                                           MaxWidth="160"/>
                            </StackPanel>
                        </Button>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </ScrollViewer>

        <!-- ── Preview area ────────────────────────────────────────────────── -->
        <Grid Grid.Row="2" Margin="24,16,24,0">

            <!-- Empty / busy state -->
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="12"
                        Visibility="{x:Bind ViewModel.HasContent, Mode=OneWay, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                <ProgressRing IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                              Width="36" Height="36"
                              Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>
                <TextBlock Text="Select a report type above then click Generate"
                           Foreground="{StaticResource MutedBrush}"
                           HorizontalAlignment="Center"
                           Visibility="{x:Bind ViewModel.IsNotBusy, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>
            </StackPanel>

            <!-- Content -->
            <Border CornerRadius="8"
                    Background="{ThemeResource HudSurfaceAltBrush}"
                    BorderBrush="{ThemeResource HudHairlineBrush}"
                    BorderThickness="1"
                    Visibility="{x:Bind ViewModel.HasContent, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto"
                              Padding="16">
                    <TextBlock Text="{x:Bind ViewModel.PreviewContent, Mode=OneWay}"
                               FontFamily="Cascadia Mono,Consolas,monospace"
                               FontSize="12"
                               IsTextSelectionEnabled="True"
                               TextWrapping="NoWrap"/>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ── Footer / status bar ─────────────────────────────────────────── -->
        <Grid Grid.Row="3" Margin="24,12,24,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                       Foreground="{StaticResource MutedBrush}"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"/>

            <Button Grid.Column="1"
                    Content="Open Folder"
                    Margin="0,0,8,0"
                    VerticalAlignment="Center"
                    Visibility="{x:Bind ViewModel.HasContent, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                    Click="OpenFolder_Click"/>

            <Button Grid.Column="2"
                    Content="Save to File"
                    Style="{ThemeResource AccentButtonStyle}"
                    Command="{x:Bind ViewModel.SaveCommand}"
                    IsEnabled="{x:Bind ViewModel.HasContent, Mode=OneWay}"
                    VerticalAlignment="Center"/>
        </Grid>

    </Grid>
    </hud:HudBackdrop>
</Page>
