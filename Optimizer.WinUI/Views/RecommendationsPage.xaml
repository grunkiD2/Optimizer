<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Optimizer.WinUI.Views.RecommendationsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Optimizer.WinUI.Models"
    xmlns:hud="using:Optimizer.WinUI.Controls.Hud"
    xmlns:converters="using:Optimizer.WinUI.Converters"
    Background="Transparent"
    Loaded="Page_Loaded">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:StringToSolidColorBrushConverter x:Key="StringToSolidColorBrush"/>
    </Page.Resources>

    <hud:HudBackdrop>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="24,16,24,24" Spacing="16">
            <StackPanel.ChildrenTransitions>
                <TransitionCollection>
                    <EntranceThemeTransition FromVerticalOffset="20"/>
                </TransitionCollection>
            </StackPanel.ChildrenTransitions>

            <!-- ── Header ────────────────────────────────────────────────── -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="2">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="{x:Bind ViewModel.CategoryIcon}"
                                   FontSize="28" VerticalAlignment="Center"/>
                        <TextBlock Text="{x:Bind ViewModel.CategoryName}"
                                   Style="{StaticResource TitleTextBlockStyle}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Personalized suggestions to improve your system"
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="13"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Retrain Intelligence"
                        VerticalAlignment="Bottom"
                        Click="TrainModel_Click"/>

                <Button Grid.Column="2"
                        Content="Refresh"
                        VerticalAlignment="Bottom"
                        Margin="8,0,0,0"
                        Click="Refresh_Click"/>

                <Button Grid.Column="3"
                        Content="Reset Dismissed"
                        VerticalAlignment="Bottom"
                        Margin="8,0,0,0"
                        Click="ResetDismissed_Click"/>
            </Grid>

            <!-- ── ML Status banner ──────────────────────────────────────── -->
            <Border Background="{ThemeResource HudSurfaceBrush}"
                    CornerRadius="6" Padding="12,8"
                    BorderBrush="{ThemeResource HudHairlineBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="&#x1F9E0;" FontSize="16"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Grid.Column="1"
                               Text="{x:Bind ViewModel.MLStatusText, Mode=OneWay}"
                               FontSize="12"
                               Foreground="{StaticResource MutedBrush}"
                               VerticalAlignment="Center"/>
                    <ProgressRing Grid.Column="2"
                                  IsActive="{x:Bind ViewModel.IsTrainingModel, Mode=OneWay}"
                                  Width="20" Height="20"
                                  Visibility="{x:Bind ViewModel.IsTrainingModel, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>
                </Grid>
            </Border>

            <!-- ── Progress ──────────────────────────────────────────────── -->
            <ProgressBar IsIndeterminate="True"
                         Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>

            <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                       Foreground="{StaticResource MutedBrush}"
                       FontSize="12"/>

            <!-- ── Smart Insights ─────────────────────────────────────────── -->
            <TextBlock Text="SMART INSIGHTS"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="{StaticResource MutedBrush}"
                       Margin="0,8,0,4"/>

            <ItemsRepeater ItemsSource="{x:Bind ViewModel.Insights, Mode=OneWay}">
                <ItemsRepeater.Layout>
                    <StackLayout Orientation="Vertical" Spacing="8"/>
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="models:SmartInsight">
                        <Border Background="{ThemeResource AccentFillColorTertiaryBrush}"
                                CornerRadius="8" Padding="16"
                                BorderBrush="{ThemeResource HudHairlineBrush}"
                                BorderThickness="1">
                            <StackPanel Spacing="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="&#x1F4A1;" FontSize="20" Margin="0,0,12,0"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{x:Bind Title, Mode=OneWay}"
                                               FontWeight="SemiBold" FontSize="14"
                                               VerticalAlignment="Center"
                                               TextWrapping="Wrap"/>
                                </Grid>
                                <TextBlock Text="{x:Bind Body, Mode=OneWay}"
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource MutedBrush}"/>
                                <Border Background="{ThemeResource HudSurfaceBrush}"
                                        CornerRadius="4" Padding="8,4">
                                    <TextBlock Text="{x:Bind SupportingDataText, Mode=OneWay}"
                                               FontSize="11" FontFamily="Consolas"/>
                                </Border>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

            <!-- ── Filter bar ────────────────────────────────────────────── -->
            <Grid ColumnSpacing="8" Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Active Recommendations"
                           FontSize="18" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>

                <ComboBox Grid.Column="1"
                          ItemsSource="{x:Bind ViewModel.CategoryOptions}"
                          SelectedItem="{x:Bind ViewModel.FilterCategory, Mode=TwoWay}"
                          MinWidth="140"/>
            </Grid>

            <!-- ── Empty state ───────────────────────────────────────────── -->
            <Border CornerRadius="8" Padding="32"
                    Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                    Background="{ThemeResource HudSurfaceAltBrush}">
                <StackPanel HorizontalAlignment="Center" Spacing="12">
                    <TextBlock Text="&#x1F389;" FontSize="48" HorizontalAlignment="Center" Opacity="0.8"/>
                    <TextBlock Text="Your system looks great!"
                               FontSize="16" FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="No recommendations right now. Keep using your system and we'll surface improvements as they arise."
                               FontSize="12" HorizontalAlignment="Center"
                               Foreground="{StaticResource MutedBrush}"
                               TextWrapping="Wrap" MaxWidth="320" TextAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- ── Recommendations list ──────────────────────────────────── -->
            <ItemsRepeater ItemsSource="{x:Bind ViewModel.Recommendations, Mode=OneWay}">
                <ItemsRepeater.Layout>
                    <StackLayout Orientation="Vertical" Spacing="10"/>
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="models:Recommendation">
                        <Border Background="{ThemeResource HudSurfaceAltBrush}"
                                CornerRadius="8" Padding="16"
                                BorderBrush="{ThemeResource HudHairlineBrush}"
                                BorderThickness="1">
                            <StackPanel Spacing="10">

                                <!-- Title row -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="{x:Bind CategoryIcon}"
                                               FontSize="22"
                                               Margin="0,0,12,0"
                                               VerticalAlignment="Center"/>

                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Title, Mode=OneWay}"
                                                   FontWeight="SemiBold"
                                                   FontSize="14"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <!-- ML confidence badge (only when model has scored this rec) -->
                                    <Border Grid.Column="2"
                                            CornerRadius="4" Padding="6,2"
                                            VerticalAlignment="Top"
                                            Margin="4,0,4,0"
                                            Background="#1E3A8A"
                                            Visibility="{x:Bind HasMLConfidence, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                        <TextBlock Text="{x:Bind MLConfidenceText, Mode=OneWay}"
                                                   FontSize="10" FontWeight="Bold"
                                                   Foreground="White"/>
                                    </Border>

                                    <Border Grid.Column="3"
                                            CornerRadius="4" Padding="8,3"
                                            VerticalAlignment="Top"
                                            Background="{x:Bind SeverityColor, Converter={StaticResource StringToSolidColorBrush}}">
                                        <TextBlock Text="{x:Bind SeverityBadge}"
                                                   FontSize="10" FontWeight="Bold"
                                                   Foreground="White"/>
                                    </Border>
                                </Grid>

                                <!-- Description -->
                                <TextBlock Text="{x:Bind Description, Mode=OneWay}"
                                           TextWrapping="Wrap"
                                           FontSize="13"
                                           Foreground="{StaticResource MutedBrush}"/>

                                <!-- Action buttons -->
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Content="{x:Bind ActionLabel, Mode=OneWay}"
                                            Style="{ThemeResource AccentButtonStyle}"
                                            Tag="{x:Bind}"
                                            Click="Action_Click"/>
                                    <Button Content="Snooze 7 days"
                                            Tag="{x:Bind Id}"
                                            Click="Snooze_Click"/>
                                    <Button Content="Dismiss"
                                            Tag="{x:Bind}"
                                            Click="Dismiss_Click"/>
                                </StackPanel>

                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

        </StackPanel>
    </ScrollViewer>
    </hud:HudBackdrop>
</Page>
