<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Optimizer.WinUI.Views.OnboardingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Optimizer.WinUI.Converters"
    Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">

    <Page.Resources>
        <converters:StepToColorConverter     x:Key="StepToColor"/>
        <converters:EqualsToVisibilityConverter x:Key="EqualsToVisibility"/>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                    MaxWidth="600" Padding="32" Spacing="24"
                    Margin="0,48,0,48">

            <!-- ── Progress dots ────────────────────────────────────────────── -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                <Ellipse Width="12" Height="12"
                         Fill="{x:Bind ViewModel.CurrentStep, Mode=OneWay,
                                Converter={StaticResource StepToColor}, ConverterParameter=0}"/>
                <Ellipse Width="12" Height="12"
                         Fill="{x:Bind ViewModel.CurrentStep, Mode=OneWay,
                                Converter={StaticResource StepToColor}, ConverterParameter=1}"/>
                <Ellipse Width="12" Height="12"
                         Fill="{x:Bind ViewModel.CurrentStep, Mode=OneWay,
                                Converter={StaticResource StepToColor}, ConverterParameter=2}"/>
                <Ellipse Width="12" Height="12"
                         Fill="{x:Bind ViewModel.CurrentStep, Mode=OneWay,
                                Converter={StaticResource StepToColor}, ConverterParameter=3}"/>
            </StackPanel>

            <!-- ── Step 0: Welcome ──────────────────────────────────────────── -->
            <StackPanel Spacing="16"
                        Visibility="{x:Bind ViewModel.CurrentStep, Mode=OneWay,
                                     Converter={StaticResource EqualsToVisibility}, ConverterParameter=0}">
                <TextBlock Text="&#x1F680;" FontSize="64" HorizontalAlignment="Center"/>
                <TextBlock Text="Welcome to Optimizer"
                           FontSize="32" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                <TextBlock Text="Take control of your Windows system. Tune performance, improve privacy, and monitor health — all from one place."
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap" TextAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           FontSize="14"/>
                <Button Content="Get Started"
                        Click="Next_Click"
                        Style="{ThemeResource AccentButtonStyle}"
                        HorizontalAlignment="Center"
                        Padding="32,12"
                        FontSize="15"/>
            </StackPanel>

            <!-- ── Step 1: Usage profile ─────────────────────────────────────── -->
            <StackPanel Spacing="16"
                        Visibility="{x:Bind ViewModel.CurrentStep, Mode=OneWay,
                                     Converter={StaticResource EqualsToVisibility}, ConverterParameter=1}">
                <TextBlock Text="How do you use this PC?"
                           FontSize="24" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                <TextBlock Text="We'll suggest an initial optimization profile based on your answer."
                           HorizontalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap" TextAlignment="Center"/>

                <Border CornerRadius="8" Padding="16"
                        Background="{ThemeResource LayerFillColorDefaultBrush}">
                    <StackPanel Spacing="10">
                        <RadioButton x:Name="UsageGaming"
                                     Content="Gaming" GroupName="Usage"
                                     Click="UsageOption_Clicked" Tag="Gaming"
                                     FontSize="14"/>
                        <RadioButton x:Name="UsageWork"
                                     Content="Work / Productivity" GroupName="Usage"
                                     Click="UsageOption_Clicked" Tag="Work / Productivity"
                                     FontSize="14"/>
                        <RadioButton x:Name="UsageMixed"
                                     Content="Mixed" GroupName="Usage"
                                     Click="UsageOption_Clicked" Tag="Mixed"
                                     FontSize="14" IsChecked="True"/>
                        <RadioButton x:Name="UsageCreator"
                                     Content="Content Creation" GroupName="Usage"
                                     Click="UsageOption_Clicked" Tag="Content Creation"
                                     FontSize="14"/>
                    </StackPanel>
                </Border>

                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Back" Click="Back_Click" Padding="16,8"/>
                    <Button Grid.Column="2" Content="Next" Click="Next_Click"
                            Style="{ThemeResource AccentButtonStyle}" Padding="16,8"/>
                </Grid>
            </StackPanel>

            <!-- ── Step 2: Privacy preference ───────────────────────────────── -->
            <StackPanel Spacing="16"
                        Visibility="{x:Bind ViewModel.CurrentStep, Mode=OneWay,
                                     Converter={StaticResource EqualsToVisibility}, ConverterParameter=2}">
                <TextBlock Text="&#x1F512; Privacy preference"
                           FontSize="24" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                <TextBlock Text="Choose how much telemetry and tracking Windows should perform."
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap" TextAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                <Border CornerRadius="8" Padding="16"
                        Background="{ThemeResource LayerFillColorDefaultBrush}">
                    <StackPanel Spacing="10">
                        <RadioButton x:Name="PrivacyMax"
                                     Content="Maximum Privacy" GroupName="Privacy"
                                     Click="PrivacyOption_Clicked" Tag="Maximum Privacy"
                                     FontSize="14"/>
                        <RadioButton x:Name="PrivacyBalanced"
                                     Content="Balanced" GroupName="Privacy"
                                     Click="PrivacyOption_Clicked" Tag="Balanced"
                                     FontSize="14" IsChecked="True"/>
                        <RadioButton x:Name="PrivacyDefault"
                                     Content="Default" GroupName="Privacy"
                                     Click="PrivacyOption_Clicked" Tag="Default"
                                     FontSize="14"/>
                    </StackPanel>
                </Border>

                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Back" Click="Back_Click" Padding="16,8"/>
                    <Button Grid.Column="2" Content="Next" Click="Next_Click"
                            Style="{ThemeResource AccentButtonStyle}" Padding="16,8"/>
                </Grid>
            </StackPanel>

            <!-- ── Step 3: All set ───────────────────────────────────────────── -->
            <StackPanel Spacing="16"
                        Visibility="{x:Bind ViewModel.CurrentStep, Mode=OneWay,
                                     Converter={StaticResource EqualsToVisibility}, ConverterParameter=3}">
                <TextBlock Text="&#x2728;" FontSize="64" HorizontalAlignment="Center"/>
                <TextBlock Text="All set!"
                           FontSize="32" FontWeight="SemiBold" HorizontalAlignment="Center"/>

                <Border CornerRadius="8" Padding="20"
                        Background="{ThemeResource LayerFillColorDefaultBrush}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Based on your selections:"
                                   FontWeight="SemiBold" FontSize="14"/>
                        <TextBlock FontSize="13"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                            <Run Text="Usage profile: "/>
                            <Run Text="{x:Bind ViewModel.SelectedUsage, Mode=OneWay}"
                                 FontWeight="SemiBold"
                                 Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        </TextBlock>
                        <TextBlock FontSize="13"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                            <Run Text="Privacy level: "/>
                            <Run Text="{x:Bind ViewModel.SelectedPrivacy, Mode=OneWay}"
                                 FontWeight="SemiBold"
                                 Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        </TextBlock>
                        <TextBlock FontSize="12" Margin="0,8,0,0"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap">
                            You can fine-tune everything from the relevant pages. Visit Diagnostics anytime for a full system review.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Button Content="Open Dashboard"
                        Click="Finish_Click"
                        Style="{ThemeResource AccentButtonStyle}"
                        HorizontalAlignment="Center"
                        Padding="32,12"
                        FontSize="15"/>
            </StackPanel>

            <!-- ── Skip button (always visible) ─────────────────────────────── -->
            <Button Content="Skip Setup"
                    Click="Skip_Click"
                    HorizontalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

        </StackPanel>
    </ScrollViewer>
</Page>
