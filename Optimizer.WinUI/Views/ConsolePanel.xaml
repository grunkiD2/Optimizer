<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Optimizer.WinUI.Views.ConsolePanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Optimizer.WinUI.Converters"
    xmlns:tk="using:CommunityToolkit.WinUI.Controls"
    xmlns:m="using:Optimizer.WinUI.Models">

    <UserControl.Resources>
        <!-- BoolToVisibility is a global converter in App.xaml -->

        <!-- Breathing animation for the live-status dot -->
        <Storyboard x:Key="LivePulse" RepeatBehavior="Forever">
            <DoubleAnimation
                Storyboard.TargetName="LiveDot"
                Storyboard.TargetProperty="Opacity"
                From="1.0" To="0.3"
                Duration="0:0:1.4"
                AutoReverse="True">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Header: tab switcher + live dot + window controls ──────── -->
        <Grid Grid.Row="0" Height="44"
              BorderThickness="0,0,0,1"
              BorderBrush="{ThemeResource HudHairlineBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Tab switcher -->
            <tk:Segmented x:Name="ConsoleTabs" Grid.Column="0"
                          SelectedIndex="0"
                          SelectionChanged="ConsoleTabs_SelectionChanged"
                          VerticalAlignment="Center"
                          Margin="10,0,0,0">
                <tk:SegmentedItem Content="Activity"/>
                <tk:SegmentedItem Content="Assistant"/>
            </tk:Segmented>

            <!-- Live indicator + utility buttons -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2"
                        VerticalAlignment="Center" Margin="0,0,6,0">
                <Ellipse x:Name="LiveDot" Width="6" Height="6"
                         Fill="{StaticResource SuccessBrush}"
                         Margin="0,0,6,0"/>
                <Button x:Name="PopOutButton" Click="PopOut_Click"
                        ToolTipService.ToolTip="Pop out"
                        Padding="8,6">
                    <FontIcon Glyph="&#xE8A7;" FontSize="12"/>
                </Button>
                <Button x:Name="CollapseButton" Click="Collapse_Click"
                        ToolTipService.ToolTip="Hide console"
                        Padding="8,6">
                    <FontIcon Glyph="&#xE8BB;" FontSize="12"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ── Activity pane (default, monospace log) ────────────────── -->
        <Grid x:Name="PaneActivity" Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ListView Grid.Row="0"
                      x:Name="ActivityList"
                      ItemsSource="{x:Bind ConsoleVM.Lines}"
                      FontFamily="Consolas"
                      FontSize="11"
                      SelectionMode="None"
                      Padding="10,6"
                      HorizontalContentAlignment="Stretch"
                      ScrollViewer.VerticalScrollMode="Enabled"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      ScrollViewer.HorizontalScrollMode="Disabled"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="m:ConsoleLine">
                        <!-- Three-column grid: timestamp | glyph | message.
                             Message column is Width="*" so it wraps instead of
                             expanding horizontally and breaking the scroll. -->
                        <Grid ColumnSpacing="8">
                            <Grid.ContextFlyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Text="Kopiér linje" Tag="{x:Bind}" Click="ActivityCopyLine_Click"/>
                                    <MenuFlyoutItem Text="Kopiér alt" Click="ActivityCopyAll_Click"/>
                                    <MenuFlyoutItem Text="Gem log…" Click="ActivitySaveLog_Click"/>
                                </MenuFlyout>
                            </Grid.ContextFlyout>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{x:Bind TimeText}"
                                       Foreground="{StaticResource MutedBrush}"/>
                            <TextBlock Grid.Column="1" Text="{x:Bind Glyph}"/>
                            <TextBlock Grid.Column="2" Text="{x:Bind Text}"
                                       TextWrapping="Wrap"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <Border Grid.Row="1"
                    BorderThickness="0,1,0,0"
                    BorderBrush="{ThemeResource HudHairlineBrush}"
                    Padding="10,4">
                <Button Content="Clear"
                        Command="{x:Bind ConsoleVM.ClearCommand}"
                        HorizontalAlignment="Right"/>
            </Border>
        </Grid>

        <!-- ── Assistant pane (AI chat) ──────────────────────────────── -->
        <Grid x:Name="PaneAssistant" Grid.Row="1" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ListView Grid.Row="0"
                      x:Name="AssistantList"
                      ItemsSource="{x:Bind AssistantVM.Messages}"
                      SelectionMode="None"
                      Padding="10,6"
                      HorizontalContentAlignment="Stretch"
                      ScrollViewer.VerticalScrollMode="Enabled"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      ScrollViewer.HorizontalScrollMode="Disabled"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="m:ChatMessage">
                        <TextBlock Text="{x:Bind Text, Mode=OneWay}"
                                   TextWrapping="Wrap" Margin="0,2"
                                   IsTextSelectionEnabled="True">
                            <TextBlock.ContextFlyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Text="Kopiér besked" Tag="{x:Bind}" Click="ChatCopy_Click"/>
                                    <MenuFlyoutItem Text="Kopiér alt" Click="ChatCopyAll_Click"/>
                                </MenuFlyout>
                            </TextBlock.ContextFlyout>
                        </TextBlock>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Feedback bar — visible only after a tool-using turn -->
            <StackPanel Grid.Row="1"
                        Orientation="Horizontal" Spacing="6" Padding="10,4"
                        Visibility="{x:Bind AssistantVM.CanRateLastTurn, Mode=OneWay}"
                        BorderThickness="0,1,0,0"
                        BorderBrush="{ThemeResource HudHairlineBrush}">
                <TextBlock Text="Was that helpful?" VerticalAlignment="Center" FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <Button Content="👍" Padding="6,2"
                        Command="{x:Bind AssistantVM.RateUpCommand}"
                        ToolTipService.ToolTip="Yes, helpful"/>
                <Button Content="👎" Padding="6,2"
                        Command="{x:Bind AssistantVM.RateDownCommand}"
                        ToolTipService.ToolTip="No, not helpful"/>
            </StackPanel>

            <!-- Input row -->
            <Grid Grid.Row="2" Padding="8"
                  BorderThickness="0,1,0,0"
                  BorderBrush="{ThemeResource HudHairlineBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" x:Name="InputBox"
                         Text="{x:Bind AssistantVM.Input, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="Ask the assistant…"
                         KeyDown="Input_KeyDown"/>
                <Button Grid.Column="1" Content="Send" Margin="8,0,0,0"
                        Command="{x:Bind AssistantVM.SendCommand}"/>
            </Grid>
        </Grid>

        <!-- "Output" tab existed here as a placeholder during the IA redesign — removed
             2026-06-04 once it became clear that Activity (Engine/EventBus log) already
             carries all the surfaces the user needs to see. Add a third tab back when
             there's genuinely-different content to show (e.g., raw stdout from a long-
             running cleanup script). -->
    </Grid>
</UserControl>
