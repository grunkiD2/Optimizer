<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Optimizer.WinUI.Views.StoragePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Optimizer.WinUI.Controls"
    xmlns:hud="using:Optimizer.WinUI.Controls.Hud"
    xmlns:vm="using:Optimizer.WinUI.ViewModels"
    xmlns:svc="using:Optimizer.WinUI.Services"
    xmlns:models="using:Optimizer.WinUI.Models"
    xmlns:converters="using:Optimizer.WinUI.Converters"
    Background="Transparent"
    Loaded="Page_Loaded">

    <Page.Resources>
        <converters:HealthScoreToColorConverter x:Key="HealthScoreToColor"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:BytesToStringConverter x:Key="BytesToString"/>
    </Page.Resources>

    <hud:HudBackdrop>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16" Padding="24,16,24,24">
            <StackPanel.ChildrenTransitions>
                <TransitionCollection>
                    <EntranceThemeTransition FromVerticalOffset="20"/>
                </TransitionCollection>
            </StackPanel.ChildrenTransitions>

            <!-- ── Page header ──────────────────────────────────────────── -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: icon + title + subtitle -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <TextBlock Text="{x:Bind ViewModel.CategoryIcon}"
                               FontSize="28" VerticalAlignment="Center"/>
                    <StackPanel Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="{x:Bind ViewModel.CategoryName}"
                                   Style="{StaticResource TitleTextBlockStyle}"/>
                        <TextBlock FontSize="12"
                                   Foreground="{StaticResource MutedBrush}">
                            <Run Text="{x:Bind ViewModel.ActiveCount, Mode=OneWay}"/>
                            <Run Text=" of "/>
                            <Run Text="{x:Bind ViewModel.TotalCount, Mode=OneWay}"/>
                            <Run Text=" optimizations active"/>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>

                <!-- Right: action buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button Content="Apply All"
                            Style="{StaticResource AccentButtonStyle}"
                            Command="{x:Bind ViewModel.ApplyAllCommand}"/>
                    <Button Content="Undo Category"
                            Command="{x:Bind ViewModel.UndoCategoryCommand}"/>
                </StackPanel>
            </Grid>

            <!-- ── Local metrics strip ──────────────────────────────────── -->
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Temp Folder Size -->
                <Border Grid.Column="0" CornerRadius="8" Padding="16,12" Background="{ThemeResource HudSurfaceAltBrush}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Temp Folder" FontSize="12" Foreground="#F59E0B"/>
                        <TextBlock Text="{x:Bind ViewModel.DiskUsageText, Mode=OneWay}"
                                   FontSize="22" FontWeight="Bold" FontFamily="Consolas"/>
                        <TextBlock Text="reclaimable space" FontSize="11"
                                   Foreground="{StaticResource MutedBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Optimizations Active -->
                <Border Grid.Column="1" CornerRadius="8" Padding="16,12" Background="{ThemeResource HudSurfaceAltBrush}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Optimizations" FontSize="12" Foreground="#A78BFA"/>
                        <TextBlock FontSize="22" FontWeight="Bold" FontFamily="Consolas">
                            <Run Text="{x:Bind ViewModel.ActiveCount, Mode=OneWay}"/>
                            <Run Text=" / "/>
                            <Run Text="{x:Bind ViewModel.TotalCount, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Text="active" FontSize="11"
                                   Foreground="{StaticResource MutedBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Total Recoverable -->
                <Border Grid.Column="2" CornerRadius="8" Padding="16,12" Background="{ThemeResource HudSurfaceAltBrush}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Recoverable" FontSize="12" Foreground="#34D399"/>
                        <TextBlock Text="{x:Bind ViewModel.TotalRecoverableText, Mode=OneWay}"
                                   FontSize="22" FontWeight="Bold" FontFamily="Consolas"/>
                        <TextBlock Text="cleanup selected" FontSize="11"
                                   Foreground="{StaticResource MutedBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!--  SMART CLEANUP                                             -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <Grid Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="SMART CLEANUP"
                           FontSize="11" FontWeight="SemiBold" CharacterSpacing="100"
                           Foreground="{StaticResource MutedBrush}"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button Content="Scan"
                            Command="{x:Bind ViewModel.ScanCleanupCommand}"
                            IsEnabled="{x:Bind ViewModel.IsNotScanningCleanup, Mode=OneWay}"/>
                    <Button Content="Clean Selected"
                            Style="{StaticResource AccentButtonStyle}"
                            Command="{x:Bind ViewModel.CleanSelectedCommand}"
                            IsEnabled="{x:Bind ViewModel.IsNotScanningCleanup, Mode=OneWay}"/>
                </StackPanel>
            </Grid>

            <!-- Cleanup progress -->
            <ProgressBar IsIndeterminate="True"
                         Visibility="{x:Bind ViewModel.IsScanningCleanup, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>
            <TextBlock Text="{x:Bind ViewModel.CleanupProgress, Mode=OneWay}"
                       FontSize="12"
                       Foreground="{StaticResource MutedBrush}"
                       Visibility="{x:Bind ViewModel.HasCleanupProgress, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>

            <!-- Cleanup category list -->
            <ItemsRepeater ItemsSource="{x:Bind ViewModel.CleanupCategories, Mode=OneWay}">
                <ItemsRepeater.Layout>
                    <StackLayout Orientation="Vertical" Spacing="4"/>
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="svc:CleanupCategory">
                        <Border Background="{ThemeResource HudSurfaceAltBrush}"
                                CornerRadius="8" Padding="14,10"
                                BorderBrush="{ThemeResource HudHairlineBrush}" BorderThickness="1">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <CheckBox Grid.Column="0"
                                          IsChecked="{x:Bind Selected, Mode=TwoWay}"
                                          VerticalAlignment="Center"/>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock Text="{x:Bind Description}" FontSize="11"
                                               Foreground="{StaticResource MutedBrush}"/>
                                </StackPanel>

                                <Border Grid.Column="2" CornerRadius="4" Padding="10,4" VerticalAlignment="Center"
                                        Background="{ThemeResource HudSurfaceAltBrush}">
                                    <TextBlock FontSize="13" FontWeight="SemiBold" FontFamily="Consolas"
                                               Text="{x:Bind SizeBytes, Converter={StaticResource BytesToString}}"/>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!--  LARGE FILES FINDER                                        -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <Grid Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="LARGE FILES FINDER"
                           FontSize="11" FontWeight="SemiBold" CharacterSpacing="100"
                           Foreground="{StaticResource MutedBrush}"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        Content="Scan System Drive"
                        Command="{x:Bind ViewModel.ScanLargeFilesCommand}"
                        IsEnabled="{x:Bind ViewModel.IsNotScanningLargeFiles, Mode=OneWay}"/>
            </Grid>

            <!-- Large files progress -->
            <ProgressBar IsIndeterminate="True"
                         Visibility="{x:Bind ViewModel.IsScanningLargeFiles, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>
            <TextBlock Text="{x:Bind ViewModel.LargeFilesProgress, Mode=OneWay}"
                       FontSize="12"
                       Foreground="{StaticResource MutedBrush}"
                       Visibility="{x:Bind ViewModel.HasLargeFilesProgress, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>

            <!-- Large files list -->
            <ItemsRepeater ItemsSource="{x:Bind ViewModel.LargeFiles, Mode=OneWay}"
                           Visibility="{x:Bind ViewModel.HasLargeFiles, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                <ItemsRepeater.Layout>
                    <StackLayout Orientation="Vertical" Spacing="4"/>
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="svc:LargeFile">
                        <Border Background="{ThemeResource HudSurfaceAltBrush}"
                                CornerRadius="8" Padding="14,10"
                                BorderBrush="{ThemeResource HudHairlineBrush}" BorderThickness="1">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind FileName}" FontWeight="SemiBold" FontSize="13"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTipService.ToolTip="{x:Bind FileName}"/>
                                    <TextBlock Text="{x:Bind FullPath}" FontSize="11"
                                               Foreground="{StaticResource MutedBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTipService.ToolTip="{x:Bind FullPath}"/>
                                </StackPanel>

                                <Border Grid.Column="1" CornerRadius="4" Padding="10,4" VerticalAlignment="Center"
                                        Background="{ThemeResource HudSurfaceAltBrush}">
                                    <TextBlock FontSize="13" FontWeight="SemiBold" FontFamily="Consolas"
                                               Text="{x:Bind SizeBytes, Converter={StaticResource BytesToString}}"/>
                                </Border>

                                <Button Grid.Column="2"
                                        Content="Open Location"
                                        VerticalAlignment="Center"
                                        Click="LargeFileOpenLocation_Click"
                                        Tag="{x:Bind FullPath}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

            <!-- ── Disk Health ──────────────────────────────────────────── -->
            <TextBlock Text="DISK HEALTH" FontSize="11" FontWeight="SemiBold"
                       Foreground="{StaticResource MutedBrush}" Margin="0,16,0,8"/>

            <ProgressRing IsActive="{x:Bind ViewModel.IsLoadingDisks, Mode=OneWay}"
                          Width="32" Height="32"
                          HorizontalAlignment="Left"
                          Visibility="{x:Bind ViewModel.IsLoadingDisks, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>

            <ItemsRepeater ItemsSource="{x:Bind ViewModel.Disks, Mode=OneWay}">
                <ItemsRepeater.Layout>
                    <StackLayout Orientation="Vertical" Spacing="8"/>
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="models:DiskHealthInfo">
                        <Border Background="{ThemeResource HudSurfaceAltBrush}"
                                CornerRadius="8" Padding="14,12"
                                BorderBrush="{ThemeResource HudHairlineBrush}" BorderThickness="1">
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{x:Bind Model}" FontWeight="SemiBold"/>
                                    <TextBlock FontSize="11" Foreground="{StaticResource MutedBrush}">
                                        <Run Text="{x:Bind BusType}"/><Run Text=" · "/><Run Text="{x:Bind MediaType}"/><Run Text=" · "/><Run Text="{x:Bind SizeText}"/>
                                    </TextBlock>
                                </StackPanel>
                                <StackPanel Grid.Column="1" MinWidth="80">
                                    <TextBlock Text="Temperature" FontSize="10" Foreground="{StaticResource MutedBrush}"/>
                                    <TextBlock Text="{x:Bind TemperatureText}" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" MinWidth="120">
                                    <TextBlock Text="Life Remaining" FontSize="10" Foreground="{StaticResource MutedBrush}"/>
                                    <TextBlock Text="{x:Bind WearText}" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="3" MinWidth="100">
                                    <TextBlock Text="Power-On" FontSize="10" Foreground="{StaticResource MutedBrush}"/>
                                    <TextBlock Text="{x:Bind PowerOnText}" FontWeight="SemiBold"/>
                                </StackPanel>
                                <Border Grid.Column="4" CornerRadius="4" Padding="8,3" VerticalAlignment="Center"
                                        Background="{x:Bind HealthScore, Converter={StaticResource HealthScoreToColor}}">
                                    <TextBlock Text="{x:Bind HealthBadge}" FontSize="11" FontWeight="Bold" Foreground="White"/>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

            <!-- ── Disk Repair ─────────────────────────────────────────── -->
            <TextBlock Text="DISK REPAIR" FontSize="11" FontWeight="SemiBold"
                       Foreground="{StaticResource MutedBrush}" Margin="0,16,0,8"/>

            <Border Background="{ThemeResource HudSurfaceAltBrush}"
                    CornerRadius="8" Padding="14"
                    BorderBrush="{ThemeResource HudHairlineBrush}" BorderThickness="1">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="4">
                        <TextBlock Text="CHKDSK" FontWeight="SemiBold"/>
                        <TextBlock Text="Check and repair file system errors. Will schedule for next boot."
                                   FontSize="11"
                                   Foreground="{StaticResource MutedBrush}"/>
                    </StackPanel>
                    <ComboBox Grid.Column="1" x:Name="DriveSelector" MinWidth="80"
                              VerticalAlignment="Center">
                        <ComboBoxItem Content="C:" IsSelected="True"/>
                        <ComboBoxItem Content="D:"/>
                        <ComboBoxItem Content="E:"/>
                        <ComboBoxItem Content="F:"/>
                    </ComboBox>
                    <Button Grid.Column="2" Content="Schedule CHKDSK"
                            Click="RunChkdsk_Click" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- ── Optimization cards ───────────────────────────────────── -->
            <TextBlock Text="Optimizations"
                       FontSize="16" FontWeight="SemiBold"
                       Margin="0,8,0,0"/>

            <ItemsRepeater x:Name="OptimizationsRepeater"
                           ItemsSource="{x:Bind ViewModel.Optimizations, Mode=OneWay}">
                <ItemsRepeater.Layout>
                    <StackLayout Orientation="Vertical" Spacing="0"/>
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="vm:OptimizationCardModel">
                        <controls:OptimizationCard
                            Tag="{x:Bind Id}"
                            Loaded="OptimizationCard_Loaded"/>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

        </StackPanel>
    </ScrollViewer>
    </hud:HudBackdrop>
</Page>
