<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Optimizer.WinUI.Views.StoragePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Optimizer.WinUI.Controls"
    xmlns:vm="using:Optimizer.WinUI.ViewModels"
    xmlns:models="using:Optimizer.WinUI.Models"
    xmlns:converters="using:Optimizer.WinUI.Converters"
    Background="Transparent"
    Loaded="Page_Loaded">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16" Padding="24,16,24,24">

            <StackPanel.Resources>
                <converters:HealthScoreToColorConverter x:Key="HealthScoreToColor"/>
                <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
            </StackPanel.Resources>

            <!-- ── Page header ──────────────────────────────────────────── -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: icon + title + subtitle -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <TextBlock Text="{x:Bind ViewModel.CategoryIcon}"
                               FontSize="28" VerticalAlignment="Center"/>
                    <StackPanel Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="{x:Bind ViewModel.CategoryName}"
                                   Style="{StaticResource TitleTextBlockStyle}"/>
                        <TextBlock FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                            <Run Text="{x:Bind ViewModel.ActiveCount, Mode=OneWay}"/>
                            <Run Text=" of "/>
                            <Run Text="{x:Bind ViewModel.TotalCount, Mode=OneWay}"/>
                            <Run Text=" optimizations active"/>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>

                <!-- Right: action buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button Content="Apply All"
                            Style="{StaticResource AccentButtonStyle}"
                            Command="{x:Bind ViewModel.ApplyAllCommand}"/>
                    <Button Content="Undo Category"
                            Command="{x:Bind ViewModel.UndoCategoryCommand}"/>
                </StackPanel>
            </Grid>

            <!-- ── Local metrics strip ──────────────────────────────────── -->
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Temp Folder Size -->
                <Border Grid.Column="0" CornerRadius="8" Padding="16,12" Background="{ThemeResource LayerFillColorDefaultBrush}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Temp Folder" FontSize="12" Foreground="#F59E0B"/>
                        <TextBlock Text="{x:Bind ViewModel.DiskUsageText, Mode=OneWay}"
                                   FontSize="22" FontWeight="Bold" FontFamily="Consolas"/>
                        <TextBlock Text="reclaimable space" FontSize="11"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Optimizations Active -->
                <Border Grid.Column="1" CornerRadius="8" Padding="16,12" Background="{ThemeResource LayerFillColorDefaultBrush}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Optimizations" FontSize="12" Foreground="#A78BFA"/>
                        <TextBlock FontSize="22" FontWeight="Bold" FontFamily="Consolas">
                            <Run Text="{x:Bind ViewModel.ActiveCount, Mode=OneWay}"/>
                            <Run Text=" / "/>
                            <Run Text="{x:Bind ViewModel.TotalCount, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Text="active" FontSize="11"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Placeholder -->
                <Border Grid.Column="2" CornerRadius="8" Padding="16,12" Background="{ThemeResource LayerFillColorDefaultBrush}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Cache" FontSize="12" Foreground="#34D399"/>
                        <TextBlock Text="Windows" FontSize="22" FontWeight="Bold" FontFamily="Consolas"/>
                        <TextBlock Text="update cache" FontSize="11"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── Disk Health ──────────────────────────────────────────── -->
            <TextBlock Text="DISK HEALTH" FontSize="11" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,16,0,8"/>

            <ProgressRing IsActive="{x:Bind ViewModel.IsLoadingDisks, Mode=OneWay}"
                          Width="32" Height="32"
                          HorizontalAlignment="Left"
                          Visibility="{x:Bind ViewModel.IsLoadingDisks, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>

            <ItemsRepeater ItemsSource="{x:Bind ViewModel.Disks, Mode=OneWay}">
                <ItemsRepeater.Layout>
                    <StackLayout Orientation="Vertical" Spacing="8"/>
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="models:DiskHealthInfo">
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="8" Padding="14,12"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{x:Bind Model}" FontWeight="SemiBold"/>
                                    <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                        <Run Text="{x:Bind BusType}"/><Run Text=" · "/><Run Text="{x:Bind MediaType}"/><Run Text=" · "/><Run Text="{x:Bind SizeText}"/>
                                    </TextBlock>
                                </StackPanel>
                                <StackPanel Grid.Column="1" MinWidth="80">
                                    <TextBlock Text="Temperature" FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="{x:Bind TemperatureText}" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" MinWidth="120">
                                    <TextBlock Text="Life Remaining" FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="{x:Bind WearText}" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="3" MinWidth="100">
                                    <TextBlock Text="Power-On" FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="{x:Bind PowerOnText}" FontWeight="SemiBold"/>
                                </StackPanel>
                                <Border Grid.Column="4" CornerRadius="4" Padding="8,3" VerticalAlignment="Center"
                                        Background="{x:Bind HealthScore, Converter={StaticResource HealthScoreToColor}}">
                                    <TextBlock Text="{x:Bind HealthBadge}" FontSize="11" FontWeight="Bold" Foreground="White"/>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

            <!-- ── Optimization cards ───────────────────────────────────── -->
            <TextBlock Text="Optimizations"
                       FontSize="16" FontWeight="SemiBold"
                       Margin="0,8,0,0"/>

            <ItemsRepeater x:Name="OptimizationsRepeater"
                           ItemsSource="{x:Bind ViewModel.Optimizations, Mode=OneWay}">
                <ItemsRepeater.Layout>
                    <StackLayout Orientation="Vertical" Spacing="0"/>
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="vm:OptimizationCardModel">
                        <controls:OptimizationCard
                            Tag="{x:Bind Id}"
                            Loaded="OptimizationCard_Loaded"/>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

        </StackPanel>
    </ScrollViewer>
</Page>
