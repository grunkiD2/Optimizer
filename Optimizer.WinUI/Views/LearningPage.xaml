<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Optimizer.WinUI.Views.LearningPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Optimizer.WinUI.Converters"
    xmlns:hud="using:Optimizer.WinUI.Controls.Hud"
    xmlns:vm="using:Optimizer.WinUI.ViewModels"
    Background="Transparent"
    Loaded="Page_Loaded">

    <!-- BoolToVisibility is a global converter in App.xaml -->


    <hud:HudBackdrop>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16" Padding="24,16,24,24">
            <StackPanel.ChildrenTransitions>
                <TransitionCollection>
                    <EntranceThemeTransition FromVerticalOffset="20"/>
                </TransitionCollection>
            </StackPanel.ChildrenTransitions>

            <!-- Header -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <TextBlock Text="{x:Bind ViewModel.CategoryIcon}" FontSize="28" VerticalAlignment="Center"/>
                    <StackPanel Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="{x:Bind ViewModel.CategoryName}" Style="{StaticResource TitleTextBlockStyle}"/>
                        <TextBlock FontSize="12" Foreground="{StaticResource MutedBrush}">
                            <Run Text="Current context: "/>
                            <Run Text="{x:Bind ViewModel.CurrentContext, Mode=OneWay}"/>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button Content="Refresh" Click="Refresh_Click"/>
                    <Button Content="Export Report" Click="ExportReport_Click"/>
                </StackPanel>
            </Grid>

            <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" FontSize="12"
                       Foreground="{StaticResource MutedBrush}"
                       Visibility="{x:Bind ViewModel.HasStatusMessage, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>

            <ProgressBar IsIndeterminate="True"
                         Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>

            <!-- Predictive alerts -->
            <TextBlock Text="Maintenance Alerts" Style="{StaticResource SubtitleTextBlockStyle}"/>
            <TextBlock Text="No active alerts — everything looks healthy." FontSize="12"
                       Foreground="{StaticResource MutedBrush}"
                       Visibility="{x:Bind ViewModel.NoAlerts, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>
            <ItemsRepeater ItemsSource="{x:Bind ViewModel.Alerts, Mode=OneWay}">
                <ItemsRepeater.Layout><StackLayout Orientation="Vertical" Spacing="6"/></ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="vm:AlertRow">
                        <Border CornerRadius="8" Padding="14,10" BorderThickness="1"
                                BorderBrush="{ThemeResource HudHairlineBrush}"
                                Background="{ThemeResource HudSurfaceAltBrush}">
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#EF4444" CornerRadius="4" Padding="7,3" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind Severity}" FontSize="10" Foreground="White" FontWeight="SemiBold"/>
                                </Border>
                                <TextBlock Grid.Column="1" Text="{x:Bind Message}" TextWrapping="Wrap" VerticalAlignment="Center" FontSize="13"/>
                                <Button Grid.Column="2" Content="Dismiss" Tag="{x:Bind}" Click="AcknowledgeAlert_Click" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

            <!-- Automation suggestions -->
            <TextBlock Text="Automation Suggestions" Style="{StaticResource SubtitleTextBlockStyle}"/>
            <TextBlock Text="No suggestions yet — keep using profiles and Optimizer will spot your routines." FontSize="12"
                       Foreground="{StaticResource MutedBrush}"
                       Visibility="{x:Bind ViewModel.NoSuggestions, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>
            <ItemsRepeater ItemsSource="{x:Bind ViewModel.Suggestions, Mode=OneWay}">
                <ItemsRepeater.Layout><StackLayout Orientation="Vertical" Spacing="6"/></ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="vm:SuggestionRow">
                        <Border CornerRadius="8" Padding="14,10" BorderThickness="1"
                                BorderBrush="{ThemeResource HudHairlineBrush}"
                                Background="{ThemeResource HudSurfaceAltBrush}">
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind ProfileName}" FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock Text="{x:Bind Trigger}" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                                    <TextBlock Text="{x:Bind Reasoning}" FontSize="11" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{x:Bind Confidence}" FontSize="12" VerticalAlignment="Center"
                                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                <Button Grid.Column="2" Content="Accept" Tag="{x:Bind}" Click="AcceptSuggestion_Click" VerticalAlignment="Center"/>
                                <Button Grid.Column="3" Content="Dismiss" Tag="{x:Bind}" Click="RejectSuggestion_Click" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

            <!-- Top tools -->
            <TextBlock Text="Most-used Tools" Style="{StaticResource SubtitleTextBlockStyle}"/>
            <TextBlock Text="No tool activity recorded yet." FontSize="12"
                       Foreground="{StaticResource MutedBrush}"
                       Visibility="{x:Bind ViewModel.NoTools, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>
            <ItemsRepeater ItemsSource="{x:Bind ViewModel.TopTools, Mode=OneWay}">
                <ItemsRepeater.Layout><StackLayout Orientation="Vertical" Spacing="4"/></ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="vm:ToolMetricRow">
                        <Border CornerRadius="8" Padding="12,8" BorderThickness="1"
                                BorderBrush="{ThemeResource HudHairlineBrush}"
                                Background="{ThemeResource HudSurfaceAltBrush}">
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind ToolId}" FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock Text="{x:Bind Context}" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{x:Bind SuccessRate}" FontSize="13" VerticalAlignment="Center"
                                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                <TextBlock Grid.Column="2" FontSize="11" VerticalAlignment="Center"
                                           Foreground="{StaticResource MutedBrush}">
                                    <Run Text="{x:Bind Invocations}"/><Run Text="×"/>
                                </TextBlock>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

            <!-- Learned patterns -->
            <TextBlock Text="Learned Patterns" Style="{StaticResource SubtitleTextBlockStyle}"/>
            <TextBlock Text="No patterns mined yet." FontSize="12"
                       Foreground="{StaticResource MutedBrush}"
                       Visibility="{x:Bind ViewModel.NoPatterns, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>
            <ItemsRepeater ItemsSource="{x:Bind ViewModel.Patterns, Mode=OneWay}">
                <ItemsRepeater.Layout><StackLayout Orientation="Vertical" Spacing="4"/></ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="vm:PatternRow">
                        <Border CornerRadius="8" Padding="12,8" BorderThickness="1"
                                BorderBrush="{ThemeResource HudHairlineBrush}"
                                Background="{ThemeResource HudSurfaceAltBrush}">
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{x:Bind Description}" FontSize="13" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                <TextBlock Grid.Column="1" Text="{x:Bind SuccessRate}" FontSize="13" VerticalAlignment="Center"
                                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                <TextBlock Grid.Column="2" FontSize="11" VerticalAlignment="Center"
                                           Foreground="{StaticResource MutedBrush}">
                                    <Run Text="{x:Bind ObservedCount}"/><Run Text="×"/>
                                </TextBlock>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

        </StackPanel>
    </ScrollViewer>
    </hud:HudBackdrop>
</Page>
