<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Optimizer.WinUI.Views.SystemPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Optimizer.WinUI.Controls"
    xmlns:hud="using:Optimizer.WinUI.Controls.Hud"
    xmlns:vm="using:Optimizer.WinUI.ViewModels"
    xmlns:services="using:Optimizer.WinUI.Services"
    xmlns:converters="using:Optimizer.WinUI.Converters"
    Background="Transparent"
    Loaded="Page_Loaded">

    <Page.Resources>
        <converters:BoolToInfoBarSeverityConverter x:Key="BoolToInfoBarSeverity"/>
    </Page.Resources>

    <hud:HudBackdrop>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16" Padding="24,16,24,24">

            <!-- ── Page header ──────────────────────────────────────────── -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: icon + title + subtitle -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <TextBlock Text="{x:Bind ViewModel.CategoryIcon}"
                               FontSize="28" VerticalAlignment="Center"/>
                    <StackPanel Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="{x:Bind ViewModel.CategoryName}"
                                   Style="{StaticResource TitleTextBlockStyle}"/>
                        <TextBlock FontSize="12"
                                   Foreground="{StaticResource MutedBrush}">
                            <Run Text="{x:Bind ViewModel.ActiveCount, Mode=OneWay}"/>
                            <Run Text=" of "/>
                            <Run Text="{x:Bind ViewModel.TotalCount, Mode=OneWay}"/>
                            <Run Text=" optimizations active"/>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>

                <!-- Right: action buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button Content="Apply All"
                            Style="{StaticResource AccentButtonStyle}"
                            Command="{x:Bind ViewModel.ApplyAllCommand}"/>
                    <Button Content="Undo Category"
                            Command="{x:Bind ViewModel.UndoCategoryCommand}"/>
                </StackPanel>
            </Grid>

            <!-- Audit Batch 2: privacy/optimization results are no longer silent. -->
            <InfoBar IsOpen="{x:Bind ViewModel.HasStatus, Mode=OneWay}"
                     Message="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                     Severity="{x:Bind ViewModel.StatusIsError, Mode=OneWay, Converter={StaticResource BoolToInfoBarSeverity}}"
                     IsClosable="True"/>

            <!-- ── Local metrics strip ──────────────────────────────────── -->
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Telemetry Status -->
                <Border Grid.Column="0" CornerRadius="8" Padding="16,12" Background="{ThemeResource HudSurfaceAltBrush}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Telemetry" FontSize="12" Foreground="#F87171"/>
                        <TextBlock Text="{x:Bind ViewModel.TelemetryStatus, Mode=OneWay}"
                                   FontSize="22" FontWeight="Bold" FontFamily="Consolas"/>
                        <TextBlock Text="data collection" FontSize="11"
                                   Foreground="{StaticResource MutedBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Optimizations Active -->
                <Border Grid.Column="1" CornerRadius="8" Padding="16,12" Background="{ThemeResource HudSurfaceAltBrush}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Optimizations" FontSize="12" Foreground="#A78BFA"/>
                        <TextBlock FontSize="22" FontWeight="Bold" FontFamily="Consolas">
                            <Run Text="{x:Bind ViewModel.ActiveCount, Mode=OneWay}"/>
                            <Run Text=" / "/>
                            <Run Text="{x:Bind ViewModel.TotalCount, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Text="active" FontSize="11"
                                   Foreground="{StaticResource MutedBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Privacy score (Batch 4a: was a hardcoded "Sleep" placeholder) -->
                <Border Grid.Column="2" CornerRadius="8" Padding="16,12" Background="{ThemeResource HudSurfaceAltBrush}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Privacy Score" FontSize="12" Foreground="#34D399"/>
                        <TextBlock Text="{x:Bind ViewModel.PrivacyScoreText, Mode=OneWay}"
                                   FontSize="22" FontWeight="Bold" FontFamily="Consolas"/>
                        <TextBlock Text="privacy-friendly settings" FontSize="11"
                                   Foreground="{StaticResource MutedBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── Optimization cards ───────────────────────────────────── -->
            <TextBlock Text="Optimizations"
                       FontSize="16" FontWeight="SemiBold"
                       Margin="0,8,0,0"/>

            <ItemsRepeater x:Name="OptimizationsRepeater"
                           ItemsSource="{x:Bind ViewModel.Optimizations, Mode=OneWay}">
                <ItemsRepeater.Layout>
                    <StackLayout Orientation="Vertical" Spacing="0"/>
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="vm:OptimizationCardModel">
                        <controls:OptimizationCard
                            Tag="{x:Bind Id}"
                            Loaded="OptimizationCard_Loaded"/>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

            <!-- ── System Integrity ────────────────────────────────────── -->
            <TextBlock Text="SYSTEM INTEGRITY"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="{StaticResource MutedBrush}"
                       Margin="0,16,0,8"/>

            <Border Background="{ThemeResource HudSurfaceAltBrush}"
                    CornerRadius="8" Padding="14"
                    BorderBrush="{ThemeResource HudHairlineBrush}" BorderThickness="1">
                <StackPanel Spacing="12">
                    <!-- SFC -->
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="4">
                            <TextBlock Text="System File Checker (SFC)" FontWeight="SemiBold"/>
                            <TextBlock Text="Scans and repairs corrupted Windows system files (5-10 min)"
                                       FontSize="11"
                                       Foreground="{StaticResource MutedBrush}"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Run SFC"
                                Click="RunSfc_Click" VerticalAlignment="Center"/>
                    </Grid>
                    <!-- DISM -->
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="4">
                            <TextBlock Text="DISM Repair Image" FontWeight="SemiBold"/>
                            <TextBlock Text="Repairs Windows component store (run before SFC for best results)"
                                       FontSize="11"
                                       Foreground="{StaticResource MutedBrush}"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Run DISM"
                                Click="RunDism_Click" VerticalAlignment="Center"/>
                    </Grid>
                    <!-- Progress output -->
                    <TextBlock x:Name="RepairProgressText"
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="11" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- ── Privacy Dashboard ────────────────────────────────────── -->
            <TextBlock Text="PRIVACY DASHBOARD"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="{StaticResource MutedBrush}"
                       Margin="0,16,0,8"/>

            <Grid Margin="0,0,0,12" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Background="{ThemeResource HudSurfaceAltBrush}"
                        CornerRadius="8" Padding="20" MinWidth="140"
                        BorderBrush="{ThemeResource HudHairlineBrush}" BorderThickness="1">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Privacy Score" FontSize="11"
                                   Foreground="{StaticResource MutedBrush}"/>
                        <TextBlock Text="{x:Bind ViewModel.PrivacyScoreText, Mode=OneWay}"
                                   FontSize="32" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <TextBlock Grid.Column="1" VerticalAlignment="Center" TextWrapping="Wrap"
                           Text="Toggle each setting to enable privacy-friendly mode. ON = privacy enabled."
                           Foreground="{StaticResource MutedBrush}"/>
            </Grid>

            <ItemsRepeater ItemsSource="{x:Bind ViewModel.PrivacySettings, Mode=OneWay}">
                <ItemsRepeater.Layout>
                    <StackLayout Orientation="Vertical" Spacing="4"/>
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="services:PrivacySetting">
                        <Border Background="{ThemeResource HudSurfaceAltBrush}"
                                CornerRadius="8" Padding="14,10"
                                BorderBrush="{ThemeResource HudHairlineBrush}" BorderThickness="1">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{x:Bind Description}" FontSize="11"
                                               Foreground="{StaticResource MutedBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1" IsOn="{x:Bind IsPrivacyFriendly, Mode=OneWay}"
                                              Toggled="PrivacyToggle_Toggled" Tag="{x:Bind Id}"
                                              VerticalAlignment="Center" MinWidth="0"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

        </StackPanel>
    </ScrollViewer>
    </hud:HudBackdrop>
</Page>
