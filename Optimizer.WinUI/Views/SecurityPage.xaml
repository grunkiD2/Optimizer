<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Optimizer.WinUI.Views.SecurityPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Optimizer.WinUI.Converters"
    xmlns:hud="using:Optimizer.WinUI.Controls.Hud"
    xmlns:vm="using:Optimizer.WinUI.ViewModels"
    xmlns:models="using:Optimizer.WinUI.Models"
    Background="Transparent"
    Loaded="Page_Loaded">

    <Page.Resources>
        <converters:StringToSolidColorBrushConverter x:Key="StringToBrush"/>
    </Page.Resources>

    <hud:HudBackdrop>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16" Padding="24,16,24,24">

            <!-- ── Page header ───────────────────────────────────────────────── -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <TextBlock Text="{x:Bind ViewModel.CategoryIcon}"
                               FontSize="28" VerticalAlignment="Center"/>
                    <StackPanel Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="{x:Bind ViewModel.CategoryName}"
                                   Style="{StaticResource TitleTextBlockStyle}"/>
                        <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                                   FontSize="12"
                                   Foreground="{StaticResource MutedBrush}"/>
                    </StackPanel>
                </StackPanel>

                <Button Grid.Column="1" Content="Refresh" VerticalAlignment="Center"
                        Click="Refresh_Click"/>
            </Grid>

            <!-- ── Loading indicator ────────────────────────────────────────── -->
            <ProgressBar IsIndeterminate="True"
                         Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>

            <!-- ═══════════════════════════════════════════════════════════════ -->
            <!--  SECTION 1 — Security Score                                   -->
            <!-- ═══════════════════════════════════════════════════════════════ -->
            <Border Background="{ThemeResource HudSurfaceAltBrush}"
                    BorderBrush="{ThemeResource HudHairlineBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Score circle -->
                    <Border Grid.Column="0"
                            Width="100" Height="100"
                            CornerRadius="50"
                            Margin="0,0,24,0"
                            BorderThickness="4"
                            BorderBrush="{x:Bind ViewModel.ScoreForeground, Mode=OneWay, Converter={StaticResource StringToBrush}}">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="2">
                            <TextBlock Text="{x:Bind ViewModel.SecurityScore, Mode=OneWay}"
                                       FontSize="32" FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       Foreground="{x:Bind ViewModel.ScoreForeground, Mode=OneWay, Converter={StaticResource StringToBrush}}"/>
                            <TextBlock Text="/100"
                                       FontSize="11"
                                       HorizontalAlignment="Center"
                                       Foreground="{StaticResource MutedBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- Score label + component summary -->
                    <StackPanel Grid.Column="1" Spacing="12" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="Security Score"
                                       FontSize="20" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <Border Background="{x:Bind ViewModel.ScoreForeground, Mode=OneWay, Converter={StaticResource StringToBrush}}"
                                    CornerRadius="4" Padding="10,3" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind ViewModel.ScoreLabel, Mode=OneWay}"
                                           FontSize="12" FontWeight="Bold" Foreground="White"/>
                            </Border>
                        </StackPanel>

                        <TextBlock TextWrapping="Wrap" FontSize="12"
                                   Foreground="{StaticResource MutedBrush}">
                            Score is based on Defender settings (40 pts), firewall profiles (30 pts), and BitLocker encryption (20 pts + 10 bonus).
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══════════════════════════════════════════════════════════════ -->
            <!--  SECTION 2 — Windows Defender                                 -->
            <!-- ═══════════════════════════════════════════════════════════════ -->
            <Border Background="{ThemeResource HudSurfaceAltBrush}"
                    BorderBrush="{ThemeResource HudHairlineBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xEA18;" FontSize="18" VerticalAlignment="Center"/>
                            <TextBlock Text="Windows Defender"
                                       FontSize="16" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <Button Grid.Column="1" Content="Run Quick Scan"
                                Click="RunQuickScan_Click"/>
                    </Grid>

                    <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                    <!-- Status tiles -->
                    <Grid ColumnSpacing="10" RowSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition/><RowDefinition/><RowDefinition/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Real-Time Protection -->
                        <Border Grid.Row="0" Grid.Column="0"
                                Background="{ThemeResource HudSurfaceAltBrush}"
                                CornerRadius="6" Padding="12,10">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Real-Time Protection" FontSize="12" FontWeight="SemiBold"/>
                                <TextBlock Text="{x:Bind ViewModel.RealTimeProtectionEnabled, Mode=OneWay}"
                                           FontSize="11"
                                           Foreground="{StaticResource MutedBrush}"/>
                            </StackPanel>
                        </Border>

                        <!-- Cloud Protection -->
                        <Border Grid.Row="0" Grid.Column="1"
                                Background="{ThemeResource HudSurfaceAltBrush}"
                                CornerRadius="6" Padding="12,10">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Cloud Protection" FontSize="12" FontWeight="SemiBold"/>
                                <TextBlock Text="{x:Bind ViewModel.CloudProtectionEnabled, Mode=OneWay}"
                                           FontSize="11"
                                           Foreground="{StaticResource MutedBrush}"/>
                            </StackPanel>
                        </Border>

                        <!-- Tamper Protection -->
                        <Border Grid.Row="1" Grid.Column="0"
                                Background="{ThemeResource HudSurfaceAltBrush}"
                                CornerRadius="6" Padding="12,10">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Tamper Protection" FontSize="12" FontWeight="SemiBold"/>
                                <TextBlock Text="{x:Bind ViewModel.TamperProtectionEnabled, Mode=OneWay}"
                                           FontSize="11"
                                           Foreground="{StaticResource MutedBrush}"/>
                            </StackPanel>
                        </Border>

                        <!-- Definition version -->
                        <Border Grid.Row="1" Grid.Column="1"
                                Background="{ThemeResource HudSurfaceAltBrush}"
                                CornerRadius="6" Padding="12,10">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Definition Version" FontSize="12" FontWeight="SemiBold"/>
                                <TextBlock Text="{x:Bind ViewModel.DefinitionVersion, Mode=OneWay}"
                                           FontSize="11"
                                           Foreground="{StaticResource MutedBrush}"
                                           TextWrapping="Wrap"
                                           MaxLines="2" TextTrimming="CharacterEllipsis"
                                           ToolTipService.ToolTip="{x:Bind ViewModel.DefinitionVersion, Mode=OneWay}"/>
                            </StackPanel>
                        </Border>

                        <!-- Last Quick Scan -->
                        <Border Grid.Row="2" Grid.Column="0"
                                Background="{ThemeResource HudSurfaceAltBrush}"
                                CornerRadius="6" Padding="12,10">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Last Quick Scan" FontSize="12" FontWeight="SemiBold"/>
                                <TextBlock Text="{x:Bind ViewModel.LastQuickScan, Mode=OneWay}"
                                           FontSize="11"
                                           Foreground="{StaticResource MutedBrush}"/>
                            </StackPanel>
                        </Border>

                        <!-- Last Full Scan -->
                        <Border Grid.Row="2" Grid.Column="1"
                                Background="{ThemeResource HudSurfaceAltBrush}"
                                CornerRadius="6" Padding="12,10">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Last Full Scan" FontSize="12" FontWeight="SemiBold"/>
                                <TextBlock Text="{x:Bind ViewModel.LastFullScan, Mode=OneWay}"
                                           FontSize="11"
                                           Foreground="{StaticResource MutedBrush}"/>
                            </StackPanel>
                        </Border>

                    </Grid>
                </StackPanel>
            </Border>

            <!-- ═══════════════════════════════════════════════════════════════ -->
            <!--  SECTION 3 — Firewall                                         -->
            <!-- ═══════════════════════════════════════════════════════════════ -->
            <Border Background="{ThemeResource HudSurfaceAltBrush}"
                    BorderBrush="{ThemeResource HudHairlineBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE7BE;" FontSize="18" VerticalAlignment="Center"/>
                        <TextBlock Text="Firewall"
                                   FontSize="16" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Domain profile -->
                        <Border Grid.Column="0"
                                Background="{ThemeResource HudSurfaceAltBrush}"
                                CornerRadius="6" Padding="12">
                            <StackPanel Spacing="6" HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xE753;" FontSize="28"
                                          HorizontalAlignment="Center"
                                          Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                                <TextBlock Text="Domain" FontSize="13" FontWeight="SemiBold"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="{x:Bind ViewModel.DomainFirewallEnabled, Mode=OneWay}"
                                           FontSize="12" HorizontalAlignment="Center"
                                           Foreground="{StaticResource MutedBrush}"/>
                            </StackPanel>
                        </Border>

                        <!-- Private profile -->
                        <Border Grid.Column="1"
                                Background="{ThemeResource HudSurfaceAltBrush}"
                                CornerRadius="6" Padding="12">
                            <StackPanel Spacing="6" HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xE8F1;" FontSize="28"
                                          HorizontalAlignment="Center"
                                          Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                                <TextBlock Text="Private" FontSize="13" FontWeight="SemiBold"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="{x:Bind ViewModel.PrivateFirewallEnabled, Mode=OneWay}"
                                           FontSize="12" HorizontalAlignment="Center"
                                           Foreground="{StaticResource MutedBrush}"/>
                            </StackPanel>
                        </Border>

                        <!-- Public profile -->
                        <Border Grid.Column="2"
                                Background="{ThemeResource HudSurfaceAltBrush}"
                                CornerRadius="6" Padding="12">
                            <StackPanel Spacing="6" HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xE704;" FontSize="28"
                                          HorizontalAlignment="Center"
                                          Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                                <TextBlock Text="Public" FontSize="13" FontWeight="SemiBold"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="{x:Bind ViewModel.PublicFirewallEnabled, Mode=OneWay}"
                                           FontSize="12" HorizontalAlignment="Center"
                                           Foreground="{StaticResource MutedBrush}"/>
                            </StackPanel>
                        </Border>

                    </Grid>
                </StackPanel>
            </Border>

            <!-- ═══════════════════════════════════════════════════════════════ -->
            <!--  SECTION 4 — Encryption (BitLocker)                           -->
            <!-- ═══════════════════════════════════════════════════════════════ -->
            <Border Background="{ThemeResource HudSurfaceAltBrush}"
                    BorderBrush="{ThemeResource HudHairlineBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE72E;" FontSize="18" VerticalAlignment="Center"/>
                        <TextBlock Text="Encryption (BitLocker)"
                                   FontSize="16" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                    <!-- Needs admin / no volumes -->
                    <TextBlock Text="BitLocker information requires administrator privileges, or no fixed drives were found."
                               FontSize="13"
                               Foreground="{StaticResource MutedBrush}"
                               TextWrapping="Wrap"
                               Visibility="{x:Bind ViewModel.HasNoBitLockerVolumes, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>

                    <!-- Volume list -->
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.BitLockerVolumes, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Vertical" Spacing="6"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="models:BitLockerVolume">
                                <Border Background="{ThemeResource HudSurfaceAltBrush}"
                                        CornerRadius="6" Padding="12,10">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="{x:Bind DriveLetter}"
                                                   FontSize="18" FontWeight="Bold"
                                                   VerticalAlignment="Center"
                                                   Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>

                                        <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind EncryptionMethod}"
                                                       FontSize="13" FontWeight="SemiBold"/>
                                            <TextBlock Text="{x:Bind LockStatus}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource MutedBrush}"/>
                                        </StackPanel>

                                        <TextBlock Grid.Column="2"
                                                   Text="{x:Bind ProtectionStatus}"
                                                   FontSize="12" VerticalAlignment="Center"
                                                   Foreground="{StaticResource MutedBrush}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>

                </StackPanel>
            </Border>

            <!-- ═══════════════════════════════════════════════════════════════ -->
            <!--  SECTION 5 — Recommendations                                  -->
            <!-- ═══════════════════════════════════════════════════════════════ -->
            <Border Background="{ThemeResource HudSurfaceAltBrush}"
                    BorderBrush="{ThemeResource HudHairlineBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE82D;" FontSize="18" VerticalAlignment="Center"/>
                        <TextBlock Text="Security Recommendations"
                                   FontSize="16" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.Recommendations, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Vertical" Spacing="8"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:SecurityRecommendation">
                                <Border Background="{ThemeResource HudSurfaceAltBrush}"
                                        CornerRadius="6" Padding="12,10"
                                        BorderThickness="1"
                                        BorderBrush="{x:Bind SeverityColor, Converter={StaticResource StringToBrush}}">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="{x:Bind Icon}"
                                                   FontSize="20"
                                                   VerticalAlignment="Top"
                                                   Margin="0,2,0,0"/>

                                        <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind Title}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock Text="{x:Bind Detail}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource MutedBrush}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
    </hud:HudBackdrop>
</Page>
