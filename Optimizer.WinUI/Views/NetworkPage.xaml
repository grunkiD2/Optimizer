<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Optimizer.WinUI.Views.NetworkPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Optimizer.WinUI.Controls"
    xmlns:vm="using:Optimizer.WinUI.ViewModels"
    xmlns:services="using:Optimizer.WinUI.Services"
    xmlns:converters="using:Optimizer.WinUI.Converters"
    Background="Transparent"
    Loaded="Page_Loaded"
    Unloaded="Page_Unloaded">

    <Page.Resources>
        <converters:BoolToVisibilityConverter    x:Key="BoolToVisibility"/>
        <converters:OneDecimalConverter          x:Key="OneDecimal"/>
        <converters:NullToVisibilityConverter    x:Key="NullToVisibility"/>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16" Padding="24,16,24,24">

            <!-- ── Page header ──────────────────────────────────────────── -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: icon + title + subtitle -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <TextBlock Text="{x:Bind ViewModel.CategoryIcon}"
                               FontSize="28" VerticalAlignment="Center"/>
                    <StackPanel Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="{x:Bind ViewModel.CategoryName}"
                                   Style="{StaticResource TitleTextBlockStyle}"/>
                        <TextBlock FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                            <Run Text="{x:Bind ViewModel.ActiveCount, Mode=OneWay}"/>
                            <Run Text=" of "/>
                            <Run Text="{x:Bind ViewModel.TotalCount, Mode=OneWay}"/>
                            <Run Text=" optimizations active"/>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>

                <!-- Right: action buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button Content="Apply All"
                            Style="{StaticResource AccentButtonStyle}"
                            Command="{x:Bind ViewModel.ApplyAllCommand}"/>
                    <Button Content="Undo Category"
                            Command="{x:Bind ViewModel.UndoCategoryCommand}"/>
                </StackPanel>
            </Grid>

            <!-- ── Local metrics strip ──────────────────────────────────── -->
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Download Speed -->
                <Border Grid.Column="0" CornerRadius="8" Padding="16,12" Background="{ThemeResource LayerFillColorDefaultBrush}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="DOWNLOAD" FontSize="12" Foreground="#60A5FA"/>
                        <TextBlock Text="{x:Bind ViewModel.DownloadSpeedText, Mode=OneWay}"
                                   FontSize="22" FontWeight="Bold" FontFamily="Consolas"/>
                        <TextBlock Text="inbound" FontSize="11"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Upload Speed -->
                <Border Grid.Column="1" CornerRadius="8" Padding="16,12" Background="{ThemeResource LayerFillColorDefaultBrush}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="UPLOAD" FontSize="12" Foreground="#34D399"/>
                        <TextBlock Text="{x:Bind ViewModel.UploadSpeedText, Mode=OneWay}"
                                   FontSize="22" FontWeight="Bold" FontFamily="Consolas"/>
                        <TextBlock Text="outbound" FontSize="11"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Latency -->
                <Border Grid.Column="2" CornerRadius="8" Padding="16,12" Background="{ThemeResource LayerFillColorDefaultBrush}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="LATENCY" FontSize="12" Foreground="#A78BFA"/>
                        <TextBlock Text="{x:Bind ViewModel.LatencyText, Mode=OneWay}"
                                   FontSize="22" FontWeight="Bold" FontFamily="Consolas"/>
                        <TextBlock Text="ping" FontSize="11"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── Speed Test ──────────────────────────────────────────────── -->
            <TextBlock Text="SPEED TEST"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="0,16,0,8"/>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">

                    <!-- Header row -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Speed Test" FontWeight="SemiBold"/>
                            <TextBlock Text="{x:Bind ViewModel.SpeedTestPhase, Mode=OneWay}"
                                       FontSize="11"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Run Test"
                                Style="{ThemeResource AccentButtonStyle}"
                                Click="RunSpeedTest_Click"/>
                    </Grid>

                    <!-- Progress bar during test -->
                    <ProgressBar IsIndeterminate="True"
                                 Visibility="{x:Bind ViewModel.IsTestingSpeed, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>

                    <!-- Result grid (shown only when a result is available) -->
                    <Grid ColumnSpacing="8"
                          Visibility="{x:Bind ViewModel.LastSpeedTest, Mode=OneWay, Converter={StaticResource NullToVisibility}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Download -->
                        <StackPanel>
                            <TextBlock Text="DOWNLOAD" FontSize="10"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock FontSize="20" FontWeight="Bold">
                                <Run Text="{x:Bind ViewModel.DownloadResultText, Mode=OneWay}"/>
                                <Run Text=" Mbps" FontSize="10"/>
                            </TextBlock>
                        </StackPanel>

                        <!-- Upload -->
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="UPLOAD" FontSize="10"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock FontSize="20" FontWeight="Bold">
                                <Run Text="{x:Bind ViewModel.UploadResultText, Mode=OneWay}"/>
                                <Run Text=" Mbps" FontSize="10"/>
                            </TextBlock>
                        </StackPanel>

                        <!-- Ping -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="PING" FontSize="10"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock FontSize="20" FontWeight="Bold">
                                <Run Text="{x:Bind ViewModel.PingResultText, Mode=OneWay}"/>
                                <Run Text=" ms" FontSize="10"/>
                            </TextBlock>
                        </StackPanel>

                        <!-- Jitter -->
                        <StackPanel Grid.Column="3">
                            <TextBlock Text="JITTER" FontSize="10"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock FontSize="20" FontWeight="Bold">
                                <Run Text="{x:Bind ViewModel.JitterResultText, Mode=OneWay}"/>
                                <Run Text=" ms" FontSize="10"/>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ── Live Latency Monitor ─────────────────────────────────────── -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="16">
                <StackPanel Spacing="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Live Latency (1.1.1.1)" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" FontWeight="Bold">
                            <Run Text="{x:Bind ViewModel.CurrentPingText, Mode=OneWay}"/>
                            <Run Text=" ms" FontSize="10"/>
                        </TextBlock>
                    </Grid>
                    <controls:SparklineChart Height="48"
                        Values="{x:Bind ViewModel.LatencyHistory, Mode=OneWay}"
                        LineColor="#34D399"/>
                </StackPanel>
            </Border>

            <!-- ── DNS Configuration ───────────────────────────────────── -->
            <TextBlock Text="DNS CONFIGURATION"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="0,16,0,8"/>
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16" Margin="0,0,0,8"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="12">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Current DNS" FontWeight="SemiBold"/>
                            <TextBlock Text="{x:Bind ViewModel.CurrentDns, Mode=OneWay}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Flush Cache" Click="FlushDns_Click"/>
                        <Button Grid.Column="2" Content="Reset to ISP" Click="ResetDns_Click"/>
                    </Grid>

                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.DnsPresets}">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout MinItemWidth="280" MinItemHeight="80"
                                               MinColumnSpacing="8" MinRowSpacing="8"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="services:DnsServerPreset">
                                <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                        CornerRadius="6" Padding="12,10"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{x:Bind Description}" FontSize="11"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   TextWrapping="Wrap"/>
                                        <Grid ColumnSpacing="8" Margin="0,4,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{x:Bind Primary}" FontFamily="Consolas" FontSize="11"/>
                                            <Button Grid.Column="1" Content="APPLY" Style="{ThemeResource AccentButtonStyle}"
                                                    Click="ApplyDns_Click" Tag="{x:Bind Id}" MinWidth="60"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>
            </Border>

            <!-- ── Optimization cards ───────────────────────────────────── -->
            <TextBlock Text="Optimizations"
                       FontSize="16" FontWeight="SemiBold"
                       Margin="0,8,0,0"/>

            <ItemsRepeater x:Name="OptimizationsRepeater"
                           ItemsSource="{x:Bind ViewModel.Optimizations, Mode=OneWay}">
                <ItemsRepeater.Layout>
                    <StackLayout Orientation="Vertical" Spacing="0"/>
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="vm:OptimizationCardModel">
                        <controls:OptimizationCard
                            Tag="{x:Bind Id}"
                            Loaded="OptimizationCard_Loaded"/>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

        </StackPanel>
    </ScrollViewer>
</Page>
