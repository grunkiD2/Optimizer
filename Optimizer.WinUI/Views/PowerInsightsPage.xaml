<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Optimizer.WinUI.Views.PowerInsightsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:hud="using:Optimizer.WinUI.Controls.Hud"
    Background="Transparent">

    <hud:HudBackdrop>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,16,24,24">
            <StackPanel Spacing="20" MaxWidth="1100" HorizontalAlignment="Left">

                <hud:HudPageHeader Icon="&#xE945;" Title="Power Insights"
                    Description="Per-process power attribution and drift detection. Read-only — estimated from CPU-time share × measured CPU package watts."/>

                <!-- Vitals row -->
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <hud:StatTile x:Name="PackageTile" Grid.Column="0" Label="PACKAGE POWER" Unit="W" Value="--"/>
                    <hud:StatTile x:Name="TopDrainTile" Grid.Column="1" Label="TOP DRAIN" Unit="W" Value="--"/>
                    <hud:StatTile x:Name="DriftTile" Grid.Column="2" Label="DRIFT EVENTS (24H)" Unit="" Value="--"/>
                </Grid>

                <hud:HudCard Header="TOP DRAINERS — LIVE (30 S WINDOW)">
                    <StackPanel x:Name="DrainerList" Spacing="10"/>
                </hud:HudCard>

                <hud:HudCard Header="DRIFT HISTORY — 24 H">
                    <StackPanel x:Name="DriftList" Spacing="10"/>
                </hud:HudCard>

            </StackPanel>
        </ScrollViewer>
    </hud:HudBackdrop>
</Page>
