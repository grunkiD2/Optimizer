<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Optimizer.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Optimizer">

    <!-- KeyboardAcceleratorPlacementMode="Hidden" suppresses the auto-generated
         "Ctrl+K" tooltip that otherwise appeared on hover anywhere in the window. -->
    <Grid x:Name="RootGrid" KeyboardAcceleratorPlacementMode="Hidden">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- custom title bar (drag region) -->
            <RowDefinition Height="Auto"/>   <!-- elevation info bar -->
            <RowDefinition Height="*"/>      <!-- nav + content -->
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Grid.KeyboardAccelerators>
            <!-- Ctrl+` (backtick / OEM_3, VK 192) is added in code-behind: its VirtualKey
                 has no named XAML member, so a numeric Key="192" fails to parse. -->
            <KeyboardAccelerator Modifiers="Control" Key="K" Invoked="OmniboxAccel_Invoked"/>
        </Grid.KeyboardAccelerators>

        <!-- Custom title bar: with ExtendsContentIntoTitleBar the top reads as one continuous
             glass (Mica) surface; the system caption buttons float at the right. -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Grid.ColumnSpan="2" Height="44" Background="Transparent">
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center" Margin="16,0,0,0">
                <TextBlock Text="&#x25C9;" Foreground="{StaticResource AccentCyanBrush}" FontSize="14" VerticalAlignment="Center"/>
                <TextBlock Text="OPTIMIZER" FontWeight="SemiBold" FontSize="13" CharacterSpacing="120"
                           Foreground="{ThemeResource HudTextPrimaryBrush}" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <InfoBar
            x:Name="ElevationInfoBar"
            Grid.Row="1"
            Grid.ColumnSpan="2"
            IsOpen="True"
            IsClosable="False"
            Severity="Warning"
            Title="Running without administrator privileges"
            Message="Some optimizations require admin access to apply."
            Visibility="Collapsed">
            <InfoBar.ActionButton>
                <Button Content="Relaunch as Admin" Click="RelaunchElevated_Click"/>
            </InfoBar.ActionButton>
        </InfoBar>

        <InfoBar
            x:Name="ElevatedInfoBar"
            Grid.Row="1"
            Grid.ColumnSpan="2"
            IsOpen="True"
            IsClosable="True"
            Severity="Success"
            Title="Running as Administrator"
            Message="All optimizations are available."
            Visibility="Collapsed"/>

        <NavigationView
            x:Name="NavView"
            Grid.Row="2"
            Grid.Column="0"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            PaneDisplayMode="LeftCompact"
            CompactPaneLength="64"
            OpenPaneLength="240"
            SelectionChanged="NavView_SelectionChanged"
            Loaded="NavView_Loaded">

            <NavigationView.MenuItems>
                <NavigationViewItem Content="Command Center" Tag="CommandCenter">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE80F;"/></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Monitor" Tag="Monitor">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE9D9;"/></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Optimize" Tag="Optimize">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE945;"/></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Automate" Tag="Automate">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE9F5;"/></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Protect" Tag="Protect">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE72E;"/></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Extend" Tag="Extend">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE74C;"/></NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem Content="Settings" Tag="Settings" Icon="Setting"/>
            </NavigationView.FooterMenuItems>

            <Frame x:Name="ContentFrame"/>
        </NavigationView>

        <!-- Persistent console dock (Assistant + Activity), right side. Toggled with Ctrl+`; can pop out. -->
        <Border Grid.Row="2" Grid.Column="1" x:Name="ConsoleDockHost" Width="440"
                Background="{ThemeResource HudSurfaceAltBrush}"
                BorderThickness="1,0,0,0"
                BorderBrush="{StaticResource HudGlassBorderBrush}"
                Visibility="Collapsed"/>
    </Grid>
</Window>
