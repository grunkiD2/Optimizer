<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Optimizer.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:tk="using:CommunityToolkit.WinUI.Controls"
    Title="Optimizer">

    <!-- KeyboardAcceleratorPlacementMode="Hidden" suppresses the auto-generated
         "Ctrl+K" tooltip that otherwise appeared on hover anywhere in the window. -->
    <Grid x:Name="RootGrid" KeyboardAcceleratorPlacementMode="Hidden">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- custom title bar (drag region) -->
            <RowDefinition Height="Auto"/>   <!-- elevation info bar -->
            <RowDefinition Height="*"/>      <!-- nav + splitter + console dock -->
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="320"/>    <!-- Col 0: navigation content -->
            <ColumnDefinition x:Name="SplitterCol" Width="4"/>          <!-- Col 1: drag splitter -->
            <ColumnDefinition x:Name="ConsoleDockCol" Width="400" MinWidth="260" MaxWidth="680"/> <!-- Col 2: console dock -->
        </Grid.ColumnDefinitions>

        <Grid.KeyboardAccelerators>
            <!-- Ctrl+` (backtick / OEM_3, VK 192) is added in code-behind: its VirtualKey
                 has no named XAML member, so a numeric Key="192" fails to parse. -->
            <KeyboardAccelerator Modifiers="Control" Key="K" Invoked="OmniboxAccel_Invoked"/>
        </Grid.KeyboardAccelerators>

        <!-- Custom title bar: with ExtendsContentIntoTitleBar the top reads as one continuous
             glass (Mica) surface; the system caption buttons float at the right. The menu bar
             (Batch 3) sits left-of-centre; TitleBarDragRegion fills the rest and is the actual
             drag region (SetTitleBar points at it in code-behind — pointing at the whole grid
             would swallow the menu's clicks). -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Grid.ColumnSpan="3" Height="44" Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>   <!-- logo + wordmark -->
                <ColumnDefinition Width="Auto"/>   <!-- menu bar -->
                <ColumnDefinition Width="*"/>      <!-- drag region (also clears the caption buttons) -->
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center" Margin="16,0,14,0">
                <TextBlock Text="&#x25C9;" Foreground="{StaticResource AccentCyanBrush}" FontSize="14" VerticalAlignment="Center"/>
                <TextBlock Text="OPTIMIZER" FontWeight="SemiBold" FontSize="13" CharacterSpacing="120"
                           Foreground="{ThemeResource HudTextPrimaryBrush}" VerticalAlignment="Center"/>
            </StackPanel>

            <MenuBar Grid.Column="1" x:Name="AppMenuBar" Background="Transparent" VerticalAlignment="Center">
                <MenuBarItem Title="Filer">
                    <MenuFlyoutItem Text="Eksportér rapport…" Click="MenuExportReport_Click">
                        <MenuFlyoutItem.Icon><FontIcon Glyph="&#xEDE1;"/></MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem Text="Indstillinger" Click="MenuSettings_Click">
                        <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE713;"/></MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutSeparator/>
                    <MenuFlyoutItem Text="Afslut" Click="MenuExit_Click">
                        <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE7E8;"/></MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                </MenuBarItem>

                <MenuBarItem Title="Vis">
                    <MenuFlyoutItem Text="Konsol-dock" Click="MenuToggleConsole_Click" KeyboardAcceleratorTextOverride="Ctrl+`"/>
                    <MenuFlyoutItem Text="Pop konsol ud" Click="MenuPopOutConsole_Click"/>
                    <MenuFlyoutItem Text="Spørg assistenten…" Click="MenuAskAssistant_Click" KeyboardAcceleratorTextOverride="Ctrl+K"/>
                    <MenuFlyoutSeparator/>
                    <MenuFlyoutSubItem Text="Tema">
                        <MenuFlyoutItem Text="System" Tag="Default" Click="MenuTheme_Click"/>
                        <MenuFlyoutItem Text="Lyst" Tag="Light" Click="MenuTheme_Click"/>
                        <MenuFlyoutItem Text="Mørkt" Tag="Dark" Click="MenuTheme_Click"/>
                    </MenuFlyoutSubItem>
                    <MenuFlyoutSubItem Text="Baggrund">
                        <MenuFlyoutItem Text="Mica" Tag="Mica" Click="MenuBackdrop_Click"/>
                        <MenuFlyoutItem Text="Mica Alt" Tag="MicaAlt" Click="MenuBackdrop_Click"/>
                        <MenuFlyoutItem Text="Akryl" Tag="Acrylic" Click="MenuBackdrop_Click"/>
                        <MenuFlyoutItem Text="Ingen" Tag="None" Click="MenuBackdrop_Click"/>
                    </MenuFlyoutSubItem>
                    <MenuFlyoutSeparator/>
                    <MenuFlyoutItem Text="Maksimér / gendan" Click="MenuMaximize_Click"/>
                </MenuBarItem>

                <MenuBarItem Title="Værktøjer">
                    <MenuFlyoutItem Text="Kør oprydning" Click="MenuRunCleanup_Click"/>
                    <MenuFlyoutItem Text="Profil-presets" Click="MenuProfiles_Click"/>
                    <MenuFlyoutItem Text="Registrér kontekst igen" Click="MenuRedetectContext_Click"/>
                    <MenuFlyoutItem Text="Fortryd seneste optimering" Click="MenuUndoLast_Click"/>
                    <MenuFlyoutSeparator/>
                    <MenuFlyoutItem Text="Stresstest" Click="MenuStressTest_Click"/>
                    <MenuFlyoutItem Text="Netværks-hastighedstest" Click="MenuNetworkSpeed_Click"/>
                    <MenuFlyoutItem Text="Systemreparation" Click="MenuSystemRepair_Click"/>
                </MenuBarItem>

                <MenuBarItem Title="Hjælp">
                    <MenuFlyoutItem Text="Tastaturgenveje" Click="MenuShortcuts_Click"/>
                    <MenuFlyoutItem Text="Vis app.log" Click="MenuShowLog_Click"/>
                    <MenuFlyoutSeparator/>
                    <MenuFlyoutItem Text="Om Optimizer" Click="MenuAbout_Click"/>
                </MenuBarItem>
            </MenuBar>

            <Border Grid.Column="2" x:Name="TitleBarDragRegion" Background="Transparent"/>
        </Grid>

        <InfoBar
            x:Name="ElevationInfoBar"
            Grid.Row="1"
            Grid.ColumnSpan="3"
            IsOpen="True"
            IsClosable="False"
            Severity="Warning"
            Title="Running without administrator privileges"
            Message="Some optimizations require admin access to apply."
            Visibility="Collapsed">
            <InfoBar.ActionButton>
                <Button Content="Relaunch as Admin" Click="RelaunchElevated_Click"/>
            </InfoBar.ActionButton>
        </InfoBar>

        <InfoBar
            x:Name="ElevatedInfoBar"
            Grid.Row="1"
            Grid.ColumnSpan="3"
            IsOpen="True"
            IsClosable="True"
            Severity="Success"
            Title="Running as Administrator"
            Message="All optimizations are available."
            Visibility="Collapsed"/>

        <NavigationView
            x:Name="NavView"
            Grid.Row="2"
            Grid.Column="0"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            PaneDisplayMode="LeftCompact"
            CompactPaneLength="64"
            OpenPaneLength="240"
            SelectionChanged="NavView_SelectionChanged"
            Loaded="NavView_Loaded">

            <NavigationView.MenuItems>
                <NavigationViewItem Content="Command Center" Tag="CommandCenter">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE80F;"/></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Monitor" Tag="Monitor">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE9D9;"/></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Optimize" Tag="Optimize">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE945;"/></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Automate" Tag="Automate">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE9F5;"/></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Protect" Tag="Protect">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE72E;"/></NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem Content="Settings" Tag="Settings" Icon="Setting"/>
            </NavigationView.FooterMenuItems>

            <Frame x:Name="ContentFrame"/>
        </NavigationView>

        <!-- Drag splitter between the nav/content area and the console dock.
             ResizeBehavior="PreviousAndNext" resizes Col 0 and Col 2 when dragged. -->
        <tk:GridSplitter
            x:Name="DockSplitter"
            Grid.Row="2" Grid.Column="1"
            ResizeDirection="Columns"
            ResizeBehavior="PreviousAndNext"
            HorizontalAlignment="Stretch"
            Background="{StaticResource HudGlassBorderBrush}"/>

        <!-- Persistent console dock (Activity / Assistant / Output), right side.
             Toggled with Ctrl+`; can pop out to a floating window. -->
        <Border
            Grid.Row="2" Grid.Column="2"
            x:Name="ConsoleDockHost"
            Background="{ThemeResource HudSurfaceAltBrush}"
            BorderThickness="0"
            Visibility="Collapsed"/>
    </Grid>
</Window>
