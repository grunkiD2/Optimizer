<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Optimizer.WinUI.Controls.Hud.HealthRing"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:w2d="using:Microsoft.Graphics.Canvas.UI.Xaml">

    <Grid Width="184" Height="184">
        <!-- Win2D draws the track, a blurred glow bloom, and the progress arc -->
        <w2d:CanvasControl x:Name="Canvas" Draw="OnDraw"/>

        <!-- Center readout overlaid on top -->
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="-2">
            <TextBlock x:Name="ScoreText" Style="{StaticResource HudDisplayStyle}" HorizontalAlignment="Center"/>
            <TextBlock Text="HEADROOM" Style="{StaticResource HudMicroStyle}" HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</UserControl>
