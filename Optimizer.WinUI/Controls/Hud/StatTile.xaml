<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Optimizer.WinUI.Controls.Hud.StatTile"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border CornerRadius="{StaticResource CardCornerRadius}"
            Background="{ThemeResource HudSurfaceBrush}"
            BorderBrush="{StaticResource HudGlassBorderBrush}"
            BorderThickness="1"
            Padding="{StaticResource CardPaddingTight}">
        <StackPanel Spacing="6">
            <TextBlock Text="{x:Bind Label, Mode=OneWay}" Style="{StaticResource HudMicroStyle}"/>
            <StackPanel Orientation="Horizontal" Spacing="4">
                <TextBlock x:Name="ValueText" Text="{x:Bind Value, Mode=OneWay}" Style="{StaticResource HudMetricStyle}"/>
                <TextBlock Text="{x:Bind Unit, Mode=OneWay}" Style="{StaticResource HudCaptionStyle}"
                           VerticalAlignment="Bottom" Margin="0,0,0,4"/>
            </StackPanel>
            <Polyline x:Name="Spark" Height="22" Stretch="Fill" HorizontalAlignment="Stretch"
                      Stroke="{StaticResource AccentCyanBrush}" StrokeThickness="1.5"
                      StrokeLineJoin="Round" Visibility="Collapsed"/>
            <TextBlock x:Name="CaptionText" Text="{x:Bind Caption, Mode=OneWay}"
                       Style="{StaticResource HudMonoSmallStyle}" Foreground="{StaticResource MutedBrush}"/>
        </StackPanel>
    </Border>
</UserControl>
