<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Optimizer.WinUI.Controls.Hud.HudCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border CornerRadius="{StaticResource CardCornerRadius}"
            Background="{ThemeResource HudSurfaceBrush}"
            BorderBrush="{StaticResource HudGlassBorderBrush}"
            BorderThickness="1"
            Padding="{StaticResource CardPadding}">
        <StackPanel Spacing="10">
            <TextBlock x:Name="HeaderText"
                       Style="{StaticResource HudMicroStyle}"
                       Text="{x:Bind Header, Mode=OneWay}"
                       Visibility="Collapsed"/>
            <ContentPresenter Content="{x:Bind CardContent, Mode=OneWay}"
                              HorizontalContentAlignment="Stretch"/>
        </StackPanel>
    </Border>
</UserControl>
