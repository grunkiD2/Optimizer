<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Optimizer.WinUI.Controls.Hud.HudCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border CornerRadius="{StaticResource CardCornerRadius}"
            Background="{ThemeResource HudSurfaceBrush}"
            BorderBrush="{StaticResource HudGlassBorderBrush}"
            BorderThickness="1"
            Padding="{StaticResource CardPadding}">
        <StackPanel Spacing="12">
            <StackPanel x:Name="HeaderArea" Spacing="2" Visibility="Collapsed">
                <TextBlock x:Name="HeaderText"
                           Style="{StaticResource HudMicroStyle}"
                           Text="{x:Bind Header, Mode=OneWay}"
                           Visibility="Collapsed"/>
                <TextBlock x:Name="DescText"
                           Style="{StaticResource HudCaptionStyle}"
                           Text="{x:Bind Description, Mode=OneWay}"
                           TextWrapping="Wrap"
                           Visibility="Collapsed"/>
            </StackPanel>
            <ContentPresenter Content="{x:Bind CardContent, Mode=OneWay}"
                              HorizontalContentAlignment="Stretch"/>
        </StackPanel>
    </Border>
</UserControl>
