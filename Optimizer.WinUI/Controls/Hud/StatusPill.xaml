<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Optimizer.WinUI.Controls.Hud.StatusPill"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    HorizontalAlignment="Left" VerticalAlignment="Center">

    <Border x:Name="Root"
            CornerRadius="{StaticResource PillCornerRadius}"
            Padding="{StaticResource PillPadding}">
        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
            <Ellipse x:Name="Dot" Width="6" Height="6" VerticalAlignment="Center"/>
            <TextBlock x:Name="LabelText" Text="{x:Bind Text, Mode=OneWay}"
                       FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
        </StackPanel>
    </Border>
</UserControl>
