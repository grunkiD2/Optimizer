<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Optimizer.WinUI.Controls.Hud.HudPageHeader"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
            <Border Width="48" Height="48" CornerRadius="{StaticResource InnerCornerRadius}"
                    Background="{StaticResource AccentSoftBrush}"
                    BorderBrush="{ThemeResource HudHairlineBrush}" BorderThickness="1">
                <TextBlock Text="{x:Bind Icon, Mode=OneWay}" FontSize="24"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <StackPanel Spacing="3" VerticalAlignment="Center">
                <TextBlock Text="{x:Bind Title, Mode=OneWay}" Style="{StaticResource HudTitleStyle}"/>
                <TextBlock Text="{x:Bind Description, Mode=OneWay}" Style="{StaticResource HudCaptionStyle}"
                           TextWrapping="Wrap" MaxWidth="720"/>
            </StackPanel>
        </StackPanel>

        <ContentPresenter Grid.Column="1" Content="{x:Bind Actions, Mode=OneWay}" VerticalAlignment="Center"/>
    </Grid>
</UserControl>
