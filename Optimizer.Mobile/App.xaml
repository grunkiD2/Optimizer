<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Optimizer.Mobile.App">
    <Application.Resources>
        <ResourceDictionary>
            <!-- Colors matching the PWA/WinUI dark theme -->
            <Color x:Key="BgColor">#0F172A</Color>
            <Color x:Key="ElevatedColor">#1E293B</Color>
            <Color x:Key="SurfaceColor">#334155</Color>
            <Color x:Key="AccentColor">#3B82F6</Color>
            <Color x:Key="MutedColor">#94A3B8</Color>
            <Color x:Key="TextColor">#E2E8F0</Color>
            <Color x:Key="GreenColor">#10B981</Color>
            <Color x:Key="AmberColor">#F59E0B</Color>
            <Color x:Key="RedColor">#EF4444</Color>

            <!-- Global page background -->
            <Style TargetType="ContentPage" ApplyToDerivedTypes="True">
                <Setter Property="BackgroundColor" Value="{StaticResource BgColor}"/>
            </Style>

            <!-- Labels default to light text -->
            <Style TargetType="Label">
                <Setter Property="TextColor" Value="{StaticResource TextColor}"/>
                <Setter Property="FontFamily" Value="OpenSansRegular"/>
            </Style>

            <!-- Entry fields -->
            <Style TargetType="Entry">
                <Setter Property="BackgroundColor" Value="{StaticResource ElevatedColor}"/>
                <Setter Property="TextColor" Value="{StaticResource TextColor}"/>
                <Setter Property="PlaceholderColor" Value="{StaticResource MutedColor}"/>
            </Style>

            <!-- Primary button -->
            <Style x:Key="PrimaryBtn" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource AccentColor}"/>
                <Setter Property="TextColor" Value="White"/>
                <Setter Property="CornerRadius" Value="12"/>
                <Setter Property="FontAttributes" Value="Bold"/>
            </Style>

            <!-- Secondary button -->
            <Style x:Key="SecondaryBtn" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource ElevatedColor}"/>
                <Setter Property="TextColor" Value="{StaticResource TextColor}"/>
                <Setter Property="CornerRadius" Value="10"/>
            </Style>

            <!-- Card frame -->
            <Style x:Key="Card" TargetType="Frame">
                <Setter Property="BackgroundColor" Value="{StaticResource ElevatedColor}"/>
                <Setter Property="BorderColor" Value="Transparent"/>
                <Setter Property="CornerRadius" Value="16"/>
                <Setter Property="HasShadow" Value="False"/>
                <Setter Property="Padding" Value="20"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
