<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Optimizer.Mobile.ViewModels"
             x:Class="Optimizer.Mobile.Pages.RecommendationsPage"
             Title="Tips"
             BackgroundColor="{StaticResource BgColor}">
    <ContentPage.BindingContext>
        <vm:RecommendationsViewModel/>
    </ContentPage.BindingContext>

    <Grid>
        <ActivityIndicator IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           Color="{StaticResource AccentColor}"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"/>

        <Label Text="{Binding StatusMessage}"
               IsVisible="{Binding HasError}"
               TextColor="{StaticResource MutedColor}"
               HorizontalOptions="Center"
               VerticalOptions="Center"
               HorizontalTextAlignment="Center"
               Padding="32"/>

        <CollectionView ItemsSource="{Binding Recommendations}" Margin="20,8">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:RecommendationModel">
                    <Frame BackgroundColor="{StaticResource ElevatedColor}"
                           BorderColor="{Binding SeverityColor}"
                           CornerRadius="14"
                           HasShadow="False"
                           Padding="16"
                           Margin="0,0,0,8">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding Title}" FontSize="14" FontAttributes="Bold"/>
                            <Label Text="{Binding Description}" FontSize="13"
                                   TextColor="{StaticResource MutedColor}" LineHeight="1.4"/>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
