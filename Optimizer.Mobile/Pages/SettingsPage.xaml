<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Optimizer.Mobile.ViewModels"
             x:Class="Optimizer.Mobile.Pages.SettingsPage"
             Title="Settings"
             BackgroundColor="{StaticResource BgColor}">
    <ContentPage.BindingContext>
        <vm:SettingsViewModel/>
    </ContentPage.BindingContext>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="8">

            <!-- Server URL row -->
            <Frame BackgroundColor="{StaticResource ElevatedColor}"
                   BorderColor="Transparent" CornerRadius="12" HasShadow="False" Padding="16">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="Server URL" VerticalOptions="Center"/>
                    <Label Grid.Column="1" Text="{Binding ServerUrl}"
                           TextColor="{StaticResource MutedColor}"
                           FontSize="13" VerticalOptions="Center"/>
                </Grid>
            </Frame>

            <!-- Connection status row -->
            <Frame BackgroundColor="{StaticResource ElevatedColor}"
                   BorderColor="Transparent" CornerRadius="12" HasShadow="False" Padding="16">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="Connection" VerticalOptions="Center"/>
                    <Label Grid.Column="1" Text="{Binding StatusText}"
                           TextColor="{StaticResource MutedColor}"
                           FontSize="13" VerticalOptions="Center"/>
                </Grid>
            </Frame>

            <!-- Test connection -->
            <Button Text="Test Connection"
                    Command="{Binding TestConnectionCommand}"
                    Style="{StaticResource SecondaryBtn}"
                    HeightRequest="48"
                    Margin="0,8,0,0"/>

            <!-- Disconnect -->
            <Button Text="Disconnect"
                    Command="{Binding DisconnectCommand}"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource RedColor}"
                    BorderColor="{StaticResource SurfaceColor}"
                    BorderWidth="1"
                    CornerRadius="10"
                    HeightRequest="48"
                    Margin="0,4,0,0"/>

            <Label Text="Optimizer Remote v2.0"
                   FontSize="12"
                   TextColor="{StaticResource MutedColor}"
                   HorizontalOptions="Center"
                   Margin="0,24,0,0"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
