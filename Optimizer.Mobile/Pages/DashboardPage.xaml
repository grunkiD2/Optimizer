<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Optimizer.Mobile.ViewModels"
             x:Class="Optimizer.Mobile.Pages.DashboardPage"
             Title="Status"
             BackgroundColor="{StaticResource BgColor}">
    <ContentPage.BindingContext>
        <vm:DashboardViewModel/>
    </ContentPage.BindingContext>

    <RefreshView Command="{Binding RefreshCommand}"
                 RefreshColor="{StaticResource AccentColor}"
                 IsRefreshing="{Binding IsBusy}">
        <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="12">

                <!-- CPU card -->
                <Frame Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="CPU" FontSize="12" TextColor="{StaticResource MutedColor}" CharacterSpacing="0.5"/>
                        <Label Text="{Binding CpuText}" FontSize="36" FontAttributes="Bold"/>
                        <ProgressBar Progress="{Binding CpuPct}" ProgressColor="{StaticResource AccentColor}"
                                     BackgroundColor="{StaticResource SurfaceColor}" HeightRequest="6"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- Memory card -->
                <Frame Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="MEMORY" FontSize="12" TextColor="{StaticResource MutedColor}" CharacterSpacing="0.5"/>
                        <Label Text="{Binding MemText}" FontSize="36" FontAttributes="Bold"/>
                        <ProgressBar Progress="{Binding MemPct}" ProgressColor="{StaticResource GreenColor}"
                                     BackgroundColor="{StaticResource SurfaceColor}" HeightRequest="6"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- GPU card -->
                <Frame Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="GPU" FontSize="12" TextColor="{StaticResource MutedColor}" CharacterSpacing="0.5"/>
                        <Label Text="{Binding GpuText}" FontSize="36" FontAttributes="Bold"/>
                        <ProgressBar Progress="{Binding GpuPct}" ProgressColor="{StaticResource AmberColor}"
                                     BackgroundColor="{StaticResource SurfaceColor}" HeightRequest="6"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- Sensor 2x2 grid -->
                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="8">
                    <Frame Grid.Column="0" Grid.Row="0" BackgroundColor="{StaticResource ElevatedColor}"
                           BorderColor="Transparent" CornerRadius="12" HasShadow="False" Padding="12">
                        <VerticalStackLayout>
                            <Label Text="CPU TEMP" FontSize="10" TextColor="{StaticResource MutedColor}" CharacterSpacing="0.5"/>
                            <Label Text="{Binding CpuTemp}" FontSize="20" FontAttributes="Bold"/>
                        </VerticalStackLayout>
                    </Frame>
                    <Frame Grid.Column="1" Grid.Row="0" BackgroundColor="{StaticResource ElevatedColor}"
                           BorderColor="Transparent" CornerRadius="12" HasShadow="False" Padding="12">
                        <VerticalStackLayout>
                            <Label Text="GPU TEMP" FontSize="10" TextColor="{StaticResource MutedColor}" CharacterSpacing="0.5"/>
                            <Label Text="{Binding GpuTemp}" FontSize="20" FontAttributes="Bold"/>
                        </VerticalStackLayout>
                    </Frame>
                    <Frame Grid.Column="0" Grid.Row="1" BackgroundColor="{StaticResource ElevatedColor}"
                           BorderColor="Transparent" CornerRadius="12" HasShadow="False" Padding="12">
                        <VerticalStackLayout>
                            <Label Text="CPU POWER" FontSize="10" TextColor="{StaticResource MutedColor}" CharacterSpacing="0.5"/>
                            <Label Text="{Binding CpuPower}" FontSize="20" FontAttributes="Bold"/>
                        </VerticalStackLayout>
                    </Frame>
                    <Frame Grid.Column="1" Grid.Row="1" BackgroundColor="{StaticResource ElevatedColor}"
                           BorderColor="Transparent" CornerRadius="12" HasShadow="False" Padding="12">
                        <VerticalStackLayout>
                            <Label Text="GPU POWER" FontSize="10" TextColor="{StaticResource MutedColor}" CharacterSpacing="0.5"/>
                            <Label Text="{Binding GpuPower}" FontSize="20" FontAttributes="Bold"/>
                        </VerticalStackLayout>
                    </Frame>
                </Grid>

                <!-- Quick actions -->
                <Button Text="Quick Cleanup"
                        Command="{Binding CleanupCommand}"
                        Style="{StaticResource SecondaryBtn}"
                        HeightRequest="50"
                        Margin="0,8,0,0"/>

            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>
</ContentPage>
