<Page
    x:Class="Optimizer.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d"
    d:DesignHeight="650" d:DesignWidth="940">
    <TabControl Margin="12" SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}">

        <!-- ============================ DASHBOARD ============================ -->
        <TabItem Header="Dashboard">
            <Grid Margin="16" DataContext="{Binding Dashboard}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="System Dashboard" FontSize="26" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding LastUpdated, StringFormat='Updated {0}'}" FontSize="13" Foreground="Gray"
                               VerticalAlignment="Bottom" Margin="16,0,0,5" />
                    <Button Content="Refresh" Command="{Binding RefreshCommand}" Margin="16,0,0,0" Padding="12,4" VerticalAlignment="Center" />
                    <Button Content="Apply safe tune" Command="{Binding ApplySafeCommand}" Margin="8,0,0,0" Padding="12,4" VerticalAlignment="Center" />
                    <Button Content="{Binding UndoText}" Command="{Binding UndoAllCommand}" Margin="8,0,0,0" Padding="12,4" VerticalAlignment="Center" />
                </StackPanel>

                <!-- Banners: health + elevation -->
                <StackPanel Grid.Row="1">
                    <Border Background="{Binding HealthBrush}" CornerRadius="6" Padding="10,6" Margin="0,0,0,8">
                        <TextBlock Text="{Binding HealthText}" FontWeight="SemiBold" />
                    </Border>
                    <Border Background="#FFFFF4CE" CornerRadius="6" Padding="10,6" Margin="0,0,0,12"
                            Visibility="{Binding ShowElevationWarning, Converter={StaticResource BoolToVisibility}}">
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="Relaunch as administrator"
                                    Command="{Binding RelaunchAsAdminCommand}" Padding="12,4" Margin="12,0,0,0"
                                    VerticalAlignment="Center" />
                            <TextBlock Text="{Binding ElevationText}" TextWrapping="Wrap" VerticalAlignment="Center" />
                        </DockPanel>
                    </Border>
                </StackPanel>

                <!-- Metric cards (CPU/Mem/GPU click to drill into History) -->
                <UniformGrid Grid.Row="2" Columns="5" Margin="0,0,0,12">
                    <Border Background="#FFF3F4F6" CornerRadius="8" Margin="0,0,6,0" Padding="14" Cursor="Hand"
                            ToolTip="Click to view history">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding ShowHistoryCommand}" />
                        </Border.InputBindings>
                        <StackPanel>
                            <TextBlock Text="CPU" FontSize="13" Foreground="Gray" />
                            <TextBlock Text="{Binding CpuText}" FontSize="26" FontWeight="Bold" />
                            <ProgressBar Value="{Binding CpuUsage}" Maximum="100" Height="6" Margin="0,6,0,0" />
                            <TextBlock Text="{Binding TotalProcessors, StringFormat='{}{0} cores'}" FontSize="11" Foreground="Gray" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>
                    <Border Background="#FFF3F4F6" CornerRadius="8" Margin="3,0,3,0" Padding="14" Cursor="Hand"
                            ToolTip="Click to view history">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding ShowHistoryCommand}" />
                        </Border.InputBindings>
                        <StackPanel>
                            <TextBlock Text="Memory" FontSize="13" Foreground="Gray" />
                            <TextBlock Text="{Binding MemoryText}" FontSize="20" FontWeight="Bold" />
                            <ProgressBar Value="{Binding MemoryPercent}" Maximum="100" Height="6" Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>
                    <Border Background="#FFF3F4F6" CornerRadius="8" Margin="3,0,3,0" Padding="14" Cursor="Hand"
                            ToolTip="Click to view history">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding ShowHistoryCommand}" />
                        </Border.InputBindings>
                        <StackPanel>
                            <TextBlock Text="GPU" FontSize="13" Foreground="Gray" />
                            <TextBlock Text="{Binding GpuText}" FontSize="26" FontWeight="Bold" />
                            <ProgressBar Value="{Binding GpuUsage}" Maximum="100" Height="6" Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>
                    <Border Background="#FFF3F4F6" CornerRadius="8" Margin="3,0,3,0" Padding="14">
                        <StackPanel>
                            <TextBlock Text="Disk" FontSize="13" Foreground="Gray" />
                            <TextBlock Text="{Binding DiskText}" FontSize="16" FontWeight="Bold" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                    <Border Background="#FFF3F4F6" CornerRadius="8" Margin="6,0,0,0" Padding="14">
                        <StackPanel>
                            <TextBlock Text="Network" FontSize="13" Foreground="Gray" />
                            <TextBlock Text="{Binding NetworkText}" FontSize="16" FontWeight="Bold" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Per-core CPU bars -->
                <StackPanel Grid.Row="3" Margin="0,0,0,12">
                    <TextBlock Text="Per-core CPU" FontSize="12" Foreground="Gray" Margin="0,0,0,4" />
                    <ItemsControl ItemsSource="{Binding CoreUsages}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ProgressBar Value="{Binding Value}" Maximum="100" Width="34" Height="8" Margin="0,0,3,3"
                                             ToolTip="{Binding Value, StringFormat='{}{0}%'}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Optimizations (left) + Top processes (right) -->
                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="300" />
                    </Grid.ColumnDefinitions>

                    <GroupBox Grid.Column="1" Header="Top processes (by memory)" Padding="8" Margin="8,0,0,0">
                        <ListView ItemsSource="{Binding TopProcesses}" BorderThickness="0">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Process" Width="120" DisplayMemberBinding="{Binding Name}" />
                                    <GridViewColumn Header="Memory" Width="70" DisplayMemberBinding="{Binding MemoryText}" />
                                    <GridViewColumn Header="" Width="60">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="End" Padding="6,1"
                                                        Command="{Binding DataContext.KillProcessCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                        CommandParameter="{Binding}" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </GroupBox>

                <!-- Optimizations + live preview -->
                <GroupBox Grid.Column="0" Header="Available Optimizations" Padding="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- List -->
                        <ListBox Grid.Row="0" Grid.Column="0" Margin="0,0,8,0"
                                 ItemsSource="{Binding Optimizations}"
                                 SelectedItem="{Binding SelectedOptimization, Mode=TwoWay}" />

                        <!-- Preview / readout (shown once an item is selected) -->
                        <Border Grid.Row="0" Grid.Column="1" BorderBrush="#FFD0D5DD" BorderThickness="1" CornerRadius="6"
                                Padding="14" Background="#FFFCFCFD"
                                Visibility="{Binding HasSelection, Converter={StaticResource BoolToVisibility}}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel DataContext="{Binding SelectedInfo}">
                                    <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding Summary}" TextWrapping="Wrap" Foreground="#FF374151" Margin="0,4,0,8" />

                                    <!-- Badges -->
                                    <WrapPanel Margin="0,0,0,8">
                                        <Border Background="#FFFEF3C7" CornerRadius="4" Padding="6,2" Margin="0,0,6,4"
                                                Visibility="{Binding RequiresAdmin, Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock Text="Requires administrator" FontSize="11" />
                                        </Border>
                                        <Border Background="#FFFFE4E6" CornerRadius="4" Padding="6,2" Margin="0,0,6,4"
                                                Visibility="{Binding RequiresRestart, Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock Text="Restart needed" FontSize="11" />
                                        </Border>
                                        <Border Background="#FFDCFCE7" CornerRadius="4" Padding="6,2" Margin="0,0,6,4"
                                                Visibility="{Binding Reversible, Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock Text="Reversible (undo)" FontSize="11" />
                                        </Border>
                                    </WrapPanel>

                                    <TextBlock Text="What changes" FontWeight="SemiBold" Margin="0,4,0,2" />
                                    <ItemsControl ItemsSource="{Binding Changes}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock TextWrapping="Wrap" Foreground="#FF4B5563" Margin="0,0,0,2">
                                                    <Run Text="•  " /><Run Text="{Binding Mode=OneWay}" />
                                                </TextBlock>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock Text="Pros" FontWeight="SemiBold" Foreground="#FF15803D" Margin="0,8,0,2" />
                                    <ItemsControl ItemsSource="{Binding Pros}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock TextWrapping="Wrap" Margin="0,0,0,2">
                                                    <Run Text="+  " Foreground="#FF15803D" /><Run Text="{Binding Mode=OneWay}" />
                                                </TextBlock>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock Text="Cons / risks" FontWeight="SemiBold" Foreground="#FFB91C1C" Margin="0,8,0,2" />
                                    <ItemsControl ItemsSource="{Binding Cons}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock TextWrapping="Wrap" Margin="0,0,0,2">
                                                    <Run Text="–  " Foreground="#FFB91C1C" /><Run Text="{Binding Mode=OneWay}" />
                                                </TextBlock>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Border Background="#FFEFF6FF" CornerRadius="4" Padding="8" Margin="0,10,0,0">
                                        <StackPanel>
                                            <TextBlock Text="Recommendation" FontWeight="SemiBold" Margin="0,0,0,2" />
                                            <TextBlock Text="{Binding Recommendation}" TextWrapping="Wrap" Foreground="#FF1E3A8A" />
                                        </StackPanel>
                                    </Border>

                                    <Border Background="#FFF5F3FF" CornerRadius="4" Padding="8" Margin="0,8,0,0"
                                            Visibility="{Binding SuggestedImplementation, Converter={StaticResource EmptyToCollapsed}}">
                                        <StackPanel>
                                            <TextBlock Text="Suggested implementation" FontWeight="SemiBold" Margin="0,0,0,2" />
                                            <TextBlock Text="{Binding SuggestedImplementation}" TextWrapping="Wrap" Foreground="#FF5B21B6" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <!-- Apply row -->
                        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="Apply Selected" Command="{Binding ApplyCommand}" Padding="16,6" />
                            <TextBlock Text="⚠ This change cannot be undone." Foreground="#FFB91C1C" VerticalAlignment="Center" Margin="12,0,0,0"
                                       Visibility="{Binding NotReversible, Converter={StaticResource BoolToVisibility}}" />
                        </StackPanel>
                    </Grid>
                </GroupBox>
                </Grid>

                <!-- Recent changes (per-item undo) -->
                <Expander Grid.Row="5" Header="Recent changes — revert individually" Margin="0,12,0,0"
                          Visibility="{Binding HasUndoEntries, Converter={StaticResource BoolToVisibility}}">
                    <Border BorderBrush="#FFD0D5DD" BorderThickness="1" CornerRadius="6" MaxHeight="150">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding UndoEntries}" Margin="6">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel Margin="0,2">
                                            <Button DockPanel.Dock="Right" Content="Revert" Padding="10,2" Margin="8,0,0,0"
                                                    Command="{Binding DataContext.UndoEntryCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}" />
                                            <TextBlock Text="{Binding Description}" TextWrapping="Wrap" VerticalAlignment="Center" Foreground="#FF4B5563" />
                                        </DockPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Expander>

                <!-- Status -->
                <Border Grid.Row="6" Background="#FFEEF2FF" CornerRadius="6" Padding="12,8" Margin="0,12,0,0">
                    <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" />
                </Border>
            </Grid>
        </TabItem>

        <!-- ============================= PROFILES ============================ -->
        <TabItem Header="Profiles">
            <Grid Margin="16" DataContext="{Binding Profiles}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="280" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Profile list -->
                <GroupBox Grid.Row="0" Grid.Column="0" Header="Saved Profiles" Margin="0,0,12,0">
                    <ListBox ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile, Mode=TwoWay}"
                             AllowDrop="True" Drop="ProfilesList_Drop" ToolTip="Drop a .json profile here to import">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="2">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                    <TextBlock FontSize="11" Foreground="Gray">
                                        <Run Text="{Binding ProfileType}" />
                                        <Run Text=" · created " />
                                        <Run Text="{Binding CreatedAt, StringFormat='g'}" />
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </GroupBox>

                <!-- Create / actions -->
                <ScrollViewer Grid.Row="0" Grid.Column="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <GroupBox Header="Presets" Padding="8" Margin="0,0,0,12">
                            <StackPanel>
                                <ComboBox ItemsSource="{Binding Presets}" SelectedItem="{Binding SelectedPreset, Mode=TwoWay}" DisplayMemberPath="Name" />
                                <TextBlock Text="{Binding SelectedPreset.Description}" TextWrapping="Wrap" FontSize="11" Foreground="Gray" Margin="0,6,0,0" />
                                <Button Content="Add to My Profiles" Command="{Binding AddPresetCommand}" Margin="0,8,0,0" Padding="12,5" />
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="{Binding NewProfileHeader}" Padding="8">
                            <StackPanel>
                                <TextBlock Text="Name" Margin="0,0,0,2" />
                                <TextBox Text="{Binding NewProfileName, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Type" Margin="0,8,0,2" />
                                <ComboBox ItemsSource="{Binding ProfileTypes}" SelectedItem="{Binding NewProfileType, Mode=TwoWay}" />
                                <TextBlock Text="Include optimizations" Margin="0,8,0,2" />
                                <Border BorderBrush="#FFD0D5DD" BorderThickness="1" CornerRadius="4" MaxHeight="160">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding AvailableOptimizations}" Margin="4">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" Content="{Binding Title}" Margin="0,2" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Border>
                                <CheckBox Content="Capture current startup state" IsChecked="{Binding CaptureStartupState, Mode=TwoWay}" Margin="0,8,0,0" />
                                <Button Content="{Binding CreateButtonText}" Command="{Binding CreateCommand}" Margin="0,10,0,0" Padding="12,5" />
                                <Button Content="Cancel edit" Command="{Binding CancelEditCommand}" Margin="0,6,0,0" Padding="12,5"
                                        Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}" />
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Selected Profile" Padding="8" Margin="0,12,0,0">
                            <StackPanel>
                                <Button Content="Apply" Command="{Binding ApplyCommand}" Margin="0,0,0,6" Padding="12,5" />
                                <Button Content="Edit" Command="{Binding EditCommand}" Margin="0,0,0,6" Padding="12,5" />
                                <Button Content="Revert" Command="{Binding RevertCommand}" Margin="0,0,0,6" Padding="12,5" />
                                <Button Content="Delete" Command="{Binding DeleteCommand}" Margin="0,0,0,6" Padding="12,5" />
                                <Separator Margin="0,4" />
                                <Button Content="Run at logon" Command="{Binding ScheduleLogonCommand}" Margin="0,0,0,6" Padding="12,5"
                                        ToolTip="Creates a Task Scheduler job that applies this profile at every sign-in" />
                                <Button Content="Remove logon schedule" Command="{Binding RemoveScheduleCommand}" Margin="0,0,0,6" Padding="12,5" />
                                <Separator Margin="0,4" />
                                <Button Content="Export…" Command="{Binding ExportCommand}" Margin="0,0,0,6" Padding="12,5" />
                                <Button Content="Import…" Command="{Binding ImportCommand}" Padding="12,5" />
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>

                <!-- Apply preview -->
                <GroupBox Grid.Row="1" Grid.ColumnSpan="2" Header="What applying this profile will change" Margin="0,12,0,0"
                          Visibility="{Binding HasSelection, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,6">
                            <Border DockPanel.Dock="Right" Background="#FFFEF3C7" CornerRadius="4" Padding="6,2" Margin="8,0,0,0"
                                    Visibility="{Binding PreviewRequiresAdmin, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="Requires administrator" FontSize="11" />
                            </Border>
                            <TextBlock Text="{Binding PreviewSummary}" TextWrapping="Wrap" Foreground="#FF374151" VerticalAlignment="Center" />
                        </DockPanel>
                        <ItemsControl ItemsSource="{Binding PreviewChanges}" MaxHeight="140"
                                      Visibility="{Binding PreviewHasChanges, Converter={StaticResource BoolToVisibility}}">
                            <ItemsControl.Template>
                                <ControlTemplate>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </ControlTemplate>
                            </ItemsControl.Template>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock TextWrapping="Wrap" FontFamily="Consolas" FontSize="12" Foreground="#FF4B5563" Margin="0,0,0,2">
                                        <Run Text="•  " /><Run Text="{Binding Mode=OneWay}" />
                                    </TextBlock>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </GroupBox>

                <!-- Status -->
                <Border Grid.Row="2" Grid.ColumnSpan="2" Background="#FFEEF2FF" CornerRadius="6" Padding="12,8" Margin="0,12,0,0">
                    <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" />
                </Border>
            </Grid>
        </TabItem>

        <!-- ============================= STARTUP ============================= -->
        <TabItem Header="Startup">
            <Grid Margin="16" DataContext="{Binding Startup}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="Startup Programs" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Button Content="Refresh" Command="{Binding RefreshCommand}" Margin="16,0,0,0" Padding="12,4" VerticalAlignment="Center" />
                </StackPanel>

                <Border Grid.Row="1" Background="#FFFFF4CE" CornerRadius="6" Padding="10,6" Margin="0,0,0,10"
                        Visibility="{Binding ShowElevationNote, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock TextWrapping="Wrap"
                               Text="Machine-wide (admin) entries can't be changed without elevation. Relaunch as administrator from the Dashboard tab to manage them." />
                </Border>

                <ListView Grid.Row="2" ItemsSource="{Binding Items}" BorderBrush="#FFD0D5DD">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Enabled" Width="70">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsEnabled, Mode=TwoWay}" HorizontalAlignment="Center" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Name" Width="200" DisplayMemberBinding="{Binding Name}" />
                            <GridViewColumn Header="Location" Width="150" DisplayMemberBinding="{Binding LocationText}" />
                            <GridViewColumn Header="Command" Width="380" DisplayMemberBinding="{Binding Command}" />
                        </GridView>
                    </ListView.View>
                </ListView>

                <Border Grid.Row="3" Background="#FFEEF2FF" CornerRadius="6" Padding="12,8" Margin="0,12,0,0">
                    <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" />
                </Border>
            </Grid>
        </TabItem>

        <!-- ============================= HISTORY ============================= -->
        <TabItem Header="History">
            <Grid Margin="16" DataContext="{Binding History}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="Resource History" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Button Content="{Binding ToggleText}" Command="{Binding ToggleCommand}" Margin="16,0,0,0" Padding="12,4" VerticalAlignment="Center" />
                    <TextBlock Text="Range" VerticalAlignment="Center" Margin="16,0,4,0" />
                    <ComboBox ItemsSource="{Binding RangeOptions}" SelectedItem="{Binding SampleRange, Mode=TwoWay}" Width="70" VerticalAlignment="Center" />
                    <TextBlock Text="samples" VerticalAlignment="Center" Margin="4,0,0,0" Foreground="Gray" />
                    <Button Content="Export CSV" Command="{Binding ExportCsvCommand}" Margin="16,0,0,0" Padding="12,4" VerticalAlignment="Center" />
                    <Button Content="Export PNG" Click="ExportPng_Click" Margin="8,0,0,0" Padding="12,4" VerticalAlignment="Center" />
                </StackPanel>

                <Border Grid.Row="1" BorderBrush="#FFD0D5DD" BorderThickness="1" CornerRadius="8" Padding="8" VerticalAlignment="Top">
                    <StackPanel>
                        <!-- Legend -->
                        <StackPanel Orientation="Horizontal" Margin="4,0,0,8">
                            <Rectangle Width="14" Height="4" Fill="#FF2563EB" VerticalAlignment="Center" />
                            <TextBlock Text="CPU" Margin="4,0,16,0" />
                            <Rectangle Width="14" Height="4" Fill="#FF16A34A" VerticalAlignment="Center" />
                            <TextBlock Text="Memory" Margin="4,0,16,0" />
                            <Rectangle Width="14" Height="4" Fill="#FFEA580C" VerticalAlignment="Center" />
                            <TextBlock Text="GPU" Margin="4,0,0,0" />
                        </StackPanel>
                        <!-- Plot (coordinate space matches HistoryViewModel.PlotWidth/PlotHeight) -->
                        <Canvas x:Name="HistoryPlot" Width="{Binding PlotW}" Height="{Binding PlotH}" Background="#FFFAFAFA" HorizontalAlignment="Left">
                            <Polyline Points="{Binding CpuPoints}" Stroke="#FF2563EB" StrokeThickness="1.5" />
                            <Polyline Points="{Binding MemoryPoints}" Stroke="#FF16A34A" StrokeThickness="1.5" />
                            <Polyline Points="{Binding GpuPoints}" Stroke="#FFEA580C" StrokeThickness="1.5" />
                        </Canvas>
                        <TextBlock Text="0–100% scale · newest on the right" FontSize="11" Foreground="Gray" Margin="4,6,0,0" />
                        <TextBlock Text="{Binding Stats}" FontSize="12" Foreground="#FF374151" Margin="4,6,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Background="#FFEEF2FF" CornerRadius="6" Padding="12,8" Margin="0,12,0,0">
                    <TextBlock Text="{Binding Summary}" TextWrapping="Wrap" />
                </Border>
            </Grid>
        </TabItem>

        <!-- ============================= SETTINGS ============================ -->
        <TabItem Header="Settings">
            <Grid Margin="16" DataContext="{Binding Settings}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Settings" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,12" />

                <StackPanel Grid.Row="1" MaxWidth="520" HorizontalAlignment="Left">
                    <GroupBox Header="Monitoring" Padding="10" Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Metrics refresh interval (seconds)" VerticalAlignment="Center" />
                            <TextBox Text="{Binding MetricsRefreshSeconds, UpdateSourceTrigger=PropertyChanged}" Width="60" Margin="12,0,0,0" />
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Appearance" Padding="10" Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Theme" VerticalAlignment="Center" />
                            <ComboBox ItemsSource="{Binding Themes}" SelectedItem="{Binding Theme, Mode=TwoWay}" Width="180" Margin="12,0,0,0" />
                            <TextBlock Text="(applies on restart)" Foreground="Gray" FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0" />
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Behavior" Padding="10" Margin="0,0,0,12">
                        <StackPanel>
                            <CheckBox Content="Start Optimizer with Windows" IsChecked="{Binding StartWithWindows, Mode=TwoWay}" Margin="0,2" />
                            <CheckBox Content="Always run as administrator (relaunches elevated at startup)" IsChecked="{Binding AlwaysRunAsAdmin, Mode=TwoWay}" Margin="0,2" />
                            <CheckBox Content="Confirm before applying changes" IsChecked="{Binding ConfirmBeforeApply, Mode=TwoWay}" Margin="0,2" />
                            <CheckBox Content="Minimize to system tray" IsChecked="{Binding MinimizeToTray, Mode=TwoWay}" Margin="0,2" />
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Automatic profile switching" Padding="10" Margin="0,0,0,12">
                        <StackPanel>
                            <CheckBox Content="Auto-apply a profile when power source changes" IsChecked="{Binding AutoSwitchEnabled, Mode=TwoWay}" Margin="0,0,0,8" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="On AC power" VerticalAlignment="Center" Margin="0,0,12,6" />
                                <ComboBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,6" ItemsSource="{Binding Profiles}"
                                          DisplayMemberPath="Name" SelectedValuePath="Id" SelectedValue="{Binding OnAcProfileId, Mode=TwoWay}" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="On battery" VerticalAlignment="Center" Margin="0,0,12,0" />
                                <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding Profiles}"
                                          DisplayMemberPath="Name" SelectedValuePath="Id" SelectedValue="{Binding OnBatteryProfileId, Mode=TwoWay}" />
                            </Grid>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Updates" Padding="10" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Update feed URL (JSON with version + url)" Margin="0,0,0,2" />
                            <TextBox Text="{Binding UpdateFeedUrl, UpdateSourceTrigger=PropertyChanged}" />
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Button Content="Check for updates" Command="{Binding CheckForUpdatesCommand}" Padding="12,5" />
                                <TextBlock Text="{Binding UpdateStatus}" VerticalAlignment="Center" Margin="12,0,0,0" Foreground="#FF374151" TextWrapping="Wrap" />
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Diagnostics" Padding="10">
                        <Button Content="Open logs folder" Command="{Binding OpenLogsCommand}" HorizontalAlignment="Left" Padding="12,5" />
                    </GroupBox>
                </StackPanel>

                <Border Grid.Row="2" Background="#FFEEF2FF" CornerRadius="6" Padding="12,8" Margin="0,12,0,0">
                    <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" />
                </Border>
            </Grid>
        </TabItem>

    </TabControl>
</Page>
