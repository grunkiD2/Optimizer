<Window
    x:Class="Optimizer.Views.OnboardingWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Welcome to Optimizer"
    Width="560" Height="440"
    WindowStartupLocation="CenterScreen"
    ResizeMode="NoResize"
    ShowInTaskbar="False">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Welcome to Optimizer" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,12" />

        <StackPanel Grid.Row="1">
            <TextBlock TextWrapping="Wrap" Foreground="#FF374151" Margin="0,0,0,12"
                       Text="A quick tour of the tabs:" />
            <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
                <Run Text="• Dashboard" FontWeight="SemiBold" /><LineBreak />
                <Run Text="Live CPU/memory/GPU/disk/network, a health score, top processes, and one-click optimizations. Every change is reversible from the 'Recent changes' list." />
            </TextBlock>
            <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
                <Run Text="• Profiles" FontWeight="SemiBold" /><LineBreak />
                <Run Text="Bundle optimizations into presets (Gaming, Battery Saver, …), capture startup state, and import/export to share between machines." />
            </TextBlock>
            <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
                <Run Text="• Startup" FontWeight="SemiBold" /><LineBreak />
                <Run Text="Toggle individual startup programs (Run keys and Startup-folder shortcuts) on or off." />
            </TextBlock>
            <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
                <Run Text="• History &amp; Settings" FontWeight="SemiBold" /><LineBreak />
                <Run Text="Track resource usage over time (export CSV/PNG), and tune refresh interval, theme, and start-with-Windows." />
            </TextBlock>
            <TextBlock TextWrapping="Wrap" Foreground="#FF15803D" Margin="0,4,0,0"
                       Text="Tip: system-wide tweaks need administrator rights — use 'Relaunch as administrator' on the Dashboard. Changes are captured for Undo and a restore point is created before risky ones." />
        </StackPanel>

        <Button Grid.Row="2" Content="Get started" Click="Close_Click" HorizontalAlignment="Right" Padding="18,6" Margin="0,12,0,0" />
    </Grid>
</Window>
